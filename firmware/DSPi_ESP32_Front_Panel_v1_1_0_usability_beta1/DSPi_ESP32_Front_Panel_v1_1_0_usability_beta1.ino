static const uint8_t REQ_GET_SPDIF_RX_CH_STATUS = 0xE3;
static const uint8_t REQ_GET_SPDIF_INPUT_CONFIG = 0xEF;
static const uint8_t REQ_GET_PLATFORM = 0x7F;

struct UartFrame {
  uint8_t type;
  uint8_t status;
  uint16_t length;
  uint8_t payload[64];
};

enum DspiFrameReadResult : uint8_t {
  DSPI_FRAME_OK,
  DSPI_FRAME_TIMEOUT,
  DSPI_FRAME_CRC_ERROR,
  DSPI_FRAME_OVERSIZE,
  DSPI_FRAME_FORMAT_ERROR
};

enum DspiTxnResult : uint8_t {
  DSPI_TXN_OK,
  DSPI_TXN_TIMEOUT,
  DSPI_TXN_LOCAL_CRC,
  DSPI_TXN_LOCAL_FRAME,
  DSPI_TXN_BUSY,
  DSPI_TXN_ERROR,
  DSPI_TXN_BLOCKED,
  DSPI_TXN_BULK_LOCKED,
  DSPI_TXN_REMOTE_CRC,
  DSPI_TXN_OVERSIZE,
  DSPI_TXN_FRAME_ERROR,
  DSPI_TXN_UNEXPECTED,
  DSPI_TXN_REENTRANT
};

// Explicit prototypes prevent Arduino's auto-prototyper from placing these
// declarations before the transport-specific types above.
void acceptDspiNotification(const UartFrame &frame);
DspiFrameReadResult dspiReadFrame(UartFrame &frame, uint16_t timeoutMs);
const char *dspiTxnResultText(DspiTxnResult result);
DspiTxnResult dspiResultForStatus(uint8_t status);
bool dspiResultCanRetry(DspiTxnResult result);
DspiTxnResult dspiTransactionResult(bool isGet, uint8_t request, uint16_t value,
                                    uint16_t index, const uint8_t *txPayload,
                                    uint16_t txLength, uint8_t *rxPayload,
                                    uint16_t rxCapacity, uint16_t &rxLength,
                                    bool affectLinkState);
DspiTxnResult dspiGetResult(uint8_t request, uint16_t value, uint16_t length,
                           uint8_t *payload, uint16_t capacity, uint16_t &received,
                           bool affectLinkState);

uint16_t dspiCrc16Step(uint16_t crc, uint8_t value)
{
  crc ^= (uint16_t)value << 8;
  for (uint8_t bit = 0; bit < 8; bit++) {
    crc = (crc & 0x8000) ? (uint16_t)((crc << 1) ^ 0x1021) : (uint16_t)(crc << 1);
  }
  return crc;
}

void dspiDrainRx()
{
  while (DspiSerial.available() > 0) DspiSerial.read();
}

void dspiSendRequest(bool isGet, uint8_t request, uint16_t value,
                     uint16_t index, const uint8_t *payload, uint16_t length)
{
  uint8_t header[8];
  header[0] = isGet ? UART_TYPE_GET : UART_TYPE_SET;
  header[1] = request;
  header[2] = (uint8_t)(value & 0xFF);
  header[3] = (uint8_t)(value >> 8);
  header[4] = (uint8_t)(index & 0xFF);
  header[5] = (uint8_t)(index >> 8);
  header[6] = (uint8_t)(length & 0xFF);
  header[7] = (uint8_t)(length >> 8);

  uint16_t crc = 0xFFFF;
  for (uint8_t i = 0; i < sizeof(header); i++) crc = dspiCrc16Step(crc, header[i]);
  if (!isGet && payload) {
    for (uint16_t i = 0; i < length; i++) crc = dspiCrc16Step(crc, payload[i]);
  }

  DspiSerial.write(UART_SYNC);
  DspiSerial.write(header, sizeof(header));
  if (!isGet && payload && length) DspiSerial.write(payload, length);
  DspiSerial.write((uint8_t)(crc & 0xFF));
  DspiSerial.write((uint8_t)(crc >> 8));
  DspiSerial.flush();
}

bool dspiReadByteUntil(uint8_t &value, unsigned long deadline)
{
  while ((long)(millis() - deadline) < 0) {
    if (DspiSerial.available() > 0) {
      value = (uint8_t)DspiSerial.read();
      return true;
    }
    delay(0);
  }
  return false;
}

void acceptDspiNotification(const UartFrame &frame)
{
  // A CRC-valid type-0x40 frame is never eligible to satisfy a request. The
  // full refresh is delayed so PRESET_LOADED/BULK_INVALIDATED cannot race the
  // Console's flash-write blackout or the immediately following apply work.
  if (frame.length >= 2 && frame.payload[0] == 2 &&
      (frame.payload[1] == 0x03 || frame.payload[1] == 0x04)) {
    scheduledSourceReason = "preset refresh";
  }
  notificationRefreshAt = millis() + DSPI_NOTIFICATION_REFRESH_MS;
}

DspiFrameReadResult dspiReadFrame(UartFrame &frame, uint16_t timeoutMs)
{
  unsigned long deadline = millis() + timeoutMs;
  uint8_t value = 0;

  do {
    if (!dspiReadByteUntil(value, deadline)) return DSPI_FRAME_TIMEOUT;
  } while (value != UART_SYNC);

  if (!dspiReadByteUntil(frame.type, deadline)) return DSPI_FRAME_TIMEOUT;
  if (frame.type != UART_RESP_SET && frame.type != UART_RESP_GET && frame.type != UART_TYPE_NOTIFY) {
    return DSPI_FRAME_FORMAT_ERROR;
  }

  if (!dspiReadByteUntil(frame.status, deadline)) return DSPI_FRAME_TIMEOUT;
  uint8_t lenLo = 0, lenHi = 0;
  if (!dspiReadByteUntil(lenLo, deadline)) return DSPI_FRAME_TIMEOUT;
  if (!dspiReadByteUntil(lenHi, deadline)) return DSPI_FRAME_TIMEOUT;
  frame.length = (uint16_t)lenLo | ((uint16_t)lenHi << 8);

  uint16_t crc = 0xFFFF;
  crc = dspiCrc16Step(crc, frame.type);
  crc = dspiCrc16Step(crc, frame.status);
  crc = dspiCrc16Step(crc, lenLo);
  crc = dspiCrc16Step(crc, lenHi);

  bool oversize = frame.length > sizeof(frame.payload);
  for (uint16_t i = 0; i < frame.length; i++) {
    uint8_t b = 0;
    if (!dspiReadByteUntil(b, deadline)) return DSPI_FRAME_TIMEOUT;
    crc = dspiCrc16Step(crc, b);
    if (!oversize) frame.payload[i] = b;
  }

  uint8_t crcLo = 0, crcHi = 0;
  if (!dspiReadByteUntil(crcLo, deadline)) return DSPI_FRAME_TIMEOUT;
  if (!dspiReadByteUntil(crcHi, deadline)) return DSPI_FRAME_TIMEOUT;
  uint16_t receivedCrc = (uint16_t)crcLo | ((uint16_t)crcHi << 8);
  if (receivedCrc != crc) return DSPI_FRAME_CRC_ERROR;
  if (oversize) return DSPI_FRAME_OVERSIZE;

  if (frame.type == UART_TYPE_NOTIFY) {
    if (frame.status != 0) return DSPI_FRAME_FORMAT_ERROR;
    acceptDspiNotification(frame);
  }
  return DSPI_FRAME_OK;
}

const char *dspiTxnResultText(DspiTxnResult result)
{
  switch (result) {
    case DSPI_TXN_TIMEOUT: return "timeout";
    case DSPI_TXN_LOCAL_CRC: return "local CRC";
    case DSPI_TXN_LOCAL_FRAME: return "local frame";
    case DSPI_TXN_BUSY: return "BUSY";
    case DSPI_TXN_ERROR: return "ERROR";
    case DSPI_TXN_BLOCKED: return "BLOCKED";
    case DSPI_TXN_BULK_LOCKED: return "BULK_LOCKED";
    case DSPI_TXN_REMOTE_CRC: return "CRC_ERROR";
    case DSPI_TXN_OVERSIZE: return "OVERSIZE";
    case DSPI_TXN_FRAME_ERROR: return "FRAME_ERROR";
    case DSPI_TXN_UNEXPECTED: return "unexpected response";
    case DSPI_TXN_REENTRANT: return "request already active";
    default: return "OK";
  }
}

DspiTxnResult dspiResultForStatus(uint8_t status)
{
  switch (status) {
    case CTRL_STATUS_OK: return DSPI_TXN_OK;
    case CTRL_STATUS_BUSY: return DSPI_TXN_BUSY;
    case CTRL_STATUS_ERROR: return DSPI_TXN_ERROR;
    case CTRL_STATUS_BLOCKED: return DSPI_TXN_BLOCKED;
    case CTRL_STATUS_BULK_LOCKED: return DSPI_TXN_BULK_LOCKED;
    case CTRL_STATUS_CRC_ERROR: return DSPI_TXN_REMOTE_CRC;
    case CTRL_STATUS_OVERSIZE: return DSPI_TXN_OVERSIZE;
    case CTRL_STATUS_FRAME_ERROR: return DSPI_TXN_FRAME_ERROR;
    default: return DSPI_TXN_UNEXPECTED;
  }
}

bool dspiResultCanRetry(DspiTxnResult result)
{
  return result == DSPI_TXN_TIMEOUT || result == DSPI_TXN_LOCAL_CRC ||
         result == DSPI_TXN_BUSY || result == DSPI_TXN_BULK_LOCKED ||
         result == DSPI_TXN_REMOTE_CRC;
}

void dspiRecoverAfterTimeout(uint8_t request)
{
  // UART responses have no request ID. After a timeout, keep a bounded
  // quarantine in which complete late frames are parsed and discarded while
  // valid notifications are still accepted. A minimum quarantine plus a
  // final quiet interval is the proof boundary before another request.
  uint32_t startedAt = millis();
  uint32_t lastActivityAt = startedAt;

  while ((uint32_t)(millis() - startedAt) < DSPI_RECOVERY_MAX_MS) {
    uint32_t elapsed = (uint32_t)(millis() - startedAt);
    if (DspiSerial.available() > 0) {
      UartFrame lateFrame = {};
      uint16_t remaining = (uint16_t)(DSPI_RECOVERY_MAX_MS - elapsed);
      DspiFrameReadResult readResult = dspiReadFrame(lateFrame, std::min<uint16_t>(25, remaining));
      lastActivityAt = millis();
      if (readResult == DSPI_FRAME_OK && lateFrame.type != UART_TYPE_NOTIFY) {
        Serial.printf("DSPi recovery discarded late frame: req=0x%02X type=0x%02X len=%u\n",
                      request, lateFrame.type, lateFrame.length);
      }
    } else {
      bool minimumPassed = elapsed >= DSPI_RECOVERY_MIN_MS;
      bool lineQuiet = (uint32_t)(millis() - lastActivityAt) >= DSPI_RECOVERY_QUIET_MS;
      if (minimumPassed && lineQuiet) return;
      delay(1);
    }
  }

  // If traffic persisted through the cap, a quiet interval was not proven.
  // Reset the ESP32 UART receiver and hold it disabled for the same quiet
  // interval. This is the bounded resynchronization fallback, not a raw drain.
  Serial.printf("DSPi recovery UART reset: req=0x%02X\n", request);
  DspiSerial.end();
  delay(DSPI_RECOVERY_QUIET_MS);
  DspiSerial.begin(DSPI_UART_BAUD, SERIAL_8N1, DSPI_UART_RX_PIN, DSPI_UART_TX_PIN);
}

DspiTxnResult dspiTransactionResult(bool isGet, uint8_t request, uint16_t value,
                                    uint16_t index, const uint8_t *txPayload,
                                    uint16_t txLength, uint8_t *rxPayload,
                                    uint16_t rxCapacity, uint16_t &rxLength,
                                    bool affectLinkState)
{
  rxLength = 0;
  if (dspiRequestInFlight) return DSPI_TXN_REENTRANT;
  dspiRequestInFlight = true;
  DspiTxnResult finalResult = DSPI_TXN_TIMEOUT;

  for (uint8_t attempt = 0; attempt < DSPI_TRANSACTION_ATTEMPTS; attempt++) {
    dspiSendRequest(isGet, request, value, index, txPayload, txLength);

    unsigned long deadline = millis() + DSPI_RESPONSE_TIMEOUT_MS;
    finalResult = DSPI_TXN_TIMEOUT;
    while ((long)(millis() - deadline) < 0) {
      UartFrame frame = {};
      uint16_t remaining = (uint16_t)max(1L, (long)(deadline - millis()));
      DspiFrameReadResult readResult = dspiReadFrame(frame, remaining);
      if (readResult == DSPI_FRAME_TIMEOUT) {
        finalResult = DSPI_TXN_TIMEOUT;
        break;
      }
      if (readResult == DSPI_FRAME_CRC_ERROR) {
        finalResult = DSPI_TXN_LOCAL_CRC;
        break;
      }
      if (readResult == DSPI_FRAME_OVERSIZE || readResult == DSPI_FRAME_FORMAT_ERROR) {
        finalResult = DSPI_TXN_LOCAL_FRAME;
        break;
      }
      if (frame.type == UART_TYPE_NOTIFY) continue;

      uint8_t expectedType = isGet ? UART_RESP_GET : UART_RESP_SET;
      if (frame.type != expectedType) {
        Serial.printf("DSPi discarded response type mismatch: req=0x%02X type=0x%02X\n",
                      request, frame.type);
        continue;
      }

      finalResult = dspiResultForStatus(frame.status);
      if (finalResult != DSPI_TXN_OK) break;
      if ((!isGet && frame.length != 0) || (isGet && frame.length > rxCapacity)) {
        finalResult = DSPI_TXN_UNEXPECTED;
        break;
      }

      rxLength = frame.length;
      if (rxPayload && rxLength) memcpy(rxPayload, frame.payload, rxLength);
      dspiRequestInFlight = false;
      dspiFailureCount = 0;
      dspi.connected = true;
      return DSPI_TXN_OK;
    }

    if (finalResult == DSPI_TXN_TIMEOUT) dspiRecoverAfterTimeout(request);
    if (!dspiResultCanRetry(finalResult) || attempt + 1 >= DSPI_TRANSACTION_ATTEMPTS) break;
    Serial.printf("DSPi retry: req=0x%02X reason=%s attempt=%u/%u\n", request,
                  dspiTxnResultText(finalResult), attempt + 2, DSPI_TRANSACTION_ATTEMPTS);
    delay(DSPI_RETRY_DELAY_MS);
  }

  dspiRequestInFlight = false;
  if (affectLinkState) {
    dspiFailureCount++;
    if (dspiFailureCount >= 4 && dspi.connected) {
      dspi.connected = false;
      resetMetersForStateChange("DSPi link lost");
    }
  }
  if (affectLinkState) {
    Serial.printf("DSPi request failed: req=0x%02X reason=%s\n",
                  request, dspiTxnResultText(finalResult));
  }
  return finalResult;
}

DspiTxnResult dspiGetResult(uint8_t request, uint16_t value, uint16_t length,
                           uint8_t *payload, uint16_t capacity, uint16_t &received,
                           bool affectLinkState = true)
{
  return dspiTransactionResult(true, request, value, 2, nullptr, length,
                               payload, capacity, received, affectLinkState);
}

bool dspiGet(uint8_t request, uint16_t value, uint16_t length,
             uint8_t *payload, uint16_t capacity, uint16_t &received,
             bool affectLinkState = true)
{
  return dspiGetResult(request, value, length, payload, capacity, received,
                       affectLinkState) == DSPI_TXN_OK;
}

bool dspiSet(uint8_t request, uint16_t value, const uint8_t *payload,
             uint16_t length, bool affectLinkState = true)
{
  uint16_t ignored = 0;
  return dspiTransactionResult(false, request, value, 2, payload, length,
                               nullptr, 0, ignored, affectLinkState) == DSPI_TXN_OK;
}

bool dspiGetByte(uint8_t request, uint8_t &value, uint16_t wValue = 0)
{
  uint8_t payload[4] = {0};
  uint16_t length = 0;
  if (!dspiGet(request, wValue, 1, payload, sizeof(payload), length) || length != 1) {
    if (length != 0) Serial.printf("DSPi length reject: req=0x%02X expected=1 actual=%u\n", request, length);
    return false;
  }
  value = payload[0];
  return true;
}

bool dspiGetFloat(uint8_t request, float &value)
{
  uint8_t payload[4] = {0};
  uint16_t length = 0;
  if (!dspiGet(request, 0, 4, payload, sizeof(payload), length) || length != 4) {
    if (length != 0) Serial.printf("DSPi length reject: req=0x%02X expected=4 actual=%u\n", request, length);
    return false;
  }
  memcpy(&value, payload, sizeof(float));
  return isfinite(value);
}

bool dspiSetByte(uint8_t request, uint8_t value)
{
  return dspiSet(request, 0, &value, 1);
}

bool dspiSetFloat(uint8_t request, float value)
{
  uint8_t payload[4];
  memcpy(payload, &value, sizeof(float));
  return dspiSet(request, 0, payload, sizeof(payload));
}

uint32_t readLe32(const uint8_t *p)
{
  return (uint32_t)p[0] | ((uint32_t)p[1] << 8) |
         ((uint32_t)p[2] << 16) | ((uint32_t)p[3] << 24);
}

uint16_t readLe16(const uint8_t *p)
{
  return (uint16_t)p[0] | ((uint16_t)p[1] << 8);
}

// -----------------------------------------------------------------------------
// DSPi state synchronisation
// -----------------------------------------------------------------------------

void showToast(const String &text, uint16_t durationMs = 1400)
{
  toastText = text;
  toastUntil = millis() + durationMs;
}

void showFeatureStateToast(const char *featureName, bool enabled)
{
  showToast(String(featureName) + (enabled ? " On" : " Off"), 900);
}

String cleanDisplayText(String value, uint8_t maxChars)
{
  value.trim();
  String out;
  for (uint16_t i = 0; i < value.length() && out.length() < maxChars; i++) {
    char c = value.charAt(i);
    bool ok = (c >= 'A' && c <= 'Z') || (c >= 'a' && c <= 'z') ||
              (c >= '0' && c <= '9') || c == ' ' || c == '-' ||
              c == '.' || c == '/' || c == '+';
    out += ok ? c : ' ';
  }
  while (out.indexOf("  ") >= 0) out.replace("  ", " ");
  out.trim();
  return out;
}

bool getExact(uint8_t request, uint16_t value, uint16_t expectedLength,
              uint8_t *payload, uint16_t capacity, bool affectLinkState = true)
{
  uint16_t length = 0;
  if (!dspiGet(request, value, expectedLength, payload, capacity, length,
               affectLinkState)) return false;
  if (length != expectedLength) {
    Serial.printf("DSPi length reject: req=0x%02X expected=%u actual=%u\n",
                  request, expectedLength, length);
    return false;
  }
  return true;
}

bool getExactByte(uint8_t request, uint8_t &value, uint16_t wValue = 0,
                  bool affectLinkState = true)
{
  uint8_t payload[1] = {0};
  if (!getExact(request, wValue, 1, payload, sizeof(payload), affectLinkState)) return false;
  value = payload[0];
  return true;
}

bool getExactFloat(uint8_t request, float &value, bool affectLinkState = true)
{
  uint8_t payload[4] = {0};
  if (!getExact(request, 0, 4, payload, sizeof(payload), affectLinkState)) return false;
  memcpy(&value, payload, sizeof(value));
  return isfinite(value);
}

bool syncPresetNameCandidate(DspiState &candidate, uint8_t slot)
{
  if (slot >= 10) return false;
  if ((candidate.occupiedPresets & (1u << slot)) == 0) {
    memset(candidate.presetNames[slot], 0, sizeof(candidate.presetNames[slot]));
    return true;
  }

  uint8_t namePayload[32] = {0};
  if (!getExact(REQ_PRESET_GET_NAME, slot, 32, namePayload, sizeof(namePayload))) {
    return false;
  }

  memset(candidate.presetNames[slot], 0, sizeof(candidate.presetNames[slot]));
  memcpy(candidate.presetNames[slot], namePayload, 31);
  candidate.presetNames[slot][31] = 0;
  return true;
}

bool syncPresetDirectoryCandidate(DspiState &candidate, bool names)
{
  uint8_t payload[7] = {0};
  if (!getExact(REQ_PRESET_GET_DIR, 0, 7, payload, sizeof(payload))) return false;
  uint16_t occupied = readLe16(payload);
  if ((occupied & ~0x03FFu) || payload[6] > 1) return false;
  candidate.occupiedPresets = occupied;
  candidate.masterVolumeMode = payload[6];

  for (uint8_t slot = 0; slot < 10; slot++) {
    if ((occupied & (1u << slot)) == 0) {
      memset(candidate.presetNames[slot], 0, sizeof(candidate.presetNames[slot]));
    } else if (names && !syncPresetNameCandidate(candidate, slot)) {
      return false;
    }
  }
  return true;
}

bool syncPsybassCandidate(DspiState &candidate)
{
  uint8_t enabledPayload[1] = {0};
  uint16_t enabledLength = 0;
  DspiTxnResult probeResult = dspiGetResult(REQ_GET_PSYBASS, 0, 1,
                                            enabledPayload, sizeof(enabledPayload),
                                            enabledLength, false);
  if (probeResult == DSPI_TXN_ERROR) {
    candidate.psybassCapabilityKnown = true;
    candidate.psybassSupported = false;
    candidate.psybassEnabled = false;
    return true;
  }
  if (probeResult != DSPI_TXN_OK || enabledLength != 1 || enabledPayload[0] > 1) return false;

  candidate.psybassCapabilityKnown = true;
  candidate.psybassSupported = true;
  candidate.psybassEnabled = enabledPayload[0] != 0;
  if (!getExactFloat(REQ_GET_PSYBASS_CUTOFF, candidate.psybassCutoffHz) ||
      !getExactFloat(REQ_GET_PSYBASS_HARMONICS, candidate.psybassHarmonicsDb) ||
      !getExactFloat(REQ_GET_PSYBASS_DRIVE, candidate.psybassDriveDb) ||
      !getExactFloat(REQ_GET_PSYBASS_CHARACTER, candidate.psybassCharacterPct) ||
      !getExactFloat(REQ_GET_PSYBASS_ORIGINAL, candidate.psybassOriginalDb)) return false;

  return candidate.psybassCutoffHz >= 30.0f && candidate.psybassCutoffHz <= 300.0f &&
         candidate.psybassHarmonicsDb >= -24.0f && candidate.psybassHarmonicsDb <= 12.0f &&
         candidate.psybassDriveDb >= 0.0f && candidate.psybassDriveDb <= 18.0f &&
         candidate.psybassCharacterPct >= 0.0f && candidate.psybassCharacterPct <= 100.0f &&
         candidate.psybassOriginalDb >= -60.0f && candidate.psybassOriginalDb <= 0.0f;
}

bool isSpdifSource(InputSource source)
{
  return source == SRC_OPTICAL || source == SRC_OPTICAL_2 || source == SRC_OPTICAL_3;
}

bool picoInputPinSane(uint8_t pin, uint8_t platform, bool allowUnset)
{
  if (allowUnset && pin == 0xFF) return true;
  uint8_t maximum = platform == 1 ? 47 : 29;
  return pin <= maximum;
}

bool inputSourceAvailable(InputSource source)
{
  switch (source) {
    case SRC_USB:
    case SRC_OPTICAL:
    case SRC_I2S:
      return true;
    case SRC_ADAT:
      return dspi.platform == 1 && dspi.adatInputEnabled && dspi.adatInputPin != 0xFF;
    case SRC_OPTICAL_2:
      return (dspi.spdifOptionalEnableMask & 0x01u) != 0;
    case SRC_OPTICAL_3:
      return (dspi.spdifOptionalEnableMask & 0x02u) != 0;
  }
  return false;
}

InputSource nextInputSourceChoice(InputSource current, int direction)
{
  // Only sources present in the last verified Console inventory are exposed.
  // USB, first S/PDIF and I2S are always available, so this always terminates.
  for (uint8_t step = 0; step < 6; step++) {
    current = (InputSource)(((int)current +
                             (direction >= 0 ? 1 : -1) + 6) % 6);
    if (inputSourceAvailable(current)) return current;
  }
  return current;
}

String inputSourceDisplayText(InputSource source)
{
  switch (source) {
    case SRC_USB: return "USB";
    case SRC_OPTICAL: return "S/PDIF";
    case SRC_I2S: return "I2S";
    case SRC_ADAT: return "ADAT";
    case SRC_OPTICAL_2: return "S/PDIF 2";
    case SRC_OPTICAL_3: return "S/PDIF 3";
  }
  return "Unknown";
}

bool syncCurrentState(bool includePresetNames)
{
  // Nothing visible changes until every required field has passed its exact
  // length and value checks. This prevents a stale response from producing a
  // half-old/half-new UI snapshot after a Console flash blackout.
  DspiState candidate = dspi;
  uint8_t platformPayload[4] = {0};
  if (!getExact(REQ_GET_PLATFORM, 0, 4, platformPayload, sizeof(platformPayload))) return false;
  if (platformPayload[0] > 1 || platformPayload[3] == 0) return false;
  candidate.platform = platformPayload[0];
  candidate.firmwareMajor = platformPayload[1];
  candidate.firmwareMinorPatchBcd = platformPayload[2];
  candidate.outputChannels = platformPayload[3];

  uint8_t spdifConfig[5] = {0};
  if (!getExact(REQ_GET_SPDIF_INPUT_CONFIG, 0, 5,
                spdifConfig, sizeof(spdifConfig))) return false;
  // Official beta5 byte 1 is an all-input mask: bit 0 is S/PDIF 1 and is
  // always set; bits 1/2 are the optional inputs. Store only the optional
  // part, shifted down, so availability consistently uses bits 0/1.
  if (spdifConfig[0] != 3 || (spdifConfig[1] & ~0x07u) != 0 ||
      (spdifConfig[1] & 0x01u) == 0) return false;
  candidate.spdifInputCount = spdifConfig[0];
  candidate.spdifOptionalEnableMask = (spdifConfig[1] >> 1) & 0x03u;
  for (uint8_t input = 0; input < 3; input++) {
    bool allowUnset = input != 0 &&
      (candidate.spdifOptionalEnableMask & (1u << (input - 1))) == 0;
    if (!picoInputPinSane(spdifConfig[input + 2], candidate.platform, allowUnset)) return false;
    candidate.spdifPins[input] = spdifConfig[input + 2];
  }

  uint8_t adatEnablePayload[1] = {0};
  uint8_t adatPinPayload[1] = {0};
  if (!getExact(REQ_GET_ADAT_INPUT_ENABLE, 0, 1,
                adatEnablePayload, sizeof(adatEnablePayload)) ||
      adatEnablePayload[0] > 1) return false;
  if (!getExact(REQ_GET_ADAT_INPUT_PIN, 0, 1,
                adatPinPayload, sizeof(adatPinPayload)) ||
      !picoInputPinSane(adatPinPayload[0], candidate.platform, true)) return false;
  candidate.adatInputEnabled = adatEnablePayload[0] != 0;
  candidate.adatInputPin = adatPinPayload[0];

  uint8_t byteValue = 0;
  if (!getExactByte(REQ_GET_INPUT_SOURCE, byteValue) || byteValue > SRC_OPTICAL_3) return false;
  candidate.source = (InputSource)byteValue;

  if (!getExactFloat(REQ_GET_USER_VOLUME, candidate.volumeDb) ||
      !getExactFloat(REQ_GET_MASTER_VOLUME, candidate.masterVolumeDb)) return false;
  if (!getExactByte(REQ_GET_USER_MUTE, byteValue) || byteValue > 1) return false;
  candidate.muted = byteValue != 0;
  if (!getExactByte(REQ_PRESET_GET_ACTIVE, byteValue) || byteValue >= 10) return false;
  candidate.activePreset = byteValue;

  if (!getExactByte(REQ_GET_LOUDNESS, byteValue) || byteValue > 1) return false;
  candidate.loudnessEnabled = byteValue != 0;
  if (!getExactFloat(REQ_GET_LOUDNESS_REFERENCE, candidate.loudnessReferenceSpl) ||
      !getExactFloat(REQ_GET_LOUDNESS_INTENSITY, candidate.loudnessIntensity)) return false;

  if (!getExactByte(REQ_GET_CROSSFEED, byteValue) || byteValue > 1) return false;
  candidate.crossfeedEnabled = byteValue != 0;
  if (!getExactByte(REQ_GET_CROSSFEED_PRESET, byteValue) || byteValue > 3) return false;
  candidate.crossfeedPreset = byteValue;
  if (!getExactFloat(REQ_GET_CROSSFEED_FREQUENCY, candidate.crossfeedFrequencyHz) ||
      !getExactFloat(REQ_GET_CROSSFEED_FEED, candidate.crossfeedFeedDb)) return false;

  if (!getExactByte(REQ_GET_LEVELLER_ENABLE, byteValue) || byteValue > 1) return false;
  candidate.levellerEnabled = byteValue != 0;
  if (!getExactFloat(REQ_GET_LEVELLER_AMOUNT, candidate.levellerAmount)) return false;
  if (!getExactByte(REQ_GET_LEVELLER_SPEED, byteValue) || byteValue > 2) return false;
  candidate.levellerSpeed = byteValue;
  if (!getExactFloat(REQ_GET_LEVELLER_MAX_GAIN, candidate.levellerMaxGainDb) ||
      !getExactFloat(REQ_GET_LEVELLER_GATE, candidate.levellerGateDb)) return false;
  if (!getExactByte(REQ_GET_LEVELLER_LOOKAHEAD, byteValue) || byteValue > 1) return false;
  candidate.levellerLookahead = byteValue != 0;

  if (!syncPsybassCandidate(candidate)) return false;
  if (!syncPresetDirectoryCandidate(candidate, includePresetNames)) return false;
  if (!includePresetNames &&
      (uiView == VIEW_VISUALIZER || pendingPresetOverlay ||
       candidate.activePreset != dspi.activePreset) &&
      !syncPresetNameCandidate(candidate, candidate.activePreset)) return false;

  uint8_t samplePayload[4] = {0};
  if (!getExact(REQ_GET_STATUS, 15, 4, samplePayload, sizeof(samplePayload))) return false;
  candidate.sampleRate = readLe32(samplePayload);
  candidate.spdifState = 0;
  candidate.spdifNonAudio = false;
  candidate.adatState = 0;
  candidate.adatClockMode = 0;
  candidate.adatRateOk = false;
  candidate.adatDetectedRate = 0;
  candidate.adatMeasuredHz = 0;
  if (isSpdifSource(candidate.source)) {
    uint8_t statusPayload[16] = {0};
    if (!getExact(REQ_GET_SPDIF_RX_STATUS, 0, 16, statusPayload, sizeof(statusPayload))) return false;
    if (statusPayload[0] > 3 || statusPayload[1] != (uint8_t)candidate.source) return false;
    candidate.spdifState = statusPayload[0];
    candidate.sampleRate = readLe32(statusPayload + 4);
    if (candidate.spdifState == 2) {
      uint8_t channelStatus[24] = {0};
      if (!getExact(REQ_GET_SPDIF_RX_CH_STATUS, 0, 24,
                    channelStatus, sizeof(channelStatus))) return false;
      candidate.spdifNonAudio = (channelStatus[0] & 0x02u) != 0;
    }
  } else if (candidate.source == SRC_ADAT) {
    uint8_t adatStatus[20] = {0};
    if (!getExact(REQ_GET_ADAT_INPUT_STATUS, 0, 20,
                  adatStatus, sizeof(adatStatus))) return false;
    if (adatStatus[0] > 4 || adatStatus[1] > 1 || adatStatus[2] > 1 ||
        adatStatus[4] > 1 ||
        !picoInputPinSane(adatStatus[3], candidate.platform, true) ||
        adatStatus[2] != (candidate.adatInputEnabled ? 1 : 0) ||
        adatStatus[3] != candidate.adatInputPin) return false;
    candidate.adatState = adatStatus[0];
    candidate.adatClockMode = adatStatus[1];
    candidate.adatRateOk = adatStatus[4] != 0;
    candidate.adatDetectedRate = readLe32(adatStatus + 12);
    candidate.adatMeasuredHz = readLe32(adatStatus + 16);
    if (candidate.adatState == 3 && candidate.adatDetectedRate != 0) {
      candidate.sampleRate = candidate.adatDetectedRate;
    }
  }

  const bool oldConnected = dspi.connected;
  InputSource oldSource = dspi.source;
  uint8_t oldActivePreset = dspi.activePreset;
  uint8_t oldSpdifState = dspi.spdifState;
  uint8_t oldAdatState = dspi.adatState;
  bool oldSpdifNonAudio = dspi.spdifNonAudio;
  candidate.connected = true;
  dspi = candidate;

  const bool sourceChanged = oldSource != dspi.source;
  const bool presetChanged = oldActivePreset != dspi.activePreset;
  const bool spdifBecameInvalid = isSpdifSource(dspi.source) &&
      oldSource == dspi.source &&
      ((oldSpdifState == 2 && (dspi.spdifState != 2 || dspi.spdifNonAudio)) ||
       (oldSpdifNonAudio != dspi.spdifNonAudio && dspi.spdifNonAudio));
  const bool adatBecameInvalid = dspi.source == SRC_ADAT &&
      oldSource == dspi.source && oldAdatState == 3 && dspi.adatState != 3;
  if (!oldConnected || sourceChanged || presetChanged ||
      spdifBecameInvalid || adatBecameInvalid) {
    const char *reason = sourceChanged ? "input source changed" :
                         presetChanged ? "preset changed" :
                         spdifBecameInvalid ? "S/PDIF signal lost" :
                         adatBecameInvalid ? "ADAT signal lost" :
                         "DSPi link restored";
    resetMetersForStateChange(reason);
  }

  // Publish only verified DSPi state. A preset load can also restore its saved
  // source; in that case the preset identity is the more useful distance view.
  if (oldConnected && pendingPresetOverlay &&
      dspi.activePreset == pendingPresetOverlaySlot) {
    showPresetChangeOverlay(dspi.activePreset);
    pendingPresetOverlay = false;
  } else if (oldConnected && presetChanged) {
    if (uiView == VIEW_HOME || uiView == VIEW_CHANGE_OVERLAY) {
      showPresetChangeOverlay(dspi.activePreset);
    }
    pendingPresetOverlay = false;
  } else if (oldConnected && sourceChanged &&
             (uiView == VIEW_HOME || uiView == VIEW_CHANGE_OVERLAY)) {
    showSourceChangeOverlay(dspi.source);
  }
  if (menuPage == PAGE_PRESET && !editActive && oldActivePreset != dspi.activePreset &&
      isPresetOccupied(dspi.activePreset)) {
    editInt = dspi.activePreset;
  }
  if (oldSource != dspi.source) {
    Serial.printf("DSPi source change: old=%u new=%u reason=%s\n",
                  (unsigned)oldSource, (unsigned)dspi.source, scheduledSourceReason);
  }
  scheduledSourceReason = "verified GET";
  stateRefreshRequested = false;
  lastStateSyncAt = millis();
  return true;
}

uint8_t meterLeftChannelIndex()
{
  // The unit's expanded beta4 status packet has eight inputs followed by
  // outputs at 8/9. The accepted compact Pico layouts use outputs at 2/3.
  return dspi.meterChannelCount >= 17 ? 8 : 2;
}

uint8_t meterRightChannelIndex()
{
  return meterLeftChannelIndex() + 1;
}

bool pollMeters()
{
  // Request the maximum combined-status packet and select its layout from the
  // actual response length. Deployed beta4 returns 17 peaks + two CPU bytes +
  // a 32-bit clip mask; accepted compact firmware returns 7 or 11 peaks + two
  // CPU bytes + a 16-bit clip mask (and may append one system-load byte).
  uint8_t payload[48] = {0};
  uint16_t length = 0;
  if (!dspiGet(REQ_GET_STATUS, 9, sizeof(payload), payload, sizeof(payload), length, false)) return false;

  uint8_t channelCount = 0;
  uint8_t clipBytes = 0;
  if (length >= 40) {
    channelCount = 17;
    clipBytes = 4;
  } else if (length >= 26) {
    channelCount = 11;
    clipBytes = length >= 28 ? 4 : 2;
  } else if (length >= 18) {
    channelCount = 7;
    clipBytes = length >= 20 ? 4 : 2;
  } else {
    return false;
  }

  const uint16_t clipOffset = channelCount * 2 + 2;
  if (clipOffset + clipBytes > length) return false;

  memset(dspi.peaks, 0, sizeof(dspi.peaks));
  for (uint8_t i = 0; i < channelCount; i++) {
    dspi.peaks[i] = readLe16(payload + (i * 2));
  }
  dspi.meterChannelCount = channelCount;
  dspi.clipFlags = clipBytes == 4 ? readLe32(payload + clipOffset)
                                  : readLe16(payload + clipOffset);

  const uint32_t outputMask = channelCount >= 17 ? 0x0001FF00UL
                              : (channelCount == 11 ? 0x000007FCUL : 0x0000007CUL);
  if (dspi.clipFlags & outputMask) {
    // Pico clip bits are sticky. Clear-on-read and retain a two-second visual
    // hold so even a one-sample output over remains clearly visible.
    outputClipUntil = millis() + 2000;
    uint8_t clearedPayload[4] = {0};
    uint16_t clearedLength = 0;
    dspiGet(REQ_CLEAR_CLIPS, 0, sizeof(clearedPayload), clearedPayload,
            sizeof(clearedPayload), clearedLength, false);
  }
  return true;
}

bool readStatusU32ForMeter(uint16_t selector, uint32_t &value)
{
  uint8_t payload[4] = {0};
  uint16_t length = 0;
  if (!dspiGet(REQ_GET_STATUS, selector, 4, payload, sizeof(payload),
               length, false) || length != 4) return false;
  value = readLe32(payload);
  return true;
}

bool pollUsbMeterStreamActive()
{
  if (dspi.source != SRC_USB) return true;
  if (!dspi.connected) return false;

  const unsigned long now = millis();
  if (usbMeterActivityCheckedAt != 0 &&
      (uint32_t)(now - usbMeterActivityCheckedAt) < USB_METER_ACTIVITY_POLL_MS) {
    return usbMeterStreamActive;
  }
  usbMeterActivityCheckedAt = now;

  uint32_t packetCount = 0;
  uint32_t altSetting = 0;
  const bool packetReadOk = readStatusU32ForMeter(10, packetCount);
  const bool altReadOk = readStatusU32ForMeter(11, altSetting);

  // Alternate setting zero means the host closed the audio stream. Clear it
  // immediately rather than allowing the last processed block to remain drawn.
  if (altReadOk && altSetting == 0) {
    if (usbMeterStreamActive || analogPeakSampleValid ||
        meterLeftActive > 0.01f || meterRightActive > 0.01f) {
      clearMeterReadout("USB stream closed");
    }
    usbMeterStreamActive = false;
    if (packetReadOk) {
      usbMeterPacketCount = packetCount;
      usbMeterPacketCounterValid = true;
    }
    usbMeterLastProgressAt = now;
    return false;
  }

  if (packetReadOk) {
    if (!usbMeterPacketCounterValid) {
      // First observation is a baseline only. A later counter change proves
      // that fresh USB audio packets are reaching the Pico.
      usbMeterPacketCount = packetCount;
      usbMeterPacketCounterValid = true;
      usbMeterLastProgressAt = now;
      usbMeterStreamActive = false;
    } else if (packetCount != usbMeterPacketCount) {
      usbMeterPacketCount = packetCount;
      usbMeterLastProgressAt = now;
      usbMeterStreamActive = true;
    }
  }

  if (usbMeterPacketCounterValid &&
      (uint32_t)(now - usbMeterLastProgressAt) >= USB_METER_STALE_MS) {
    if (usbMeterStreamActive || analogPeakSampleValid ||
        meterLeftActive > 0.01f || meterRightActive > 0.01f) {
      clearMeterReadout("USB audio packets stopped");
    }
    usbMeterStreamActive = false;
  }

  return usbMeterStreamActive;
}

bool meterTransportHasFreshAudio()
{
  if (!dspi.connected) return false;
  if (dspi.source == SRC_USB) return pollUsbMeterStreamActive();
  if (isSpdifSource(dspi.source)) {
    return dspi.spdifState == 2 && !dspi.spdifNonAudio;
  }
  if (dspi.source == SRC_ADAT) return dspi.adatState == 3;

  // I2S master input has no host packet counter. Source/preset changes clear
  // the local snapshot, and fresh DSPi peak packets repopulate it.
  return true;
}

void scheduleStateRefresh(uint16_t delayMs, const char *sourceReason = "verified GET")
{
  scheduledSourceReason = sourceReason;
  delayedRefreshAt = millis() + delayMs;
}

bool setUserVolume(float value)
{
  value = constrain(value, -60.0f, 0.0f);
  if (!dspiSetFloat(REQ_SET_USER_VOLUME, value)) return false;
  dspi.volumeDb = value;
  return true;
}

bool setMasterVolumeVerified(float value)
{
  value = constrain(roundf(value * 2.0f) / 2.0f, -60.0f, 0.0f);
  if (!dspiSetFloat(REQ_SET_MASTER_VOLUME, value)) return false;

  float readback = dspi.masterVolumeDb;
  if (!dspiGetFloat(REQ_GET_MASTER_VOLUME, readback)) return false;
  if (fabsf(readback - value) > 0.26f) return false;

  dspi.masterVolumeDb = readback;
  return true;
}

bool ensureIndependentMasterVolumeModeVerified()
{
  // The panel intentionally presents Volume Limit as one device-wide safety
  // ceiling. Existing Console mode is left alone until the user applies a
  // limit here; at that point switch DSPi to its native independent mode.
  if (dspi.masterVolumeMode == 0) return true;
  if (!dspiSetByte(REQ_SET_MASTER_VOLUME_MODE, 0)) return false;

  // Mode changes are persisted by DSPi's deferred main-loop flash handler.
  // Wait through that blackout and accept only an exact verified readback.
  for (uint8_t attempt = 0; attempt < 6; attempt++) {
    delay(attempt == 0 ? 110 : 65);
    uint8_t mode = 0xFF;
    if (getExactByte(REQ_GET_MASTER_VOLUME_MODE, mode) && mode == 0) {
      dspi.masterVolumeMode = 0;
      return true;
    }
  }
  return false;
}

bool persistIndependentMasterVolumeVerified()
{
  // In mode 0 the live 0xD2 value is not a preset property. 0xD6 copies it
  // into the DSPi directory so the same safety ceiling returns after boot.
  if (dspi.masterVolumeMode != 0) return true;

  uint8_t payload[1] = {0xFF};
  uint16_t length = 0;
  if (!dspiGet(REQ_SAVE_MASTER_VOLUME, 0, 1,
               payload, sizeof(payload), length) ||
      length != 1 || payload[0] != 0) return false;

  // The action acknowledgement means accepted; the flash write is deferred.
  // Verify the directory value after the UART blackout has completed.
  for (uint8_t attempt = 0; attempt < 6; attempt++) {
    delay(attempt == 0 ? 110 : 65);
    float saved = NAN;
    if (dspiGetFloat(REQ_GET_SAVED_MASTER_VOLUME, saved) &&
        fabsf(saved - dspi.masterVolumeDb) <= 0.26f) return true;
  }
  return false;
}

bool setUserMute(bool enabled)
