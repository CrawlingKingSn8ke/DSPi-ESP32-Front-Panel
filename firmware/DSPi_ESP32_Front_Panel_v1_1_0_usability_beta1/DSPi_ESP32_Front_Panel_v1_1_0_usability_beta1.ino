  char ch;
  uint8_t w;
  uint8_t h;
  uint8_t advance;
  int8_t xOffset;
  uint8_t yOffset;
  uint16_t dataLen;
  const uint8_t *data;
};

struct FontDef {
  const GlyphDef *glyphs;
  uint8_t count;
  uint8_t lineHeight;
  uint8_t spaceAdvance;
};

