const GlyphDef *findGlyph(const FontDef &font, char ch)
{
  for (uint8_t i = 0; i < font.count; i++) {
    if (font.glyphs[i].ch == ch) return &font.glyphs[i];
  }
  return nullptr;
}

int16_t fontPlusAdvance(const FontDef &font)
{
  if (&font == &FontSmall) return 9;
  if (&font == &FontMedium) return 13;
  if (&font == &FontLarge) return 47;
  return 0;
}

void drawFontPlus(const FontDef &font, int16_t x, int16_t y,
                  uint16_t colour, uint8_t scalePercent = 100)
{
  int16_t baseWidth = fontPlusAdvance(font);
  if (baseWidth <= 0 || scalePercent == 0) return;

  int16_t baseTop = 0;
  int16_t baseHeight = 0;
  int16_t baseThickness = 0;
  if (&font == &FontSmall) {
    baseTop = 5; baseHeight = 10; baseThickness = 2;
  } else if (&font == &FontMedium) {
    baseTop = 7; baseHeight = 14; baseThickness = 2;
  } else {
    baseTop = 25; baseHeight = 38; baseThickness = 6;
  }

  int16_t width = std::max<int16_t>(3, (baseWidth * scalePercent + 50) / 100);
  int16_t top = (baseTop * scalePercent + 50) / 100;
  int16_t height = std::max<int16_t>(3, (baseHeight * scalePercent + 50) / 100);
  int16_t thickness = std::max<int16_t>(1, (baseThickness * scalePercent + 50) / 100);
  canvas->fillRect(x + (width - thickness) / 2, y + top, thickness, height, colour);
  canvas->fillRect(x, y + top + (height - thickness) / 2, width, thickness, colour);
}

int16_t fontTextWidth(const FontDef &font, const String &text)
{
  int16_t w = 0;
  for (uint16_t i = 0; i < text.length(); i++) {
    char ch = text.charAt(i);
    if (ch == ' ') {
      w += font.spaceAdvance;
      continue;
    }
    if (ch == '+') {
      w += fontPlusAdvance(font);
      continue;
    }
    const GlyphDef *g = findGlyph(font, ch);
    if (g) w += g->advance;
  }
  return w;
}

void fontVisualBounds(const FontDef &font, const String &text,
                      int16_t &left, int16_t &right)
{
  int16_t cursor = 0;
  bool haveGlyph = false;
  left = 0;
  right = 0;

  for (uint16_t i = 0; i < text.length(); i++) {
    char ch = text.charAt(i);
    if (ch == ' ') {
      cursor += font.spaceAdvance;
      continue;
    }

    if (ch == '+') {
      int16_t advance = fontPlusAdvance(font);
      if (advance <= 0) continue;
      int16_t glyphLeft = cursor;
      int16_t glyphRight = cursor + advance;
      if (!haveGlyph) {
        left = glyphLeft;
        right = glyphRight;
        haveGlyph = true;
      } else {
        left = std::min<int16_t>(left, glyphLeft);
        right = std::max<int16_t>(right, glyphRight);
      }
      cursor += advance;
      continue;
    }

    const GlyphDef *g = findGlyph(font, ch);
    if (!g) continue;

    int16_t glyphLeft = cursor + g->xOffset;
    int16_t glyphRight = glyphLeft + g->w;
    if (!haveGlyph) {
      left = glyphLeft;
      right = glyphRight;
      haveGlyph = true;
    } else {
      left = std::min<int16_t>(left, glyphLeft);
      right = std::max<int16_t>(right, glyphRight);
    }
    cursor += g->advance;
  }

  if (!haveGlyph) left = right = 0;
}

int16_t fontVisualStartX(const FontDef &font, const String &text)
{
  int16_t left = 0;
  int16_t right = 0;
  fontVisualBounds(font, text, left, right);
  int16_t visibleWidth = right - left;
  return (UI_W - visibleWidth) / 2 - left;
}

void drawGlyphRle(int16_t x, int16_t y, const GlyphDef *g, uint16_t colour)
{
  if (!g) return;
  uint32_t pos = 0;
  uint32_t total = (uint32_t)g->w * (uint32_t)g->h;

  for (uint16_t i = 0; i < g->dataLen; i += 2) {
    uint8_t count = pgm_read_byte(g->data + i);
    uint8_t alpha = pgm_read_byte(g->data + i + 1);

    for (uint8_t n = 0; n < count; n++) {
      if (pos >= total) return;
      if (alpha > 0) {
        int16_t px = x + (pos % g->w);
        int16_t py = y + (pos / g->w);
        if (px >= 0 && px < UI_W && py >= 0 && py < UI_H) {
          canvas->drawPixel(px, py, blend565(C_BLACK, colour, alpha));
        }
      }
      pos++;
    }
  }
}

void drawFontText(const FontDef &font, int16_t x, int16_t y, const String &text, uint16_t colour)
{
  for (uint16_t i = 0; i < text.length(); i++) {
    char ch = text.charAt(i);
    if (ch == ' ') {
      x += font.spaceAdvance;
      continue;
    }
    if (ch == '+') {
      drawFontPlus(font, x, y, colour);
      x += fontPlusAdvance(font);
      continue;
    }
    const GlyphDef *g = findGlyph(font, ch);
    if (!g) continue;
    drawGlyphRle(x + g->xOffset, y + g->yOffset, g, colour);
    x += g->advance;
  }
}

void drawFontCentred(const FontDef &font, int16_t y, const String &text, uint16_t colour)
{
  int16_t x = (UI_W - fontTextWidth(font, text)) / 2;
  if (x < 0) x = 0;
  drawFontText(font, x, y, text, colour);
}

void drawFontCentredVisual(const FontDef &font, int16_t y,
                           const String &text, uint16_t colour)
{
  drawFontText(font, fontVisualStartX(font, text), y, text, colour);
}

void drawFontRight(const FontDef &font, int16_t rightX, int16_t y, const String &text, uint16_t colour)
{
  int16_t x = rightX - fontTextWidth(font, text);
  if (x < 0) x = 0;
  drawFontText(font, x, y, text, colour);
}

int8_t volumeKernAdjust(char prev, char cur)
{
  int8_t adjust = -2;
  if (cur == '.') adjust = -7;
  if (prev == '.') adjust = -5;
  if (prev == '1') adjust = -3;
  if (prev == '8' && cur == '.') adjust = -8;
  if (prev == '3' && cur == '8') adjust = -3;
  return adjust;
}

int16_t fontTextWidthKerned(const FontDef &font, const String &text)
{
  int16_t w = 0;
  char prev = 0;
  for (uint16_t i = 0; i < text.length(); i++) {
    char ch = text.charAt(i);
    if (ch == ' ') {
      w += font.spaceAdvance;
      prev = ch;
      continue;
    }
    if (ch == '+') {
      if (i > 0) w += volumeKernAdjust(prev, ch);
      w += fontPlusAdvance(font);
      prev = ch;
      continue;
    }
    const GlyphDef *g = findGlyph(font, ch);
    if (!g) continue;
    if (i > 0) w += volumeKernAdjust(prev, ch);
    w += g->advance;
    prev = ch;
  }
  return w;
}

void drawFontTextKerned(const FontDef &font, int16_t x, int16_t y, const String &text, uint16_t colour)
{
  char prev = 0;
  for (uint16_t i = 0; i < text.length(); i++) {
    char ch = text.charAt(i);
    if (ch == ' ') {
      x += font.spaceAdvance;
      prev = ch;
      continue;
    }
    if (ch == '+') {
      if (i > 0) x += volumeKernAdjust(prev, ch);
      drawFontPlus(font, x, y, colour);
      x += fontPlusAdvance(font);
      prev = ch;
      continue;
    }
    const GlyphDef *g = findGlyph(font, ch);
    if (!g) continue;
    if (i > 0) x += volumeKernAdjust(prev, ch);
    drawGlyphRle(x + g->xOffset, y + g->yOffset, g, colour);
    x += g->advance;
    prev = ch;
  }
}

int16_t fontTextWidthScaledKerned(const FontDef &font, const String &text,
                                  uint8_t scalePercent)
{
  return (int16_t)(((int32_t)fontTextWidthKerned(font, text) * scalePercent + 50) / 100);
}

void drawGlyphRleScaled(int16_t x, int16_t y, const GlyphDef *g,
                        uint16_t colour, uint8_t scalePercent)
{
  if (!g || scalePercent == 0) return;
  uint32_t pos = 0;
  uint32_t total = (uint32_t)g->w * (uint32_t)g->h;

  for (uint16_t i = 0; i < g->dataLen; i += 2) {
    uint8_t count = pgm_read_byte(g->data + i);
    uint8_t alpha = pgm_read_byte(g->data + i + 1);
    for (uint8_t n = 0; n < count; n++) {
      if (pos >= total) return;
      if (alpha > 0) {
        uint16_t sourceX = pos % g->w;
        uint16_t sourceY = pos / g->w;
        int16_t px = x + (int16_t)(((uint32_t)sourceX * scalePercent + 50) / 100);
        int16_t py = y + (int16_t)(((uint32_t)sourceY * scalePercent + 50) / 100);
        if (px >= 0 && px < UI_W && py >= 0 && py < UI_H) {
          canvas->drawPixel(px, py, blend565(C_BLACK, colour, alpha));
        }
      }
      pos++;
    }
  }
}

void drawFontTextScaledKerned(const FontDef &font, int16_t x, int16_t y,
                              const String &text, uint16_t colour,
                              uint8_t scalePercent)
{
  char prev = 0;
  for (uint16_t i = 0; i < text.length(); i++) {
    char ch = text.charAt(i);
    if (ch == ' ') {
      x += (font.spaceAdvance * scalePercent + 50) / 100;
      prev = ch;
      continue;
    }
    if (ch == '+') {
      if (i > 0) x += (volumeKernAdjust(prev, ch) * scalePercent) / 100;
      drawFontPlus(font, x, y, colour, scalePercent);
      x += (fontPlusAdvance(font) * scalePercent + 50) / 100;
      prev = ch;
      continue;
    }
    const GlyphDef *g = findGlyph(font, ch);
    if (!g) continue;
    if (i > 0) x += (volumeKernAdjust(prev, ch) * scalePercent) / 100;
    int16_t glyphX = x + (g->xOffset * scalePercent) / 100;
    int16_t glyphY = y + (g->yOffset * scalePercent) / 100;
    drawGlyphRleScaled(glyphX, glyphY, g, colour, scalePercent);
    x += (g->advance * scalePercent + 50) / 100;
    prev = ch;
  }
}

