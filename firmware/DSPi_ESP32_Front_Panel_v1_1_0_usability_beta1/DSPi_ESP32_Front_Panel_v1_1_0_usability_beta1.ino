void drawBleSpinner(int16_t cx, int16_t cy, uint8_t phase)
{
  static const int8_t points[12][2] = {
    {  0, -15}, {  8, -13}, { 13,  -8}, { 15,   0},
    { 13,   8}, {  8,  13}, {  0,  15}, { -8,  13},
    {-13,   8}, {-15,   0}, {-13,  -8}, { -8, -13}
  };

  for (uint8_t i = 0; i < 12; i++) {
    uint8_t distance = (uint8_t)((i + 12 - (phase % 12)) % 12);
    uint8_t alpha;
    if (distance == 0) alpha = 255;
    else if (distance == 1) alpha = 205;
    else if (distance == 2) alpha = 155;
    else if (distance == 3) alpha = 105;
    else alpha = 45;

    uint16_t colour = blend565(C_BLACK, C_CYAN, alpha);
    uint8_t radius = distance < 2 ? 3 : 2;
    canvas->fillCircle(cx + points[i][0], cy + points[i][1], radius, colour);
  }
}

void drawBleScreen()
{
  uiView = VIEW_BLE;
  drawBase();
  drawFontCentredGlow(FontMedium, 8, "Remote");
  drawTaperLine(UI_W / 2, 44, 220, 1, C_CYAN_DARK);

  if (bleUiMode == BLE_UI_SCANNING) {
    drawMenuOptionCentredGlow(53, "Searching");
    drawBleSpinner(UI_W / 2, 137, bleAnimationStep);
  } else if (bleUiMode == BLE_UI_RESULTS) {
    uint8_t count;
    portENTER_CRITICAL(&bleDataMux);
    count = bleDeviceCount;
    portEXIT_CRITICAL(&bleDataMux);
    drawMenuOptionCentredGlow(53, "Devices");
    if (!count) {
      drawFontCentredGlowColour(FontMedium, 112, "None found", C_DIM);
    } else {
      BleDeviceInfo device;
      portENTER_CRITICAL(&bleDataMux);
      device = bleDevices[std::min<uint8_t>(bleResultIndex, count - 1)];
      portEXIT_CRITICAL(&bleDataMux);
      String name = device.name[0] ? String(device.name) : "BLE remote";
      name = cleanDisplayText(name, 22);
      if (fontTextWidth(FontMedium, name) <= UI_W - 20) {
        drawFontCentredGlowColour(FontMedium, 103, name, C_WHITE);
      } else {
        drawFontCentredGlowColour(FontSmall, 124, name, C_WHITE);
      }
      String signal = String("Signal ") + String((int)device.rssi) + " dBm";
      drawFontCentred(FontSmall, 169, signal, device.hidAdvertised ? C_CYAN : C_DIM);
      drawMenuDots(count, bleResultIndex);
    }
  } else if (bleUiMode == BLE_UI_MAPPING) {
    drawMenuOptionCentredGlow(53, "Key Map");
    String actionName = bleMappingNames[bleMappingIndex];
    if (fontTextWidth(FontMedium, actionName) <= UI_W - 20) {
      drawFontCentredGlowColour(FontMedium, 100, actionName, C_WHITE);
    } else {
      drawFontCentredGlowColour(FontSmall, 120, actionName, C_WHITE);
    }
    String label = remoteLabelForAction(bleMappingIndex);
    drawFontCentredGlowColour(FontSmall, 166, label,
                              remoteMapEntrySet(remoteMap[bleMappingIndex]) ? C_CYAN : C_DIM);
    drawMenuDots(BLE_MAPPING_COUNT, bleMappingIndex);
  } else if (bleUiMode == BLE_UI_LEARNING) {
    drawMenuOptionCentredGlow(53, bleMappingNames[bleMappingIndex]);
    String prompt = bleLearningMessage.length() ? bleLearningMessage :
                    (bleLearningAwaitRelease ? "Release buttons" : "Press remote");
    const FontDef &promptFont = fontTextWidth(FontMedium, prompt) <= UI_W - 20 ? FontMedium : FontSmall;
    drawFontCentredGlowColour(promptFont, promptFont.lineHeight > 30 ? 112 : 126,
                              prompt, C_CYAN);
  } else if (bleUiMode == BLE_UI_SHORTCUTS) {
    drawMenuOptionCentredGlow(53, "Home Screen D-pad shortcuts");
    drawFontCentredGlowColour(FontMedium, 98, homeShortcutKeyNames[bleShortcutIndex], C_WHITE);
    uint8_t option = homeShortcutOptionIndex(homeShortcuts[bleShortcutIndex]);
    String value = homeShortcutOptionNames[option];
    if (fontTextWidth(FontMedium, value) <= UI_W - 24) {
      drawFontCentredGlowColour(FontMedium, 145, value, C_CYAN);
    } else {
      drawFontCentredGlowColour(FontSmall, 161, value, C_CYAN);
    }
    drawMenuDots(HOME_SHORTCUT_COUNT, bleShortcutIndex);
  } else if (bleUiMode == BLE_UI_SHORTCUT_EDIT) {
    String heading = String(homeShortcutKeyNames[bleShortcutIndex]) + " Shortcut";
    drawMenuOptionCentredGlow(53, heading);
    String value = homeShortcutOptionNames[bleShortcutOptionIndex];
    if (fontTextWidth(FontMedium, value) <= UI_W - 24) {
      drawFontCentredGlowColour(FontMedium, 112, value, C_CYAN);
    } else {
      drawFontCentredGlowColour(FontSmall, 133, value, C_CYAN);
    }
    drawMenuDots(HOME_SHORTCUT_OPTION_COUNT, bleShortcutOptionIndex);
  } else if (bleUiMode == BLE_UI_CONFIRM_DEFAULTS) {
    drawMenuOptionCentredGlow(53, "Restore Defaults");
    drawFontCentredGlowColour(FontLarge, 88, bleDefaultsYes ? "Yes" : "No", C_CYAN);
  } else if (bleUiMode == BLE_UI_CONFIRM_REMOVE) {
    drawMenuOptionCentredGlow(53, "Remove remote?");
    drawFontCentredGlowColour(FontLarge, 88, bleRemoveYes ? "Yes" : "No", C_CYAN);
  } else if (bleUiMode == BLE_UI_MESSAGE && bleMessage == "Pairing") {
    // Pairing is shown only once. The animated spinner supplies the activity cue.
    drawMenuOptionCentredGlow(53, "Pairing");
    drawBleSpinner(UI_W / 2, 137, bleAnimationStep);
  } else if (bleUiMode == BLE_UI_MESSAGE && bleMessage == "Removing remote") {
    drawMenuOptionCentredGlow(53, "Removing remote");
    drawBleSpinner(UI_W / 2, 137, bleAnimationStep);
  } else if (bleUiMode == BLE_UI_MESSAGE &&
             (bleMessage == "Connected" || bleMessage == "Reconnecting")) {
    String name = cleanDisplayText(String(bleSavedName), 22);
    const FontDef &nameFont = fontTextWidth(FontMedium, name) <= UI_W - 20 ? FontMedium : FontSmall;
    drawFontCentredGlowColour(nameFont, nameFont.lineHeight > 30 ? 67 : 80, name, C_WHITE);
    drawFontCentredGlowColour(FontMedium, 133, bleMessage, C_CYAN);
  } else {
    drawMenuOptionCentredGlow(53, "Remote");
    drawFontCentredGlowColour(FontMedium, 112,
                              bleMessage.length() ? bleMessage : "Ready",
                              C_CYAN);
  }

  canvas->flush();
}

void bleNavigate(int direction)
{
  if (bleUiMode == BLE_UI_RESULTS) {
    uint8_t count;
    portENTER_CRITICAL(&bleDataMux);
    count = bleDeviceCount;
    portEXIT_CRITICAL(&bleDataMux);
    if (count) {
      int next = ((int)bleResultIndex + direction) % count;
      if (next < 0) next += count;
      bleResultIndex = (uint8_t)next;
    }
  } else if (bleUiMode == BLE_UI_MAPPING) {
    int next = ((int)bleMappingIndex + direction) % BLE_MAPPING_COUNT;
    if (next < 0) next += BLE_MAPPING_COUNT;
    bleMappingIndex = (uint8_t)next;
  } else if (bleUiMode == BLE_UI_SHORTCUTS) {
    int next = ((int)bleShortcutIndex + direction) % HOME_SHORTCUT_COUNT;
    if (next < 0) next += HOME_SHORTCUT_COUNT;
    bleShortcutIndex = (uint8_t)next;
  } else if (bleUiMode == BLE_UI_SHORTCUT_EDIT) {
    int next = ((int)bleShortcutOptionIndex + direction) % HOME_SHORTCUT_OPTION_COUNT;
    if (next < 0) next += HOME_SHORTCUT_OPTION_COUNT;
    bleShortcutOptionIndex = (uint8_t)next;
  } else if (bleUiMode == BLE_UI_CONFIRM_DEFAULTS) {
    if (direction) bleDefaultsYes = direction > 0;
  } else if (bleUiMode == BLE_UI_CONFIRM_REMOVE) {
    if (direction) bleRemoveYes = direction > 0;
  }
  drawBleScreen();
}

void bleBack()
{
#if DSPI_HAVE_NIMBLE
  if (bleUiMode == BLE_UI_SCANNING || bleScanActive) resetBleScanState(true);
#endif
  if (bleRemovalInProgress) {
    transitionToHome();
    return;
  }
  if (bleUiMode == BLE_UI_LEARNING) {
    clearBleHeldState();
    bleLearningAwaitRelease = false;
    bleLearningMessage = "";
    bleUiMode = BLE_UI_MAPPING;
    transitionToBleScreen();
    return;
  }
  if (bleUiMode == BLE_UI_SHORTCUT_EDIT) {
    bleUiMode = BLE_UI_SHORTCUTS;
    transitionToBleScreen();
    return;
  }
  bleUiMode = BLE_UI_NONE;
  enterPage(PAGE_BLUETOOTH);
}

void bleSelect()
{
  if (bleUiMode == BLE_UI_RESULTS) {
    uint8_t count;
    portENTER_CRITICAL(&bleDataMux);
    count = bleDeviceCount;
    if (count) blePendingDevice = bleDevices[std::min<uint8_t>(bleResultIndex, count - 1)];
    portEXIT_CRITICAL(&bleDataMux);
    if (!count) return;
    blePendingSave = true;
    bleConnectRequested = true;
    bleUiMode = BLE_UI_MESSAGE;
    bleMessage = "Pairing";
    bleAnimationStep = 0;
    bleLastAnimationAt = millis();
    drawBleScreen();
  } else if (bleUiMode == BLE_UI_MAPPING) {
    if (!bleConnected) {
      bleUiMode = BLE_UI_MESSAGE;
      bleMessage = "Remote asleep";
      bleMessageUntil = millis() + 1600;
    } else {
      clearBleHeldState();
      bleUiMode = BLE_UI_LEARNING;
      bleLearningAwaitRelease = true;
      bleLearningMessage = "";
      bleLearningMessageUntil = 0;
    }
    transitionToBleScreen();
  } else if (bleUiMode == BLE_UI_SHORTCUTS) {
    bleShortcutOptionIndex = homeShortcutOptionIndex(homeShortcuts[bleShortcutIndex]);
    bleUiMode = BLE_UI_SHORTCUT_EDIT;
    transitionToBleScreen();
  } else if (bleUiMode == BLE_UI_SHORTCUT_EDIT) {
    homeShortcuts[bleShortcutIndex] = homeShortcutOptions[bleShortcutOptionIndex];
    saveHomeShortcuts();
    bleUiMode = BLE_UI_SHORTCUTS;
    transitionToBleScreen();
  } else if (bleUiMode == BLE_UI_CONFIRM_DEFAULTS) {
    if (bleDefaultsYes) {
      restoreRemoteDefaults();
      bleUiMode = BLE_UI_MESSAGE;
      bleMessage = "Defaults restored";
      bleMessageUntil = millis() + 1400;
      drawBleScreen();
    } else {
      bleBack();
    }
  } else if (bleUiMode == BLE_UI_CONFIRM_REMOVE) {
    if (bleRemoveYes) {
      beginBleRemoteRemoval();
    } else {
      bleBack();
    }
  } else if (bleUiMode == BLE_UI_MESSAGE) {
    if (bleMessage != "Removing remote" && bleMessage != "BLE restarting") bleBack();
  }
}

// -----------------------------------------------------------------------------
// BLE HID and proprietary remote support (NimBLE-Arduino 2.x)
// -----------------------------------------------------------------------------

#if DSPI_HAVE_NIMBLE

bool bleDeviceMatchesSaved(const NimBLEAdvertisedDevice *device)
{
  if (!bleProfileValid) return false;
  String address = String(std::string(device->getAddress()).c_str());
  if (address.equalsIgnoreCase(bleSavedAddress)) return true;
  String name = String(device->getName().c_str());
  return name.length() && name.equalsIgnoreCase(bleSavedName);
}

void copyAdvertisedDevice(BleDeviceInfo &out, const NimBLEAdvertisedDevice *device)
{
  memset(&out, 0, sizeof(out));
  String name = String(device->getName().c_str());
  if (name.length() == 0) name = "BLE remote";
  name = cleanDisplayText(name, 24);
  name.toCharArray(out.name, sizeof(out.name));
  String address = String(std::string(device->getAddress()).c_str());
  address.toCharArray(out.address, sizeof(out.address));
  out.addressType = device->getAddressType();
  out.rssi = device->getRSSI();
  out.hidAdvertised = device->isAdvertisingService(NimBLEUUID("1812"));
}

uint32_t bleHashByte(uint32_t hash, uint8_t value)
{
  hash ^= value;
  return hash * 16777619UL;
}

uint32_t bleHashText(uint32_t hash, const std::string &text)
{
  for (char value : text) hash = bleHashByte(hash, (uint8_t)value);
  return hash;
}

uint32_t makeBleSourceKey(const NimBLERemoteService *service,
                          NimBLERemoteCharacteristic *characteristic,
                          uint8_t reportId, uint8_t reportType)
{
  uint32_t hash = 2166136261UL;
  hash = bleHashText(hash, service->getUUID().toString());
  hash = bleHashByte(hash, 0xFF);
  hash = bleHashText(hash, characteristic->getUUID().toString());
  hash = bleHashByte(hash, 0xFE);
  hash = bleHashByte(hash, reportId);
  hash = bleHashByte(hash, reportType);
  return hash ? hash : 1;
}

bool findBleInputSource(uint16_t handle, BleInputSource &source)
{
  uint8_t count = bleInputSourceCount;
  for (uint8_t i = 0; i < count; i++) {
    if (bleInputSources[i].handle == handle) {
      source = bleInputSources[i];
      return true;
    }
  }
  return false;
}

void bleReportCallback(NimBLERemoteCharacteristic *characteristic,
                       uint8_t *data, size_t length, bool isNotify)
{
  (void)isNotify;
  if (!bleReportQueue || !characteristic || length == 0) return;

  BleReportPacket packet = {};
  BleInputSource source = {};
  packet.handle = characteristic->getHandle();
  if (findBleInputSource(packet.handle, source)) {
    packet.sourceKey = source.sourceKey;
    packet.reportId = source.reportId;
    packet.reportType = source.reportType;
  } else {
    // A handle is runtime-only and must never become persistent identity.
    packet.sourceKey = 0;
  }

  packet.receivedAt = millis();
  packet.length = std::min<size_t>(sizeof(packet.data), length);
  memcpy(packet.data, data, packet.length);
  xQueueSend(bleReportQueue, &packet, 0);
}

class DspiBleClientCallbacks : public NimBLEClientCallbacks {
  void onConnect(NimBLEClient *client) override {
    (void)client;
    bleConnected = true;
    bleConnectionChanged = true;
    Serial.println("BLE: remote connected.");
  }

  void onConnectFail(NimBLEClient *client, int reason) override {
    (void)client;
    bleConnected = false;
    bleConnectionChanged = true;
    Serial.printf("BLE: connection failed, reason %d.\n", reason);
  }

  void onDisconnect(NimBLEClient *client, int reason) override {
    (void)client;
    bleConnected = false;
    bleConnectionChanged = true;
    clearBleHeldState();
    bleInputSourceCount = 0;
    lastBleScanAt = 0;
    Serial.printf("BLE: remote disconnected, reason %d.\n", reason);
  }

  void onAuthenticationComplete(NimBLEConnInfo &connInfo) override {
    Serial.printf("BLE: pairing complete, encrypted=%s bonded=%s\n",
                  connInfo.isEncrypted() ? "yes" : "no",
                  connInfo.isBonded() ? "yes" : "no");
  }
} dspiBleClientCallbacks;

class DspiBleScanCallbacks : public NimBLEScanCallbacks {
  void onResult(const NimBLEAdvertisedDevice *device) override {
    if (!device->isConnectable()) return;

    BleScanPurpose purpose = bleScanPurpose;
    if (purpose == BLE_SCAN_RECONNECT) {
      if (!bleDeviceMatchesSaved(device)) return;
      copyAdvertisedDevice(blePendingDevice, device);
      blePendingSave = false;
      bleConnectRequested = true;
      NimBLEDevice::getScan()->stop();
      return;
    }

    if (purpose != BLE_SCAN_USER) return;
    bool hasName = device->haveName() && device->getName().length();
    bool hid = device->isAdvertisingService(NimBLEUUID("1812"));
    if (!hasName && !hid) return;

    BleDeviceInfo info;
    copyAdvertisedDevice(info, device);
    portENTER_CRITICAL(&bleDataMux);
    int existing = -1;
    for (uint8_t i = 0; i < bleDeviceCount; i++) {
      if (strcmp(bleDevices[i].address, info.address) == 0) {
        existing = i;
        break;
      }
    }
    if (existing >= 0) {
      bleDevices[existing] = info;
    } else if (bleDeviceCount < BLE_MAX_DEVICES) {
      bleDevices[bleDeviceCount++] = info;
    } else {
      uint8_t weakest = 0;
      for (uint8_t i = 1; i < BLE_MAX_DEVICES; i++) {
        if (bleDevices[i].rssi < bleDevices[weakest].rssi) weakest = i;
      }
      if (info.rssi > bleDevices[weakest].rssi) bleDevices[weakest] = info;
    }
    portEXIT_CRITICAL(&bleDataMux);
  }

  void onScanEnd(const NimBLEScanResults &results, int reason) override {
    (void)results;
    (void)reason;
    if (bleIgnoreNextScanEnd) {
      bleIgnoreNextScanEnd = false;
      return;
    }
    bleScanActive = false;
    bleScanFinished = true;
  }
} dspiBleScanCallbacks;

BleDeviceInfo bleConnectDevice = {};
volatile bool bleConnectTaskRunning = false;
volatile bool bleConnectTaskFinished = false;
volatile bool bleConnectTaskResult = false;
bool bleConnectTaskSave = false;

void bleConnectWorker(void *parameter)
{
  (void)parameter;
  bool ok = connectBleRemote(bleConnectDevice, bleConnectTaskSave);
  bleConnectTaskResult = ok;
  bleConnectTaskFinished = true;
  bleConnectTaskRunning = false;
  vTaskDelete(nullptr);
}

bool initialiseBleRemoteStack()
{
  if (!bleReportQueue) bleReportQueue = xQueueCreate(12, sizeof(BleReportPacket));
  else xQueueReset(bleReportQueue);
  if (!bleReportQueue) return false;
  if (!NimBLEDevice::init("DSPi Front Panel")) return false;
  NimBLEDevice::setPower(3);
  NimBLEDevice::setSecurityAuth(true, false, false);
  NimBLEDevice::setSecurityIOCap(BLE_HS_IO_NO_INPUT_OUTPUT);
  NimBLEScan *scan = NimBLEDevice::getScan();
  scan->setScanCallbacks(&dspiBleScanCallbacks, false);
  scan->setActiveScan(true);
  scan->setInterval(100);
  scan->setWindow(80);
  scan->setMaxResults(BLE_MAX_DEVICES);
  return true;
}

void beginBleRemote()
{
  bleStackReady = initialiseBleRemoteStack();
  if (!bleStackReady) {
    Serial.println("BLE: stack initialization failed.");
    return;
  }

  // A saved remote is searched for immediately after boot. If it is asleep,
  // normal periodic reconnect scans continue without blocking the UI.
  if (bleProfileValid) lastBleScanAt = millis() - BLE_RESCAN_INTERVAL_MS;
}

bool restartBleRemoteStack()
{
  if (bleConnectTaskRunning) return false;

  // Removal is serviced from pollBleRemote(). Never block the UI waiting for
  // GAP teardown; request disconnect and retry the restart on a later poll.
  if (bleClient && bleClient->isConnected()) {
    bleClient->disconnect();
    return false;
  }

  bleStackReady = false;
  bool stopped = NimBLEDevice::deinit(true);
  bleClient = nullptr;
  bleConnected = false;
  bleScanActive = false;
  bleScanFinished = false;
  bleIgnoreNextScanEnd = false;
  bleScanPurpose = BLE_SCAN_NONE;
  bleConnectRequested = false;
  bleConnectionChanged = true;
  blePendingSave = false;
  bleConnectTaskFinished = false;
  bleConnectTaskResult = false;
  bleConnectTaskSave = false;
  bleInputSourceCount = 0;
  portENTER_CRITICAL(&bleDataMux);
  memset(bleDevices, 0, sizeof(bleDevices));
  bleDeviceCount = 0;
  portEXIT_CRITICAL(&bleDataMux);
  clearBleHeldState();

  if (!stopped || !initialiseBleRemoteStack()) {
    Serial.println("BLE: stack restart failed.");
    return false;
  }

  bleStackReady = true;
  lastBleScanAt = millis();
  Serial.println("BLE: stack restarted after profile removal.");
  return true;
}

void serviceBleRemoteRemoval()
{
  if (!bleRemovalInProgress || bleConnectTaskRunning) return;

  bool clientConnected = bleClient && bleClient->isConnected();
  if (clientConnected) {
    if (!bleRemovalDisconnectRequested ||
        (long)(millis() - bleRemovalDisconnectRetryAt) >= 0) {
      bleRemovalDisconnectRequested = true;
      bleRemovalDisconnectRetryAt = millis() + 500;
      bleClient->disconnect();
    }
    bleStackRestartRetryAt = millis() + 100;
    return;
  }
  // The client object is the authoritative connection check. Clear a delayed
  // callback flag once it is already disconnected so cleanup cannot stall.
  bleConnected = false;

  if ((long)(millis() - bleStackRestartRetryAt) < 0) return;
  bool restarted = restartBleRemoteStack();
  bleStackRestartPending = !restarted;
  bleStackRestartRetryAt = millis() + 1000;
  if (!restarted) return;

  if (bleRemovedAddress[0]) {
    // Defensive second delete after the clean stack restart handles a peer
    // that was still connected during the first bond-store deletion.
    NimBLEAddress address(std::string(bleRemovedAddress), bleRemovedAddressType);
    NimBLEDevice::deleteBond(address);
  }
  memset(bleRemovedAddress, 0, sizeof(bleRemovedAddress));
  bleRemovedAddressType = 0;
  bleRemovalDisconnectRequested = false;
  bleRemovalDisconnectRetryAt = 0;
  bleRemovalInProgress = false;
  clampBleMenuIndex();

  if (uiView == VIEW_BLE) {
    bleUiMode = BLE_UI_MESSAGE;
    bleMessage = "Remote removed";
    bleMessageUntil = millis() + 1500;
    drawBleScreen();
  } else {
    showToast("Remote removed", 1500);
    redrawCurrentView();
  }
}

bool startBleScan(BleScanPurpose purpose, uint32_t duration)
{
  if (!bleStackReady || bleRemovalInProgress || bleStackRestartPending ||
      bleScanActive || bleConnected ||
      (purpose == BLE_SCAN_USER && bleProfileValid) ||
      (bleClient && bleClient->isConnected())) return false;
  clearBleHeldState();
  bleScanPurpose = purpose;
  bleScanFinished = false;
  bleScanActive = true;
  lastBleScanAt = millis();
  NimBLEScan *scan = NimBLEDevice::getScan();
  scan->clearResults();
  if (!scan->start(duration, false, true)) {
    bleScanActive = false;
    bleScanPurpose = BLE_SCAN_NONE;
    return false;
  }
  return true;
}

void resetBleScanState(bool stopActive)
{
  if (stopActive && bleScanActive) {
    bleIgnoreNextScanEnd = true;
    NimBLEDevice::getScan()->stop();
  }
  bleScanActive = false;
  bleScanFinished = false;
  bleScanPurpose = BLE_SCAN_NONE;
}

void scheduleSavedReconnect()
{
  if (bleProfileValid) lastBleScanAt = millis() - BLE_RESCAN_INTERVAL_MS;
}

void startBleUserScanNow()
{
  if (!bleCanOfferFindRemote()) {
    bleUiMode = BLE_UI_MESSAGE;
    bleMessage = bleProfileValid ? "Remove remote first" : "Scan unavailable";
    bleMessageUntil = millis() + 1600;
    drawBleScreen();
    return;
  }
  clearBleHeldState();
  resetBleScanState(true);
  bleConnectRequested = false;
  portENTER_CRITICAL(&bleDataMux);
  memset(bleDevices, 0, sizeof(bleDevices));
  bleDeviceCount = 0;
  portEXIT_CRITICAL(&bleDataMux);
  bleResultIndex = 0;
  bleUiMode = BLE_UI_SCANNING;
  bleAnimationStep = 0;
  bleLastAnimationAt = millis();
  drawBleScreen();
  if (!startBleScan(BLE_SCAN_USER, BLE_SCAN_TIME_MS)) {
    bleUiMode = BLE_UI_MESSAGE;
    bleMessage = "Scan unavailable";
    bleMessageUntil = millis() + 1600;
    drawBleScreen();
  }
}

void bleStartUserScan()
{
  clearBleHeldState();
  if (bleProfileValid) {
    bleUiMode = BLE_UI_MESSAGE;
    bleMessage = "Remove remote first";
    bleMessageUntil = millis() + 1600;
    drawBleScreen();
    return;
  }

  if (bleRemovalInProgress || bleStackRestartPending) {
    bleUiMode = BLE_UI_MESSAGE;
    bleMessage = bleRemovalInProgress ? "Removing remote" : "BLE restarting";
    bleMessageUntil = 0;
    drawBleScreen();
    return;
  }

  if (bleConnectTaskRunning || bleConnected ||
      (bleClient && bleClient->isConnected())) {
    // No profile plus a live/stale client is incomplete cleanup. Finish a
    // proper removal/restart; never present a false Searching state.
    beginBleRemoteRemoval();
    return;
  }

  if (!bleStackReady) {
    bleUiMode = BLE_UI_MESSAGE;
    bleMessage = "BLE unavailable";
    bleMessageUntil = millis() + 1600;
    drawBleScreen();
    return;
  }

  startBleUserScanNow();
}

bool connectBleRemote(const BleDeviceInfo &device, bool saveOnSuccess)
{
  NimBLEAddress address(std::string(device.address), device.addressType);
  bleClient = NimBLEDevice::getClientByPeerAddress(address);
  if (!bleClient) bleClient = NimBLEDevice::getDisconnectedClient();
  if (!bleClient) {
    bleClient = NimBLEDevice::createClient();
    if (!bleClient) return false;
    bleClient->setClientCallbacks(&dspiBleClientCallbacks, false);
    bleClient->setConnectionParams(12, 24, 0, 200);
    bleClient->setConnectTimeout(5000);
    bleClient->setConnectRetries(2);
  }

  if (!bleClient->connect(address, true, false, true)) {
    bleConnected = false;
    return false;
  }

  // Remotes commonly require encryption before report descriptors and
  // proprietary input services are visible/readable.
  bool secured = bleClient->secureConnection();
  Serial.printf("BLE: security %s.\n", secured ? "ready" : "not confirmed");

  // Discover the complete GATT database. Amazon Fire TV remotes and some other
  // media remotes place navigation reports in proprietary services while only
  // exposing Home through the standard HID service.
  const auto &services = bleClient->getServices(true);
  NimBLERemoteService *hid = bleClient->getService(NimBLEUUID("1812"));

  if (hid) {
    // Ask compatible HOGP devices for Report Protocol rather than Boot mode.
    NimBLERemoteCharacteristic *protocolMode = hid->getCharacteristic(NimBLEUUID("2A4E"));
    if (protocolMode && (protocolMode->canWrite() || protocolMode->canWriteNoResponse())) {
      const uint8_t reportProtocol = 0x01;
      bool response = protocolMode->canWrite();
      bool ok = protocolMode->writeValue(&reportProtocol, 1, response);
      Serial.printf("BLE: Report Protocol %s.\n", ok ? "selected" : "write failed");
    }

    // Explicitly exit HID suspend where the control point is provided.
    NimBLERemoteCharacteristic *controlPoint = hid->getCharacteristic(NimBLEUUID("2A4C"));
    if (controlPoint && (controlPoint->canWrite() || controlPoint->canWriteNoResponse())) {
      const uint8_t exitSuspend = 0x01;
      bool response = controlPoint->canWrite();
      bool ok = controlPoint->writeValue(&exitSuspend, 1, response);
      Serial.printf("BLE: HID Exit Suspend %s.\n", ok ? "sent" : "write failed");
    }
  }

  memset(bleInputSources, 0, sizeof(bleInputSources));
  bleInputSourceCount = 0;
  uint8_t subscribed = 0;
  uint8_t hidSubscribed = 0;
  uint8_t proprietarySubscribed = 0;

  for (NimBLERemoteService *service : services) {
    if (!service) continue;
    const NimBLEUUID &serviceUuid = service->getUUID();

    // These standard services do not carry remote key presses.
    if (serviceUuid == NimBLEUUID("1800") ||
        serviceUuid == NimBLEUUID("1801") ||
        serviceUuid == NimBLEUUID("180F")) {
      continue;
    }

    bool isHidService = serviceUuid == NimBLEUUID("1812");
    const auto &characteristics = service->getCharacteristics(true);
    for (NimBLERemoteCharacteristic *characteristic : characteristics) {
      if (!characteristic || (!characteristic->canNotify() && !characteristic->canIndicate())) continue;

      const NimBLEUUID &characteristicUuid = characteristic->getUUID();
      if (characteristicUuid == NimBLEUUID("2A05") ||
          characteristicUuid == NimBLEUUID("2A19")) {
        continue;
      }

      uint8_t reportId = 0;
      uint8_t reportType = 0;
      if (isHidService && characteristicUuid == NimBLEUUID("2A4D")) {
        characteristic->getDescriptors(true);
        NimBLERemoteDescriptor *reference = characteristic->getDescriptor(NimBLEUUID("2908"));
        if (reference) {
          NimBLEAttValue value = reference->readValue();
          if (value.size() >= 2) {
            reportId = value.data()[0];
            reportType = value.data()[1];
          }
        }
        // Report Reference type 1 is Input. Do not subscribe to Output or
        // Feature reports even if a device exposes unusual properties.
        if (reportType != 0 && reportType != 1) continue;
      }

      if (bleInputSourceCount >= BLE_MAX_INPUT_SOURCES) {
        Serial.println("BLE: input-source table full; remaining notifications skipped.");
        break;
      }

      BleInputSource source = {};
      source.handle = characteristic->getHandle();
      source.reportId = reportId;
      source.reportType = reportType;
      source.sourceKey = makeBleSourceKey(service, characteristic, reportId, reportType);
      bleInputSources[bleInputSourceCount++] = source;

      bool useNotify = characteristic->canNotify();
      bool ok = characteristic->subscribe(useNotify, bleReportCallback, true);
      if (!ok) ok = characteristic->subscribe(useNotify, bleReportCallback, false);

      std::string serviceText = serviceUuid.toString();
      std::string characteristicText = characteristicUuid.toString();
      Serial.printf("BLE SUB: svc=%s chr=%s handle=0x%04X rid=%u type=%u %s\n",
                    serviceText.c_str(), characteristicText.c_str(), source.handle,
                    source.reportId, source.reportType, ok ? "OK" : "FAILED");

      if (ok) {
        subscribed++;
        if (isHidService) hidSubscribed++;
        else proprietarySubscribed++;
      } else {
        bleInputSourceCount--;
      }
    }
  }

  bleConnected = subscribed > 0;
  if (!bleConnected) {
    bleClient->disconnect();
    return false;
  }

  if (bleRemovalInProgress) {
    bleClient->disconnect();
    return false;
  }
  if (saveOnSuccess) saveRemoteDevice(device);
  Serial.printf("BLE: subscribed to %u input characteristic(s): HID=%u other=%u.\n",
                subscribed, hidSubscribed, proprietarySubscribed);
  return true;
}

bool allBytesZero(const uint8_t *data, uint8_t start, uint8_t length)
{
  for (uint8_t i = start; i < length; i++) if (data[i] != 0) return false;
  return true;
}

bool reportIsRelease(const BleReportPacket &packet)
{
  if (!packet.length) return true;

  // HOGP Report characteristics already identify the report through their
  // Report Reference descriptor. Their notification payload is report data,
  // not a leading report-ID byte. A release is therefore an all-zero report.
  //
  // Do not treat "byte 0 non-zero, remaining bytes zero" as a release. Fire
  // TV remotes use compact arrays such as B4 00 00 00 for Rewind and
  // 4F 00 00 for Right. The old heuristic discarded every one of those
  // single-button reports and only exposed them while another key was held.
  return allBytesZero(packet.data, 0, packet.length);
}

UiAction keyboardUsageAction(uint8_t usage)
{
  switch (usage) {
    case 0x52: return ACT_NAV_UP;
    case 0x51: return ACT_NAV_DOWN;
    case 0x50: return ACT_LEFT;
    case 0x4F: return ACT_RIGHT;
    case 0x28: return ACT_SELECT;
    case 0x58: return ACT_SELECT; // Keypad Enter, used by some media remotes.
    case 0x29: return ACT_BACK;
    case 0x4A: return ACT_HOME;
    case 0xF1: return ACT_BACK;   // Fire TV remote Back usage in report 1.
  }
  return ACT_NONE;
}

UiAction standardKeyboardAction(const uint8_t *data, uint8_t length)
{
  // Standard 8-byte boot/report keyboard, optionally prefixed by report ID.
  uint8_t offset = length == 9 ? 1 : 0;
  if (length - offset >= 8) {
    for (uint8_t i = offset + 2; i < offset + 8; i++) {
      UiAction action = keyboardUsageAction(data[i]);
      if (action != ACT_NONE) return action;
    }
  }

  // Compact Fire TV reports often use F1 as a prefix, e.g. F1 52 00 for Up.
  // Prefer a real direction/select usage before treating a lone F1 as Back.
  if (length <= 6) {
    for (uint8_t i = 0; i < length; i++) {
      if (data[i] == 0 || data[i] == 0xF1) continue;
      UiAction action = keyboardUsageAction(data[i]);
      if (action != ACT_NONE) return action;
    }
    for (uint8_t i = 0; i < length; i++) {
      if (data[i] == 0xF1) return ACT_BACK;
    }
  }
  return ACT_NONE;
}

UiAction consumerUsageAction(uint16_t usage)
{
  switch (usage) {
    case 0x00E9: return ACT_VOL_UP;
    case 0x00EA: return ACT_VOL_DOWN;
    case 0x00E2: return ACT_MUTE;
    case 0x00CD: return ACT_INPUT_TOGGLE;
    case 0x00B3: return ACT_PRESET_NEXT;
    case 0x00B4: return ACT_PRESET_PREV;
    case 0x00B5: return ACT_PRESET_NEXT;
    case 0x00B6: return ACT_PRESET_PREV;
    case 0x0030: return ACT_VISUALIZER_TOGGLE; // Power.
    case 0x0040: return ACT_MENU_TOGGLE;       // Menu.
    case 0x0221: return ACT_BACK;              // Fire TV Back on some revisions.
    case 0x0223: return ACT_HOME;
    case 0x0224: return ACT_BACK;
  }
  return ACT_NONE;
}

UiAction standardConsumerAction(const uint8_t *data, uint8_t length)
{
  // Consumer reports can be one 16-bit usage or an array of several usages.
  // Odd-sized reports may include a leading report-ID byte.
  uint8_t offset = (length & 1U) ? 1 : 0;
  for (uint8_t i = offset; i + 1 < length; i += 2) {
    uint16_t usage = (uint16_t)data[i] | ((uint16_t)data[i + 1] << 8);
    UiAction action = consumerUsageAction(usage);
    if (action != ACT_NONE) return action;
  }
  return ACT_NONE;
}

bool extractKeyboardUsageIdentity(const uint8_t *data, uint8_t length,
                                  uint16_t &usage, bool &chord)
{
  usage = 0;
  chord = false;
  if (length != 8 && length != 9) return false;
  uint8_t offset = length == 9 ? 1 : 0;
  uint8_t count = 0;
  for (uint8_t i = offset + 2; i < offset + 8; i++) {
    if (data[i] == 0) continue;
    if (count == 0) usage = data[i];
    count++;
  }
  bool modifierHeld = data[offset] != 0;
  chord = count > 1 || (modifierHeld && count > 0);
  return count > 0;
}

bool extractConsumerUsageIdentity(const uint8_t *data, uint8_t length,
                                  uint16_t &usage, bool &chord)
{
  usage = 0;
  chord = false;
  uint8_t offset = (length & 1U) ? 1 : 0;
  uint8_t count = 0;
  bool recognized = false;
  for (uint8_t i = offset; i + 1 < length; i += 2) {
    uint16_t candidate = (uint16_t)data[i] | ((uint16_t)data[i + 1] << 8);
    if (candidate == 0) continue;
    if (count == 0) usage = candidate;
    count++;
    if (consumerUsageAction(candidate) != ACT_NONE) recognized = true;
  }
  chord = count > 1;
  return recognized && count > 0;
}

void inspectLearnIdentity(const BleReportPacket &packet, BleMappingKind &kind,
                          uint16_t &usage, bool &chord)
{
  kind = BLE_MAP_RAW;
  usage = 0;
  chord = false;

  if (extractKeyboardUsageIdentity(packet.data, packet.length, usage, chord)) {
    kind = BLE_MAP_KEYBOARD_USAGE;
    return;
  }
  if (extractConsumerUsageIdentity(packet.data, packet.length, usage, chord)) {
    kind = BLE_MAP_CONSUMER_USAGE;
    return;
  }

  // Compact proprietary reports remain raw. We can still reject a compact
  // report that contains more than one independently recognized key usage.
  uint8_t recognizedKeys = 0;
  if (packet.length <= 6) {
    for (uint8_t i = 0; i < packet.length; i++) {
      if (packet.data[i] == 0 || packet.data[i] == 0xF1) continue;
      if (keyboardUsageAction(packet.data[i]) != ACT_NONE) recognizedKeys++;
    }
  }
  chord = recognizedKeys > 1;
}

UiAction lookupRemoteMapping(const BleReportPacket &packet)
{
  uint16_t keyboardUsage = 0;
  uint16_t consumerUsage = 0;
  bool keyboardChord = false;
  bool consumerChord = false;
  bool haveKeyboard = extractKeyboardUsageIdentity(packet.data, packet.length,
                                                   keyboardUsage, keyboardChord);
  bool haveConsumer = extractConsumerUsageIdentity(packet.data, packet.length,
                                                   consumerUsage, consumerChord);

  for (uint8_t i = 0; i < BLE_MAPPING_COUNT; i++) {
    const RemoteMapEntry &entry = remoteMap[i];
    if (!remoteMapEntrySet(entry) || entry.sourceKey != packet.sourceKey ||
        entry.reportId != packet.reportId) continue;

    if (entry.matchKind == BLE_MAP_KEYBOARD_USAGE && haveKeyboard && !keyboardChord &&
        entry.usage == keyboardUsage) return entry.action;
    if (entry.matchKind == BLE_MAP_CONSUMER_USAGE && haveConsumer && !consumerChord &&
        entry.usage == consumerUsage) return entry.action;
    if (entry.matchKind == BLE_MAP_RAW && entry.length == packet.length && packet.length &&
        memcmp(entry.bytes, packet.data, packet.length) == 0) return entry.action;
  }
  return ACT_NONE;
}

String consumerUsageLabel(uint16_t usage)
{
  switch (usage) {
    case 0x00E9: return "Volume +";
    case 0x00EA: return "Volume -";
    case 0x00E2: return "Mute";
    case 0x00CD: return "Play / Pause";
    case 0x00B3: return "Fast forward";
    case 0x00B4: return "Rewind";
    case 0x00B5: return "Next";
    case 0x00B6: return "Previous";
    case 0x0030: return "Power";
    case 0x0040: return "Menu";
    case 0x0221: return "Back";
    case 0x0223: return "Home";
    case 0x0224: return "Back";
  }
  return "";
}

String describeRemoteReport(const uint8_t *data, uint8_t length)
{
  uint8_t offset = (length & 1U) ? 1 : 0;
  for (uint8_t i = offset; i + 1 < length; i += 2) {
    uint16_t usage = (uint16_t)data[i] | ((uint16_t)data[i + 1] << 8);
    String label = consumerUsageLabel(usage);
    if (label.length()) return label;
  }

  UiAction keyboard = standardKeyboardAction(data, length);
  switch (keyboard) {
    case ACT_NAV_UP: return "Up";
    case ACT_NAV_DOWN: return "Down";
    case ACT_LEFT: return "Left";
    case ACT_RIGHT: return "Right";
    case ACT_SELECT: return "Select";
    case ACT_BACK: return "Back";
    case ACT_HOME: return "Home";
    default: return "Button";
  }
}

bool learnRemoteReport(const BleReportPacket &packet)
{
  if (packet.sourceKey == 0) {
    bleLearningAwaitRelease = true;
    bleLearningMessage = "Source unavailable";
    drawBleScreen();
    return false;
  }
  BleMappingKind matchKind = BLE_MAP_RAW;
  uint16_t usage = 0;
  bool chord = false;
  inspectLearnIdentity(packet, matchKind, usage, chord);
  if (chord) {
    bleLearningAwaitRelease = true;
    bleLearningMessage = "Release other buttons";
    bleLearningMessageUntil = 0;
    drawBleScreen();
    return false;
  }

  UiAction action = bleMappingActions[bleMappingIndex];
  for (uint8_t i = 0; i < BLE_MAPPING_COUNT; i++) {
    if (i == bleMappingIndex || remoteMap[i].sourceKey != packet.sourceKey ||
        remoteMap[i].reportId != packet.reportId ||
        remoteMap[i].matchKind != matchKind) continue;
    bool duplicate = matchKind == BLE_MAP_RAW
      ? (remoteMap[i].length == packet.length &&
         memcmp(remoteMap[i].bytes, packet.data, packet.length) == 0)
      : (remoteMap[i].usage == usage);
    if (duplicate) memset(&remoteMap[i], 0, sizeof(remoteMap[i]));
  }

  RemoteMapEntry &entry = remoteMap[bleMappingIndex];
  memset(&entry, 0, sizeof(entry));
  entry.sourceKey = packet.sourceKey;
  entry.reportId = packet.reportId;
  entry.matchKind = matchKind;
  entry.usage = usage;
  if (matchKind == BLE_MAP_RAW) {
    entry.length = packet.length;
    memcpy(entry.bytes, packet.data, packet.length);
  }
  entry.action = action;
  String label = describeRemoteReport(packet.data, packet.length);
  label.toCharArray(entry.label, sizeof(entry.label));
  saveRemoteMappings();

  bleUiMode = BLE_UI_MESSAGE;
  bleMessage = "Saved";
  bleMessageUntil = millis() + 900;
  drawBleScreen();
  return true;
}

UiAction actionForRemotePacket(const BleReportPacket &packet)
{
  // Parsers are retained for stable learning identities and readable labels,
  // but no report is allowed to control the panel until the user maps it.
  return lookupRemoteMapping(packet);
}

bool remoteActionCanRepeat(UiAction action)
{
  return action == ACT_VOL_UP || action == ACT_VOL_DOWN;
}

void clearBleHeldState()
{
  bleButtonHeld = false;
  bleHeldSourceKey = 0;
  bleHeldReportId = 0;
  bleHeldLength = 0;
  memset(bleHeldData, 0, sizeof(bleHeldData));
  bleHeldLastSeenAt = 0;
  bleHeldStartedAt = 0;
  bleHeldLastDispatchAt = 0;
  bleHeldAction = ACT_NONE;
  bleHeldCanRepeat = false;
  bleHeldFailsafeBlocked = false;
}

bool packetMatchesHeldFingerprint(const BleReportPacket &packet)
{
  return bleHeldSourceKey == packet.sourceKey &&
         bleHeldReportId == packet.reportId &&
         bleHeldLength == packet.length &&
         memcmp(bleHeldData, packet.data, packet.length) == 0;
}

void serviceBleHeldButton()
{
  if (!bleButtonHeld) return;
  uint32_t now = millis();
  uint32_t heldFor = (uint32_t)(now - bleHeldStartedAt);

  // A remote that never releases cannot run volume forever. After eight
  // seconds the exact held fingerprint is suppressed until release or a
  // different non-zero report arrives.
  if (heldFor >= BLE_HELD_FAILSAFE_MS) {
    bleButtonHeld = false;
    bleHeldAction = ACT_NONE;
    bleHeldCanRepeat = false;
    bleHeldFailsafeBlocked = true;
    return;
  }

  if (!bleHeldCanRepeat || bleHeldAction == ACT_NONE) return;
  if (heldFor < BLE_REPEAT_DELAY_MS) return;
  if ((uint32_t)(now - bleHeldLastDispatchAt) < BLE_REPEAT_INTERVAL_MS) return;

  bleHeldLastDispatchAt = now;
  float stepDb = 0.5f;
  if (heldFor >= BLE_REPEAT_ACCEL_3_MS) stepDb = 4.0f;
  else if (heldFor >= BLE_REPEAT_ACCEL_2_MS) stepDb = 2.0f;
  else if (heldFor >= BLE_REPEAT_ACCEL_1_MS) stepDb = 1.0f;
  changeVolume(bleHeldAction == ACT_VOL_UP ? stepDb : -stepDb);
}

void processBleReport(const BleReportPacket &packet)
{
  if (reportIsRelease(packet)) {
    clearBleHeldState();
    if (bleUiMode == BLE_UI_LEARNING) {
      bleLearningAwaitRelease = false;
      bleLearningMessage = "";
      bleLearningMessageUntil = 0;
      drawBleScreen();
    }
    return;
  }

  if (uiView == VIEW_BLE && bleUiMode == BLE_UI_LEARNING) {
    if (bleLearningAwaitRelease) return;
    learnRemoteReport(packet);
    return;
  }

  bool sameFingerprint = (bleButtonHeld || bleHeldFailsafeBlocked) &&
                         packetMatchesHeldFingerprint(packet);
  if (bleHeldFailsafeBlocked) {
    if (sameFingerprint) return;
    clearBleHeldState();
  }

  if (bleButtonHeld && sameFingerprint) {
    bleHeldLastSeenAt = packet.receivedAt;
    return;
  }

  // A different non-zero report replaces the old hold atomically.
  clearBleHeldState();
  bleButtonHeld = true;
  bleHeldSourceKey = packet.sourceKey;
  bleHeldReportId = packet.reportId;
  bleHeldLength = packet.length;
  bleHeldLastSeenAt = packet.receivedAt;
  bleHeldStartedAt = packet.receivedAt;
  bleHeldLastDispatchAt = packet.receivedAt;
  memcpy(bleHeldData, packet.data, packet.length);

  UiAction action = actionForRemotePacket(packet);
  if (uiView == VIEW_HOME) action = resolveHomeShortcut(action);
  bleHeldAction = action;
  bleHeldCanRepeat = remoteActionCanRepeat(action);

  Serial.printf("BLE RAW src=%08lX h=%04X rid=%u type=%u data=",
                (unsigned long)packet.sourceKey, packet.handle,
                packet.reportId, packet.reportType);
  for (uint8_t i = 0; i < packet.length; i++) Serial.printf("%02X", packet.data[i]);
  Serial.println();

  if (action != ACT_NONE) dispatchUiAction(action);
}

void sortBleResults()
{
  portENTER_CRITICAL(&bleDataMux);
  uint8_t count = bleDeviceCount;
  for (uint8_t i = 0; i < count; i++) {
    for (uint8_t j = i + 1; j < count; j++) {
      if (bleDevices[j].rssi > bleDevices[i].rssi) {
        BleDeviceInfo tmp = bleDevices[i];
        bleDevices[i] = bleDevices[j];
        bleDevices[j] = tmp;
      }
    }
  }
  portEXIT_CRITICAL(&bleDataMux);
}

void pollBleRemote()
{
  if (bleRemovalInProgress) {
    serviceBleRemoteRemoval();
  } else if (bleStackRestartPending && !bleConnectTaskRunning &&
      (long)(millis() - bleStackRestartRetryAt) >= 0) {
    bleStackRestartPending = !restartBleRemoteStack();
    bleStackRestartRetryAt = millis() + 1000;
  }

  if (bleConnectRequested && !bleConnectTaskRunning) {
    bleConnectRequested = false;
    bleConnectDevice = blePendingDevice;
    bleConnectTaskSave = blePendingSave;
    blePendingSave = false;
    bleConnectTaskFinished = false;
    bleConnectTaskRunning = true;

    BaseType_t created = xTaskCreatePinnedToCore(
      bleConnectWorker,
      "ble-connect",
      6144,
      nullptr,
      1,
      nullptr,
      1
    );
    if (created != pdPASS) {
      bleConnectTaskRunning = false;
      bleConnectTaskResult = false;
      bleConnectTaskFinished = true;
    }
  }

  if (bleConnectTaskFinished) {
    bleConnectTaskFinished = false;
    bool ok = bleConnectTaskResult;
    bool save = bleConnectTaskSave;
    bleConnectTaskSave = false;
    if (save) {
      if (ok) clampBleMenuIndex();
      if (!ok) scheduleSavedReconnect();
      bleUiMode = BLE_UI_MESSAGE;
      bleMessage = ok ? "Remote saved" : "No key reports";
      bleMessageUntil = millis() + 1800;
      drawBleScreen();
    }
  }

  if (bleScanFinished) {
    bleScanFinished = false;
    BleScanPurpose finishedPurpose = bleScanPurpose;
    bleScanPurpose = BLE_SCAN_NONE;
    if (finishedPurpose == BLE_SCAN_USER) {
      sortBleResults();
      uint8_t count;
      portENTER_CRITICAL(&bleDataMux);
      count = bleDeviceCount;
      portEXIT_CRITICAL(&bleDataMux);
      bleUiMode = count ? BLE_UI_RESULTS : BLE_UI_MESSAGE;
      if (!count) {
        bleMessage = "None found";
        bleMessageUntil = millis() + 1800;
      }
      drawBleScreen();
    }
  }

  BleReportPacket packet;
  while (bleReportQueue && xQueueReceive(bleReportQueue, &packet, 0) == pdTRUE) {
    processBleReport(packet);
  }
  serviceBleHeldButton();

  if (bleConnectionChanged) {
    bleConnectionChanged = false;
    if (menuPage == PAGE_BLUETOOTH || uiView == VIEW_BLE) redrawCurrentView();
  }

  bool animateBle = bleUiMode == BLE_UI_SCANNING ||
                    (bleUiMode == BLE_UI_MESSAGE &&
                     (bleMessage == "Pairing" || bleMessage == "Removing remote"));
  if (animateBle && millis() - bleLastAnimationAt >= 90) {
    bleLastAnimationAt = millis();
    bleAnimationStep = (bleAnimationStep + 1) % 12;
    drawBleScreen();
  }

  if (bleUiMode == BLE_UI_MESSAGE && bleMessageUntil &&
      (long)(millis() - bleMessageUntil) >= 0) {
    bleMessageUntil = 0;
    if (bleMessage == "Saved") {
      bleUiMode = BLE_UI_MAPPING;
      drawBleScreen();
    } else {
      bleBack();
    }
  }

  if (bleProfileValid && !bleConnected && !bleScanActive && !bleRemovalInProgress &&
      !bleStackRestartPending && bleStackReady &&
      !bleConnectRequested && bleUiMode != BLE_UI_SCANNING &&
      millis() - lastBleScanAt >= BLE_RESCAN_INTERVAL_MS) {
    startBleScan(BLE_SCAN_RECONNECT, BLE_RECONNECT_SCAN_MS);
  }
}

#else

void beginBleRemote() {}
void bleStartUserScan() {
  bleUiMode = BLE_UI_MESSAGE;
  bleMessage = "BLE unavailable";
  bleMessageUntil = millis() + 1600;
  drawBleScreen();
}
void pollBleRemote() {}

