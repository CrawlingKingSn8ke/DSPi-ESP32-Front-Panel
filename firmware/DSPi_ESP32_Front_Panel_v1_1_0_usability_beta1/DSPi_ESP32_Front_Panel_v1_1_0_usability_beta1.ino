String sourceText()
{
  return inputSourceDisplayText(dspi.source);
}

String sourceMenuText(InputSource source)
{
  return inputSourceDisplayText(source);
}

String presetText()
{
  // Firmware preset slots are zero-based internally. The front panel is
  // deliberately one-based so the first preset is presented as P1, not P0.
  return "P" + String((int)dspi.activePreset + 1);
}

String volumeText()
{
  return String(dspi.volumeDb, 1);
}

String sampleRateText()
{
  uint32_t rate = dspi.sampleRate;
  if (rate == 0) return "--.- KHz";
  if (rate % 1000 == 0) return String(rate / 1000) + ".0 KHz";
  return String(rate / 1000.0f, 1) + " KHz";
}

String audioMetaText()
{
  if (!dspi.connected) return "NO DSPi";
  if (isSpdifSource(dspi.source) && dspi.spdifState != 2) return "PCM NO LOCK";
  if (dspi.source == SRC_ADAT && dspi.adatState != 3) return "PCM NO LOCK";
  return String(dspi.spdifNonAudio ? "DATA " : "PCM ") + sampleRateText();
}

bool isPresetOccupied(uint8_t slot)
{
  return slot < 10 && (dspi.occupiedPresets & (1u << slot));
}

int8_t firstOccupiedPreset()
{
  for (uint8_t slot = 0; slot < 10; slot++) {
    if (isPresetOccupied(slot)) return (int8_t)slot;
  }
  return -1;
}

uint8_t displayedPresetSlot()
{
  if (menuPage == PAGE_PRESET && menuIndex == 0 &&
      isPresetOccupied((uint8_t)editInt)) return (uint8_t)editInt;
  if (isPresetOccupied(dspi.activePreset)) return dspi.activePreset;
  int8_t first = firstOccupiedPreset();
  return first >= 0 ? (uint8_t)first : dspi.activePreset;
}

String presetName(uint8_t slot)
{
  if (!isPresetOccupied(slot)) return "";

  String name = cleanDisplayText(String(dspi.presetNames[slot]), 24);
  if (name.length() == 0) return "";

  String genericLong = "Preset " + String((int)slot + 1);
  String genericShort = "P" + String((int)slot + 1);
  if (name.equalsIgnoreCase(genericLong) || name.equalsIgnoreCase(genericShort)) return "";

  return name;
}

String crossfeedProfileText(uint8_t value)
{
  switch (value) {
    case 0: return "Balanced";
    case 1: return "Strong";
    case 2: return "Natural";
    case 3: return "Custom";
    default: return "Balanced";
  }
}

String levellerSpeedText(uint8_t value)
