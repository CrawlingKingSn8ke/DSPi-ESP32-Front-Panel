  canvas->flush();
}

void transitionToStatusScreen()
{
  fadeUiOut();
  drawStatusScreen();
  fadeUiIn();
}

void transitionToBleScreen()
{
  fadeUiOut();
  drawBleScreen();
  fadeUiIn();
}

void redrawCurrentView()
{
  if (uiView == VIEW_HOME) drawHome();
  else if (uiView == VIEW_STATUS) drawStatusScreen();
  else if (uiView == VIEW_BLE) drawBleScreen();
  else if (uiView == VIEW_VISUALIZER) drawVisualizer();
  else if (uiView == VIEW_FEATURE_CONFIRM) drawFeatureConfirmation();
  else if (uiView == VIEW_PRESET_SAVE_CONFIRM) drawPresetSaveConfirmation();
  else if (uiView == VIEW_CHANGE_OVERLAY) drawChangeOverlay();
  else drawMenu();
}

void dismissFeatureConfirmation()
{
  if (uiView != VIEW_FEATURE_CONFIRM) return;
  UiView returnView = featureConfirmReturnView;
  featureConfirmUntil = 0;
  featureConfirmName = "";
  uiView = returnView;
  redrawCurrentView();
}

// -----------------------------------------------------------------------------
// Menu operation and user actions
// -----------------------------------------------------------------------------

int8_t mainIndexForPage(MenuPage page)
{
  switch (page) {
    case PAGE_INPUT: return 0;
    case PAGE_PRESET: return 1;
    case PAGE_LOUDNESS: return 2;
    case PAGE_CROSSFEED: return 3;
    case PAGE_LEVELLER: return 4;
    case PAGE_PSYBASS: return 5;
    case PAGE_BLUETOOTH: return 6;
    case PAGE_SYSTEM: return 7;
    default: return -1;
  }
}

MenuPage pageForMainIndex(uint8_t index)
{
  const MenuPage pages[] = {
    PAGE_INPUT, PAGE_PRESET, PAGE_LOUDNESS, PAGE_CROSSFEED,
    PAGE_LEVELLER, PAGE_PSYBASS, PAGE_BLUETOOTH, PAGE_SYSTEM
  };
  return pages[std::min<uint8_t>(index, 7)];
}

void enterPage(MenuPage page)
{
  encoderMenuDetentRemainder = 0;
  fadeUiOut();
  // Preset names are Console-owned metadata. Refresh them on demand so a
  // rename made on the PC appears without requiring a front-panel reboot.
  if (dspi.connected && (page == PAGE_PRESET || page == PAGE_INPUT)) {
    syncCurrentState(page == PAGE_PRESET);
  }

  MenuPage previousPage = menuPage;
  if (previousPage == PAGE_MAIN) {
    lastMainMenuIndex = std::min<uint8_t>(menuIndex, menuItemCount(PAGE_MAIN) - 1);
  } else {
    rememberedMenuIndex[previousPage] =
      std::min<uint8_t>(menuIndex, menuItemCount(previousPage) - 1);
  }

  if (page == PAGE_MAIN) {
    int8_t previousCategory = mainIndexForPage(previousPage);
    if (previousCategory >= 0) lastMainMenuIndex = (uint8_t)previousCategory;
    menuIndex = std::min<uint8_t>(lastMainMenuIndex, menuItemCount(PAGE_MAIN) - 1);
  } else {
    menuIndex = std::min<uint8_t>(rememberedMenuIndex[page], menuItemCount(page) - 1);
  }
  menuPage = page;
  editActive = false;
  if (page == PAGE_BLUETOOTH && (bleRemovalInProgress || bleStackRestartPending)) {
    bleUiMode = BLE_UI_MESSAGE;
    bleMessage = bleRemovalInProgress ? "Removing remote" : "BLE restarting";
    bleMessageUntil = 0;
    bleAnimationStep = 0;
    bleLastAnimationAt = millis();
    drawBleScreen();
    fadeUiIn();
    return;
  }
  if (page == PAGE_PRESET) {
    editInt = isPresetOccupied(dspi.activePreset) ? dspi.activePreset : firstOccupiedPreset();
  }
  drawMenu();
  fadeUiIn();
}

void cancelActiveEdit()
{
  if (!editActive) return;
  if (menuPage == PAGE_SCREEN_SETTINGS && menuIndex == 2) {
    brightnessPercent = (uint8_t)editOriginalInt;
    applyBrightness();
  }
  if (menuPage == PAGE_SYSTEM && menuIndex == 2 &&
      fabsf(dspi.masterVolumeDb - editOriginalFloat) > 0.26f) {
    if (!setMasterVolumeVerified(editOriginalFloat)) showToast("Restore failed");
  }
  editActive = false;
}

void goBack()
{
  if (uiView == VIEW_VISUALIZER) {
    transitionToHome();
    return;
  }
  if (uiView == VIEW_BLE) {
    bleBack();
    return;
  }
  if (uiView == VIEW_STATUS) {
    enterPage(PAGE_SYSTEM);
    return;
  }
  if (uiView == VIEW_PRESET_SAVE_CONFIRM) {
    enterPage(PAGE_PRESET);
    return;
  }
  if (uiView == VIEW_CHANGE_OVERLAY) {
    dismissChangeOverlay();
    return;
  }
  if (editActive) {
    cancelActiveEdit();
    drawMenu();
    return;
  }
  if (menuPage != PAGE_MAIN) {
    if (menuPage == PAGE_SCREEN_SETTINGS) {
      enterPage(PAGE_SYSTEM);
      return;
    }
    enterPage(PAGE_MAIN);
    return;
  }
  transitionToHome();
}

void beginEdit()
{
  editActive = true;
  if (menuPage == PAGE_INPUT) {
    editInt = (int)dspi.source;
  } else if (menuPage == PAGE_PRESET) {
    if (isPresetOccupied(dspi.activePreset)) editInt = dspi.activePreset;
    else editInt = firstOccupiedPreset();
  }
  else if (menuPage == PAGE_LOUDNESS) {
    if (menuIndex == 0) editBool = dspi.loudnessEnabled;
    else if (menuIndex == 1) editFloat = dspi.loudnessReferenceSpl;
    else editFloat = dspi.loudnessIntensity;
  } else if (menuPage == PAGE_CROSSFEED) {
    if (menuIndex == 0) editBool = dspi.crossfeedEnabled;
    else if (menuIndex == 1) editInt = dspi.crossfeedPreset;
    else if (menuIndex == 2) editFloat = dspi.crossfeedFrequencyHz;
    else editFloat = dspi.crossfeedFeedDb;
  } else if (menuPage == PAGE_LEVELLER) {
    if (menuIndex == 0) editBool = dspi.levellerEnabled;
    else if (menuIndex == 1) editFloat = dspi.levellerAmount;
    else if (menuIndex == 2) editInt = dspi.levellerSpeed;
    else if (menuIndex == 3) editFloat = dspi.levellerMaxGainDb;
    else if (menuIndex == 4) editFloat = dspi.levellerGateDb;
    else editBool = dspi.levellerLookahead;
  } else if (menuPage == PAGE_PSYBASS) {
    if (menuIndex == 0) editBool = dspi.psybassEnabled;
    else if (menuIndex == 1) editFloat = dspi.psybassCutoffHz;
    else if (menuIndex == 2) editFloat = dspi.psybassHarmonicsDb;
    else if (menuIndex == 3) editFloat = dspi.psybassDriveDb;
    else if (menuIndex == 4) editFloat = dspi.psybassCharacterPct;
    else editFloat = dspi.psybassOriginalDb;
  } else if (menuPage == PAGE_SYSTEM && menuIndex == 2) {
    editFloat = dspi.masterVolumeDb;
  } else if (menuPage == PAGE_SCREEN_SETTINGS) {
    if (menuIndex == 0) editInt = screenTimeoutOption;
    else if (menuIndex == 1) editInt = screenDimPercent;
    else editInt = brightnessPercent;
  }
  encoderMenuDetentRemainder = 0;
  editOriginalFloat = editFloat;
  editOriginalInt = editInt;
  editOriginalBool = editBool;
  drawMenu();
}

uint8_t nextAvailablePreset(uint8_t current, int direction)
{
  if (firstOccupiedPreset() < 0) return current;

  for (uint8_t step = 0; step < 10; step++) {
    current = (uint8_t)((current + direction + 10) % 10);
    if (isPresetOccupied(current)) return current;
  }
  return current;
}

float wrapEditFloat(float current, int direction, float step, float minimum, float maximum)
{
  const float epsilon = step * 0.25f;
  if (direction > 0 && current >= maximum - epsilon) return minimum;
  if (direction < 0 && current <= minimum + epsilon) return maximum;
  return constrain(current + (direction > 0 ? step : -step), minimum, maximum);
}

int wrapEditInt(int current, int direction, int step, int minimum, int maximum)
{
  if (direction > 0 && current >= maximum) return minimum;
  if (direction < 0 && current <= minimum) return maximum;
  return constrain(current + (direction > 0 ? step : -step), minimum, maximum);
}

void adjustEdit(int direction)
{
  if (!editActive) return;
  if (menuPage == PAGE_INPUT) {
    editInt = (int)nextInputSourceChoice((InputSource)editInt, direction);
  } else if (menuPage == PAGE_PRESET) editInt = nextAvailablePreset((uint8_t)editInt, direction);
  else if (menuPage == PAGE_LOUDNESS) {
    if (menuIndex == 0) editBool = !editBool;
    else if (menuIndex == 1) editFloat = wrapEditFloat(editFloat, direction, 1.0f, 40.0f, 100.0f);
    else editFloat = wrapEditFloat(editFloat, direction, 5.0f, 0.0f, 200.0f);
  } else if (menuPage == PAGE_CROSSFEED) {
    if (menuIndex == 0) editBool = !editBool;
    else if (menuIndex == 1) editInt = (editInt + direction + 4) % 4;
    else if (menuIndex == 2) editFloat = wrapEditFloat(editFloat, direction, 50.0f, 500.0f, 2000.0f);
    else editFloat = wrapEditFloat(editFloat, direction, 0.5f, 0.0f, 15.0f);
  } else if (menuPage == PAGE_LEVELLER) {
    if (menuIndex == 0 || menuIndex == 5) editBool = !editBool;
    else if (menuIndex == 1) editFloat = wrapEditFloat(editFloat, direction, 5.0f, 0.0f, 100.0f);
    else if (menuIndex == 2) editInt = (editInt + direction + 3) % 3;
    else if (menuIndex == 3) editFloat = wrapEditFloat(editFloat, direction, 0.5f, 0.0f, 35.0f);
    else editFloat = wrapEditFloat(editFloat, direction, 1.0f, -96.0f, 0.0f);
  } else if (menuPage == PAGE_PSYBASS) {
    if (menuIndex == 0) editBool = !editBool;
    else if (menuIndex == 1) editFloat = wrapEditFloat(editFloat, direction, 5.0f, 30.0f, 300.0f);
    else if (menuIndex == 2) editFloat = wrapEditFloat(editFloat, direction, 0.5f, -24.0f, 12.0f);
    else if (menuIndex == 3) editFloat = wrapEditFloat(editFloat, direction, 0.5f, 0.0f, 18.0f);
    else if (menuIndex == 4) editFloat = wrapEditFloat(editFloat, direction, 5.0f, 0.0f, 100.0f);
    else editFloat = wrapEditFloat(editFloat, direction, 1.0f, -60.0f, 0.0f);
  } else if (menuPage == PAGE_SYSTEM && menuIndex == 2) {
    // Keep the live output-volume limit clamped: wrapping -60 dB directly to
    // 0 dB on one key press would be an unsafe 60 dB level jump.
    float target = constrain(roundf((editFloat + direction * 0.5f) * 2.0f) / 2.0f, -60.0f, 0.0f);
    if (fabsf(target - editFloat) > 0.01f) {
      if (setMasterVolumeVerified(target)) editFloat = dspi.masterVolumeDb;
      else showToast("DSPi error");
    }
  } else if (menuPage == PAGE_SCREEN_SETTINGS) {
    if (menuIndex == 0) editInt = wrapEditInt(editInt, direction, 1, 0, 4);
    else if (menuIndex == 1) editInt = wrapEditInt(editInt, direction, 10, 0, 80);
    else {
      editInt = wrapEditInt(editInt, direction, 10, 10, 100);
      brightnessPercent = editInt;
      applyBrightness();
    }
  }
  drawMenu();
}

void applyEdit()
{
  if (!editActive) return;

  if (menuPage == PAGE_INPUT &&
      !inputSourceAvailable((InputSource)editInt)) {
    showToast("Enable in Console");
    drawMenu();
    return;
  }

  bool ok = true;
  bool applyingPreset = menuPage == PAGE_PRESET;
  String successText = "Applied";
  if (menuPage == PAGE_INPUT) {
    InputSource selectedSource = (InputSource)editInt;
    ok = selectedSource == dspi.source ||
         (dspi.connected && setInputSource(selectedSource));
  } else if (menuPage == PAGE_PRESET) ok = loadPreset((uint8_t)editInt);
  else if (menuPage == PAGE_LOUDNESS) {
    if (menuIndex == 0) ok = setLoudness(editBool);
    else if (menuIndex == 1) ok = setLoudnessReference(editFloat);
    else ok = setLoudnessIntensity(editFloat);
  } else if (menuPage == PAGE_CROSSFEED) {
    if (menuIndex == 0) ok = setCrossfeed(editBool);
    else if (menuIndex == 1) ok = setCrossfeedPreset((uint8_t)editInt);
    else if (menuIndex == 2) ok = setCrossfeedFrequency(editFloat);
    else ok = setCrossfeedFeed(editFloat);
  } else if (menuPage == PAGE_LEVELLER) {
    if (menuIndex == 0) ok = setLeveller(editBool);
    else if (menuIndex == 1) ok = setLevellerAmount(editFloat);
    else if (menuIndex == 2) ok = setLevellerSpeed((uint8_t)editInt);
    else if (menuIndex == 3) ok = setLevellerMaxGain(editFloat);
    else if (menuIndex == 4) ok = setLevellerGate(editFloat);
    else ok = setLevellerLookahead(editBool);
  } else if (menuPage == PAGE_PSYBASS) {
    if (menuIndex == 0) ok = setPsybassEnabled(editBool);
    else if (menuIndex == 1) ok = setPsybassCutoff(editFloat);
    else if (menuIndex == 2) ok = setPsybassHarmonics(editFloat);
    else if (menuIndex == 3) ok = setPsybassDrive(editFloat);
    else if (menuIndex == 4) ok = setPsybassCharacter(editFloat);
    else ok = setPsybassOriginal(editFloat);
  } else if (menuPage == PAGE_SYSTEM && menuIndex == 2) {
    ok = ensureIndependentMasterVolumeModeVerified() &&
         setMasterVolumeVerified(editFloat) &&
         persistIndependentMasterVolumeVerified();
    successText = "Global limit saved";
  } else if (menuPage == PAGE_SCREEN_SETTINGS) {
    if (menuIndex == 0) {
      screenTimeoutOption = (uint8_t)editInt;
      preferences.putUChar("screen_to", screenTimeoutOption);
    } else if (menuIndex == 1) {
      screenDimPercent = (uint8_t)editInt;
      preferences.putUChar("screen_dim", screenDimPercent);
    } else {
      brightnessPercent = (uint8_t)editInt;
      preferences.putUChar("brightness", brightnessPercent);
      applyBrightness();
    }
    recordUserActivity();
    successText = "Saved";
  }

  editActive = false;
  if (applyingPreset && !ok) {
    editInt = isPresetOccupied(dspi.activePreset) ? dspi.activePreset : firstOccupiedPreset();
  }
  showToast(ok ? successText : "DSPi error");
  drawMenu();
}

void moveMenu(int direction)
{
  int count = menuItemCount(menuPage);
  int next = ((int)menuIndex + direction) % count;
  if (next < 0) next += count;
  menuIndex = (uint8_t)next;
  if (menuPage == PAGE_MAIN) lastMainMenuIndex = menuIndex;
  else rememberedMenuIndex[menuPage] = menuIndex;
  drawMenu();
}

void selectMenuItem()
{
  if (editActive) {
    applyEdit();
    return;
  }

  if (menuPage == PAGE_MAIN) {
    enterPage(pageForMainIndex(menuIndex));
    return;
  }

  if (menuPage == PAGE_SYSTEM && menuIndex == 0) {
    transitionToStatusScreen();
    return;
  }

  if (menuPage == PAGE_SYSTEM && menuIndex == 1) {
    enterPage(PAGE_SCREEN_SETTINGS);
    return;
  }

  if (menuPage == PAGE_BLUETOOTH) {
    switch (bleMenuActionForIndex(menuIndex)) {
      case BLE_MENU_DEVICE:
        if (!bleProfileValid) {
          showToast("No remote saved");
          drawMenu();
        } else {
          bleUiMode = BLE_UI_MESSAGE;
          bleMessage = bleConnected ? "Connected" : "Reconnecting";
          bleMessageUntil = millis() + 1800;
          transitionToBleScreen();
        }
        break;
      case BLE_MENU_FIND_REMOTE:
        fadeUiOut();
        bleStartUserScan();
        fadeUiIn();
        break;
      case BLE_MENU_KEY_MAP:
        clearBleHeldState();
        bleUiMode = BLE_UI_MAPPING;
        bleMappingIndex = 0;
        transitionToBleScreen();
        break;
      case BLE_MENU_SHORTCUTS:
        bleUiMode = BLE_UI_SHORTCUTS;
        bleShortcutIndex = 0;
        transitionToBleScreen();
        break;
      case BLE_MENU_RESTORE_DEFAULTS:
        bleUiMode = BLE_UI_CONFIRM_DEFAULTS;
        bleDefaultsYes = false;
        transitionToBleScreen();
        break;
      case BLE_MENU_REMOVE_REMOTE:
        bleUiMode = BLE_UI_CONFIRM_REMOVE;
        bleRemoveYes = false;
        transitionToBleScreen();
        break;
      default:
        showToast("Unavailable");
        drawMenu();
        break;
    }
    return;
  }

  if (menuPage == PAGE_PRESET && menuIndex == 1) {
    beginPresetSaveConfirmation();
    return;
  }

  if (menuPage == PAGE_PRESET && firstOccupiedPreset() < 0) {
    showToast("No presets");
    drawMenu();
    return;
  }

  if (menuPage == PAGE_PSYBASS && !psybassWritable()) {
    showToast("Unavailable");
    drawMenu();
    return;
  }

  beginEdit();
}

void changeVolume(float delta)
{
  if (!dspi.connected) {
    showToast("NO DSPi");
    redrawCurrentView();
    return;
  }
  float target = roundf((dspi.volumeDb + delta) * 2.0f) / 2.0f;
  if (!setUserVolume(target)) showToast("DSPi ERROR");
  redrawCurrentView();
}

void changePreset(int direction)
{
  uint8_t slot = nextAvailablePreset(dspi.activePreset, direction);
  // With only one occupied slot the wrapped search returns the active preset.
  // Reloading that slot would unexpectedly restore its saved volume and DSP
  // state even though Preset Previous/Next did not select a different preset.
  if (slot == dspi.activePreset && isPresetOccupied(slot)) {
    showToast("Only one preset");
    redrawCurrentView();
    return;
  }
  if (dspi.connected && !loadPreset(slot)) showToast("DSPi ERROR");
  redrawCurrentView();
}

void changeInput(int direction)
{
  if (!dspi.connected) {
    showToast("NO DSPi");
    redrawCurrentView();
    return;
  }
  InputSource target = nextInputSourceChoice(dspi.source, direction);
  if (target == dspi.source || !setInputSource(target)) {
    showToast(target == dspi.source ? "Only one input" : "DSPi error");
    redrawCurrentView();
    return;
  }
  showSourceChangeOverlay(dspi.source);
}

void dispatchUiAction(UiAction action)
{
  if (action == ACT_NONE) return;

  recordUserActivity();

  // A confirmation never swallows input: restore the exact previous view and
  // then process the action against that view.
  if (uiView == VIEW_FEATURE_CONFIRM) dismissFeatureConfirmation();
  if (uiView == VIEW_CHANGE_OVERLAY) dismissChangeOverlay();

  // Dedicated volume keys remain User Volume controls on every screen.
  if (action == ACT_VOL_UP) {
    changeVolume(0.5f);
    return;
  }
  if (action == ACT_VOL_DOWN) {
    changeVolume(-0.5f);
    return;
  }

  if (uiView == VIEW_PRESET_SAVE_CONFIRM) {
    if (action == ACT_LEFT || action == ACT_NAV_UP) {
      presetSaveConfirmYes = false;
      drawPresetSaveConfirmation();
    } else if (action == ACT_RIGHT || action == ACT_NAV_DOWN) {
      presetSaveConfirmYes = true;
      drawPresetSaveConfirmation();
    } else if (action == ACT_BACK || action == ACT_MENU_TOGGLE) {
      enterPage(PAGE_PRESET);
    } else if (action == ACT_HOME) {
      transitionToHome();
    } else if (action == ACT_SELECT) {
      if (!presetSaveConfirmYes) {
        enterPage(PAGE_PRESET);
      } else {
        bool accepted = saveCurrentPreset();
        menuPage = PAGE_PRESET;
        menuIndex = 1;
        rememberedMenuIndex[PAGE_PRESET] = 1;
        editActive = false;
        uiView = VIEW_MENU;
        showToast(accepted ? "Saving..." : "DSPi error");
        drawMenu();
      }
    }
    return;
  }

  if (uiView == VIEW_BLE) {
    if (action == ACT_HOME) transitionToHome();
    else if (action == ACT_MENU_TOGGLE) enterPage(PAGE_MAIN);
    else if (action == ACT_BACK) bleBack();
    else if (action == ACT_SELECT) bleSelect();
    else if (action == ACT_LEFT) bleNavigate(-1);
    else if (action == ACT_RIGHT) bleNavigate(1);
    return;
  }

  if (uiView == VIEW_EDIT) {
    bool handled = true;
    if (action == ACT_NAV_UP) adjustEdit(1);
    else if (action == ACT_NAV_DOWN) adjustEdit(-1);
    else if (action == ACT_SELECT) applyEdit();
    else if (action == ACT_BACK) goBack();
    else if (action == ACT_HOME) { cancelActiveEdit(); transitionToHome(); }
    else if (action == ACT_MENU_TOGGLE) { cancelActiveEdit(); transitionToHome(); }
    else if (action == ACT_VISUALIZER_TOGGLE) { cancelActiveEdit(); toggleVisualizer(); }
    else handled = false;
    if (handled) return;
  }

  if (uiView == VIEW_MENU) {
    bool handled = false;
    if (menuPage == PAGE_MAIN) {
      if (action == ACT_LEFT) { moveMenu(-1); handled = true; }
      else if (action == ACT_RIGHT) { moveMenu(1); handled = true; }
    } else {
      if (action == ACT_NAV_UP) { moveMenu(-1); handled = true; }
      else if (action == ACT_NAV_DOWN) { moveMenu(1); handled = true; }
    }
    if (action == ACT_SELECT) { selectMenuItem(); handled = true; }
    else if (action == ACT_BACK) { goBack(); handled = true; }
    if (action == ACT_HOME) { transitionToHome(); handled = true; }
    else if (action == ACT_MENU_TOGGLE) { transitionToHome(); handled = true; }
    else if (action == ACT_VISUALIZER_TOGGLE) { toggleVisualizer(); handled = true; }
    if (handled) return;
  }

  switch (action) {
    case ACT_MUTE: {
      bool visualizerActive = uiView == VIEW_VISUALIZER;
      if (dspi.connected) setUserMute(!dspi.muted);
      if (visualizerActive) drawVisualizer();
      else drawHome();
      break;
    }
    case ACT_NAV_UP:
      if (uiView == VIEW_HOME) changeVolume(0.5f); // Serial/test fallback only.
      break;
    case ACT_NAV_DOWN:
      if (uiView == VIEW_HOME) changeVolume(-0.5f); // Serial/test fallback only.
      break;
    case ACT_SELECT:
      if (uiView == VIEW_VISUALIZER) transitionToHome();
      else if (uiView == VIEW_HOME) enterPage(PAGE_MAIN);
      else if (uiView == VIEW_STATUS) goBack();
      break;
    case ACT_BACK: goBack(); break;
    case ACT_HOME:
      cancelActiveEdit();
      transitionToHome();
      break;
    case ACT_MENU_TOGGLE:
      if (uiView == VIEW_HOME || uiView == VIEW_VISUALIZER) {
        enterPage(PAGE_MAIN);
      } else {
        cancelActiveEdit();
        transitionToHome();
      }
      break;
    case ACT_LOUDNESS_TOGGLE: {
      bool fullScreen = uiView == VIEW_HOME;
      bool target = !dspi.loudnessEnabled;
      bool ok = dspi.connected && setLoudness(target);
      if (ok && fullScreen) showFeatureConfirmation("Loudness", target);
      else {
        showToast(ok ? (String("Loudness ") + (target ? "On" : "Off"))
                     : (dspi.connected ? "DSPi error" : "NO DSPi"), 900);
        redrawCurrentView();
      }
      break;
    }
    case ACT_CROSSFEED_TOGGLE: {
      bool fullScreen = uiView == VIEW_HOME;
      bool target = !dspi.crossfeedEnabled;
      bool ok = dspi.connected && setCrossfeed(target);
      if (ok && fullScreen) showFeatureConfirmation("Crossfeed", target);
      else {
        showToast(ok ? (String("Crossfeed ") + (target ? "On" : "Off"))
                     : (dspi.connected ? "DSPi error" : "NO DSPi"), 900);
        redrawCurrentView();
      }
      break;
    }
    case ACT_LEVELLER_TOGGLE: {
      bool fullScreen = uiView == VIEW_HOME;
      bool target = !dspi.levellerEnabled;
      bool ok = dspi.connected && setLeveller(target);
      if (ok && fullScreen) showFeatureConfirmation("Leveller", target);
      else {
        showToast(ok ? (String("Leveller ") + (target ? "On" : "Off"))
                     : (dspi.connected ? "DSPi error" : "NO DSPi"), 900);
        redrawCurrentView();
      }
      break;
    }
    case ACT_PSYBASS_TOGGLE: {
      bool fullScreen = uiView == VIEW_HOME;
      bool target = !dspi.psybassEnabled;
      bool ok = dspi.connected && psybassWritable() && setPsybassEnabled(target);
      if (ok && fullScreen) showFeatureConfirmation("Psy Bass", target);
      else {
        String failure = dspi.connected && !psybassWritable() ? "Unavailable" :
                         (dspi.connected ? "DSPi error" : "NO DSPi");
        showToast(ok ? (String("Psy Bass ") + (target ? "On" : "Off")) : failure, 900);
        redrawCurrentView();
      }
      break;
    }
    case ACT_PRESET_PREV: changePreset(-1); break;
    case ACT_PRESET_NEXT: changePreset(1); break;
    case ACT_INPUT_PREV: changeInput(-1); break;
    case ACT_INPUT_NEXT: changeInput(1); break;
    case ACT_INPUT_TOGGLE: changeInput(1); break;
    case ACT_VISUALIZER_TOGGLE:
      cancelActiveEdit();
      toggleVisualizer();
      break;
    default: break;
  }
}

// -----------------------------------------------------------------------------
// Encoder and push button
// -----------------------------------------------------------------------------

bool buttonRaw = true;
bool buttonStable = true;
bool buttonLongSent = false;
bool buttonVisualizerSent = false;
unsigned long buttonChangedAt = 0;
unsigned long buttonPressedAt = 0;

void IRAM_ATTR encoderEdgeIsr()
{
  uint8_t current = ((uint8_t)gpio_get_level((gpio_num_t)ENCODER_A_PIN) << 1) |
                    (uint8_t)gpio_get_level((gpio_num_t)ENCODER_B_PIN);
  uint8_t lookup = (encoderIsrPrevious << 2) | current;
  encoderIsrPrevious = current;

  int8_t delta = 0;
  switch (lookup) {
    case 0x2: case 0x4: case 0xB: case 0xD: delta = 1; break;
    case 0x1: case 0x7: case 0x8: case 0xE: delta = -1; break;
    default: break;
  }

  if (delta) {
    portENTER_CRITICAL_ISR(&encoderMux);
    encoderQuarterSteps += delta;
    portEXIT_CRITICAL_ISR(&encoderMux);
  }
}

void beginEncoder()
{
  pinMode(ENCODER_A_PIN, INPUT_PULLUP);
  pinMode(ENCODER_B_PIN, INPUT_PULLUP);
  pinMode(ENCODER_SW_PIN, INPUT_PULLUP);
  encoderIsrPrevious = (digitalRead(ENCODER_A_PIN) << 1) | digitalRead(ENCODER_B_PIN);
  attachInterrupt(digitalPinToInterrupt(ENCODER_A_PIN), encoderEdgeIsr, CHANGE);
  attachInterrupt(digitalPinToInterrupt(ENCODER_B_PIN), encoderEdgeIsr, CHANGE);
}

void applyEncoderDetents(int16_t detents)
{
  if (detents == 0) return;

  recordUserActivity();

  if (uiView == VIEW_FEATURE_CONFIRM) dismissFeatureConfirmation();
  if (uiView == VIEW_CHANGE_OVERLAY) dismissChangeOverlay();

  if (uiView == VIEW_PRESET_SAVE_CONFIRM) {
    presetSaveConfirmYes = detents > 0;
    encoderMenuDetentRemainder = 0;
    drawPresetSaveConfirmation();
    return;
  }

  if (uiView == VIEW_HOME || uiView == VIEW_VISUALIZER) {
    changeVolume((float)detents * 0.5f);
    return;
  }
  if (uiView == VIEW_MENU) {
    if ((encoderMenuDetentRemainder > 0 && detents < 0) ||
        (encoderMenuDetentRemainder < 0 && detents > 0)) {
      encoderMenuDetentRemainder = 0;
    }
    encoderMenuDetentRemainder += detents;
    int16_t steps = encoderMenuDetentRemainder / ENCODER_MENU_DETENTS_PER_STEP;
    encoderMenuDetentRemainder -= steps * ENCODER_MENU_DETENTS_PER_STEP;
    if (steps) moveMenu(steps);
    return;
  }
  if (uiView == VIEW_BLE) {
    if ((encoderMenuDetentRemainder > 0 && detents < 0) ||
        (encoderMenuDetentRemainder < 0 && detents > 0)) {
      encoderMenuDetentRemainder = 0;
    }
    encoderMenuDetentRemainder += detents;
    int16_t steps = encoderMenuDetentRemainder / ENCODER_MENU_DETENTS_PER_STEP;
    encoderMenuDetentRemainder -= steps * ENCODER_MENU_DETENTS_PER_STEP;
    if (steps) bleNavigate(steps);
    return;
  }
  encoderMenuDetentRemainder = 0;
  if (uiView == VIEW_EDIT) {
    int direction = detents > 0 ? 1 : -1;
    uint16_t count = (uint16_t)abs(detents);
    while (count--) adjustEdit(direction);
  }
}

void pollEncoder()
{
  int16_t quarterSteps = 0;
  portENTER_CRITICAL(&encoderMux);
  quarterSteps = encoderQuarterSteps;
  encoderQuarterSteps = 0;
  portEXIT_CRITICAL(&encoderMux);

  encoderDetentRemainder += quarterSteps;
  int16_t detents = 0;
  while (encoderDetentRemainder >= ENCODER_COUNTS_PER_DETENT) {
    encoderDetentRemainder -= ENCODER_COUNTS_PER_DETENT;
    detents++;
  }
  while (encoderDetentRemainder <= -ENCODER_COUNTS_PER_DETENT) {
    encoderDetentRemainder += ENCODER_COUNTS_PER_DETENT;
    detents--;
  }
  applyEncoderDetents(detents);

  bool raw = digitalRead(ENCODER_SW_PIN);
  if (raw != buttonRaw) {
    buttonRaw = raw;
    buttonChangedAt = millis();
  }
  if (millis() - buttonChangedAt < ENCODER_DEBOUNCE_MS || raw == buttonStable) return;

  buttonStable = raw;
  if (!buttonStable) {
    recordUserActivity();
    buttonPressedAt = millis();
    buttonLongSent = false;
    buttonVisualizerSent = false;
  } else if (!buttonLongSent && !buttonVisualizerSent) {
    unsigned long heldMs = millis() - buttonPressedAt;
    if (uiView == VIEW_VISUALIZER) {
      drawHome();
    } else if (uiView == VIEW_HOME && heldMs >= ENCODER_LONG_PRESS_MS) {
      dispatchUiAction(ACT_MUTE);
    } else {
      dispatchUiAction(ACT_SELECT);
    }
  }
}

void pollEncoderLongPress()
{
  if (buttonStable) return;
  unsigned long heldMs = millis() - buttonPressedAt;

  if (uiView == VIEW_HOME) {
    if (!buttonVisualizerSent && heldMs >= ENCODER_VISUALIZER_HOLD_MS) {
      buttonVisualizerSent = true;
      buttonLongSent = true;
      enterVisualizer();
    }
    return;
  }

  if (uiView != VIEW_VISUALIZER && !buttonLongSent && heldMs >= ENCODER_LONG_PRESS_MS) {
    buttonLongSent = true;
    dispatchUiAction(ACT_BACK);
  }
}

// -----------------------------------------------------------------------------
// BLE remote profile storage in ESP32 NVS
// -----------------------------------------------------------------------------

uint8_t countRemoteMappings()
{
  uint8_t count = 0;
  for (uint8_t i = 0; i < BLE_MAPPING_COUNT; i++) if (remoteMapEntrySet(remoteMap[i])) count++;
  return count;
}

int8_t mappingIndexForAction(UiAction action)
{
  for (uint8_t i = 0; i < BLE_MAPPING_COUNT; i++) {
    if (bleMappingActions[i] == action) return (int8_t)i;
  }
  return -1;
}

bool isValidHomeShortcut(UiAction action)
{
  for (uint8_t i = 0; i < HOME_SHORTCUT_OPTION_COUNT; i++) {
    if (homeShortcutOptions[i] == action) return true;
  }
  return false;
}

void resetHomeShortcutsToDefaults()
{
  memcpy(homeShortcuts, homeShortcutDefaults, sizeof(homeShortcuts));
}

void saveHomeShortcuts()
{
  preferences.putUChar("home_sc_ver", HOME_SHORTCUT_VERSION);
  preferences.putBytes("home_sc", homeShortcuts, sizeof(homeShortcuts));
}

void loadHomeShortcuts()
{
  resetHomeShortcutsToDefaults();
  uint8_t version = preferences.getUChar("home_sc_ver", 0);
  if (version == HOME_SHORTCUT_VERSION &&
      preferences.getBytesLength("home_sc") == sizeof(homeShortcuts)) {
    preferences.getBytes("home_sc", homeShortcuts, sizeof(homeShortcuts));
    bool repaired = false;
    for (uint8_t i = 0; i < HOME_SHORTCUT_COUNT; i++) {
      if (!isValidHomeShortcut(homeShortcuts[i])) {
        homeShortcuts[i] = homeShortcutDefaults[i];
        repaired = true;
      }
    }
    if (repaired) saveHomeShortcuts();
  } else if (version == 1 &&
             preferences.getBytesLength("home_sc") == 4 * sizeof(UiAction)) {
    // Preserve the released Up/Down/Left/Right assignments and seed Centre
    // with the old home-screen behaviour (open the main menu).
    UiAction legacy[4] = {};
    preferences.getBytes("home_sc", legacy, sizeof(legacy));
    for (uint8_t i = 0; i < 4; i++) {
      homeShortcuts[i] = isValidHomeShortcut(legacy[i])
                       ? legacy[i] : homeShortcutDefaults[i];
    }
    homeShortcuts[4] = ACT_MENU_TOGGLE;
    saveHomeShortcuts();
  } else {
    saveHomeShortcuts();
  }
}

uint8_t homeShortcutOptionIndex(UiAction action)
{
  for (uint8_t i = 0; i < HOME_SHORTCUT_OPTION_COUNT; i++) {
    if (homeShortcutOptions[i] == action) return i;
  }
  return 0;
}

UiAction resolveHomeShortcut(UiAction role)
{
  switch (role) {
    case ACT_NAV_UP: return homeShortcuts[0];
    case ACT_NAV_DOWN: return homeShortcuts[1];
    case ACT_LEFT: return homeShortcuts[2];
    case ACT_RIGHT: return homeShortcuts[3];
    case ACT_SELECT: return homeShortcuts[4];
    default: return role;
  }
}

void saveRemoteMappings()
{
  preferences.putUChar("ble_map_ver", BLE_MAPPING_VERSION);
  preferences.putBytes("ble_maps", remoteMap, sizeof(remoteMap));
}

void restoreRemoteDefaults()
{
  memset(remoteMap, 0, sizeof(remoteMap));
  saveRemoteMappings();
  resetHomeShortcutsToDefaults();
  saveHomeShortcuts();
}

void loadRemoteProfile()
{
  loadHomeShortcuts();
  memset(remoteMap, 0, sizeof(remoteMap));
  uint8_t version = preferences.getUChar("ble_map_ver", 0);
  if (version == BLE_MAPPING_VERSION && preferences.getBytesLength("ble_maps") == sizeof(remoteMap)) {
    preferences.getBytes("ble_maps", remoteMap, sizeof(remoteMap));
    for (uint8_t i = 0; i < BLE_MAPPING_COUNT; i++) {
      if (remoteMap[i].length > sizeof(remoteMap[i].bytes) ||
          remoteMap[i].action != bleMappingActions[i] ||
          remoteMap[i].matchKind > BLE_MAP_CONSUMER_USAGE ||
          (remoteMapEntrySet(remoteMap[i]) && remoteMap[i].sourceKey == 0) ||
          (remoteMap[i].matchKind == BLE_MAP_RAW && remoteMap[i].sourceKey && !remoteMap[i].length) ||
          (remoteMap[i].matchKind != BLE_MAP_RAW && remoteMap[i].sourceKey && !remoteMap[i].usage)) {
        memset(&remoteMap[i], 0, sizeof(remoteMap[i]));
      }
    }
  } else {
    // Fix6 mappings contained runtime GATT handles and cannot be migrated
    // reliably. Invalidate only custom keys; retain the saved/bonded device.
    saveRemoteMappings();
  }

  String address = preferences.getString("ble_addr", "");
  String name = preferences.getString("ble_name", "");
  if (address.length() == 17) {
    address.toCharArray(bleSavedAddress, sizeof(bleSavedAddress));
    if (name.length() == 0) name = "BLE remote";
    name.toCharArray(bleSavedName, sizeof(bleSavedName));
    bleSavedAddressType = preferences.getUChar("ble_type", 0);
    bleProfileValid = true;
  }
}

void saveRemoteDevice(const BleDeviceInfo &device)
{
  clearBleHeldState();
  bool newRemote = !bleProfileValid || !String(bleSavedAddress).equalsIgnoreCase(device.address);
  if (newRemote) {
    memset(remoteMap, 0, sizeof(remoteMap));
    saveRemoteMappings();
  }

  memset(bleSavedName, 0, sizeof(bleSavedName));
  memset(bleSavedAddress, 0, sizeof(bleSavedAddress));
  strncpy(bleSavedName, device.name, sizeof(bleSavedName) - 1);
  strncpy(bleSavedAddress, device.address, sizeof(bleSavedAddress) - 1);
  bleSavedAddressType = device.addressType;
  bleProfileValid = true;
  preferences.putString("ble_name", bleSavedName);
  preferences.putString("ble_addr", bleSavedAddress);
  preferences.putUChar("ble_type", bleSavedAddressType);
  preferences.putUChar("ble_ver", BLE_PROFILE_VERSION);
}

void beginBleRemoteRemoval()
{
  clearBleHeldState();
  if (bleRemovalInProgress) return;

  memset(bleRemovedAddress, 0, sizeof(bleRemovedAddress));
  if (bleProfileValid && strlen(bleSavedAddress) == 17) {
    strncpy(bleRemovedAddress, bleSavedAddress, sizeof(bleRemovedAddress) - 1);
    bleRemovedAddressType = bleSavedAddressType;
  }

  bleRemovalInProgress = true;
  bleRemovalDisconnectRequested = false;
  bleRemovalDisconnectRetryAt = 0;
  bleProfileValid = false;
#if DSPI_HAVE_NIMBLE
  resetBleScanState(true);
  bleConnectRequested = false;
  blePendingSave = false;
  if (bleReportQueue) xQueueReset(bleReportQueue);
  memset(bleInputSources, 0, sizeof(bleInputSources));
  bleInputSourceCount = 0;
  if (bleStackReady && bleRemovedAddress[0]) {
    NimBLEAddress address(std::string(bleRemovedAddress), bleRemovedAddressType);
    NimBLEDevice::deleteBond(address);
  }
  if (bleClient && bleClient->isConnected()) {
    bleRemovalDisconnectRequested = true;
    bleRemovalDisconnectRetryAt = millis() + 500;
    bleClient->disconnect();
  }
  bleStackRestartPending = true;
  bleStackRestartRetryAt = millis() + 100;
#endif
  lastBleScanAt = millis();
  memset(bleSavedName, 0, sizeof(bleSavedName));
  memset(bleSavedAddress, 0, sizeof(bleSavedAddress));
  memset(remoteMap, 0, sizeof(remoteMap));
  preferences.remove("ble_name");
  preferences.remove("ble_addr");
  preferences.remove("ble_type");
  preferences.remove("ble_maps");
  preferences.remove("ble_map_ver");
  preferences.remove("ble_ver");
  clampBleMenuIndex();

  bleUiMode = BLE_UI_MESSAGE;
  bleMessage = "Removing remote";
  bleMessageUntil = 0;
  bleAnimationStep = 0;
  bleLastAnimationAt = millis();
  drawBleScreen();
}

UiAction lookupRemoteMapping(const BleReportPacket &packet);

String remoteLabelForAction(uint8_t mappingIndex)
{
  if (mappingIndex >= BLE_MAPPING_COUNT || !remoteMapEntrySet(remoteMap[mappingIndex])) return "Not set";
  if (remoteMap[mappingIndex].label[0]) return String(remoteMap[mappingIndex].label);
  return "Mapped";
}

