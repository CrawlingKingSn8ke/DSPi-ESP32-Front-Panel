// Keep function bodies below the BLE type declarations. Arduino CLI generates
// prototypes before the first function body; placing meter helpers above the
// BLE structs caused those generated prototypes to reference undeclared types.
void resetUsbMeterActivityTracker()
{
  usbMeterPacketCount = 0;
  usbMeterActivityCheckedAt = 0;
  usbMeterLastProgressAt = 0;
  usbMeterPacketCounterValid = false;
  usbMeterStreamActive = false;
}

void clearMeterReadout(const char *reason = nullptr)
{
  const bool hadVisibleReading = meterLeftActive > 0.01f ||
                                 meterRightActive > 0.01f ||
                                 meterLeftTrail > 0.01f ||
                                 meterRightTrail > 0.01f ||
                                 analogPeakSampleValid ||
                                 analogNeedleDb > -19.95f ||
                                 dspi.clipFlags != 0;

  memset(dspi.peaks, 0, sizeof(dspi.peaks));
  dspi.meterChannelCount = 0;
  dspi.clipFlags = 0;
  meterLeftActive = 0.0f;
  meterRightActive = 0.0f;
  meterLeftTrail = 0.0f;
  meterRightTrail = 0.0f;
  outputClipUntil = 0;
  analogNeedleDb = -20.0f;
  analogPeakHeldDb = -20.0f;
  analogNeedleUpdatedAt = 0;
  analogPeakHoldUntil = 0;
  analogPeakSampleValid = false;

  if (reason && hadVisibleReading) {
    Serial.printf("DSPi meters cleared: %s\n", reason);
  }
}

void resetMetersForStateChange(const char *reason)
{
  resetUsbMeterActivityTracker();
  meterPollFailureCount = 0;
  clearMeterReadout(reason);
}


uint16_t blend565(uint16_t bg, uint16_t fg, uint8_t alpha)
{
  if (alpha == 0) return bg;
  if (alpha == 255) return fg;

  uint8_t br = (bg >> 11) & 0x1F;
  uint8_t bgc = (bg >> 5) & 0x3F;
  uint8_t bb = bg & 0x1F;

  uint8_t fr = (fg >> 11) & 0x1F;
  uint8_t fg2 = (fg >> 5) & 0x3F;
  uint8_t fb = fg & 0x1F;

  uint8_t r = (fr * alpha + br * (255 - alpha)) / 255;
  uint8_t g = (fg2 * alpha + bgc * (255 - alpha)) / 255;
  uint8_t b = (fb * alpha + bb * (255 - alpha)) / 255;

  return (r << 11) | (g << 5) | b;
}


