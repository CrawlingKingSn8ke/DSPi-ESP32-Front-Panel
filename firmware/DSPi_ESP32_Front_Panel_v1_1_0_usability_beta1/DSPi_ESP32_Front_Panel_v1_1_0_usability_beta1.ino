#define C_WHITE        0xFFFF
#define C_DIM          0x7BEF
#define C_LINE         0x31A6
#define C_CYAN         0x7EFC
#define C_CYAN_SOFT    0x4DFF
#define C_CYAN_DARK    0x22F7
#define C_BLUE         0x2A3F
#define C_PURPLE       0x801F
