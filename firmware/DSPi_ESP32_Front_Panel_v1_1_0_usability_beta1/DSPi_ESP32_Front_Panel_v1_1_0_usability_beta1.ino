// -----------------------------------------------------------------------------
// Serial diagnostics and boot
// -----------------------------------------------------------------------------

void printHelp()
{
  Serial.println();
  Serial.println("DSPi Front Panel v1.1.0-usability beta 1");
  Serial.println("u/d = navigate (volume on home)");
  Serial.println("r = search for BLE remote");
  Serial.println("o = select/OK, b = back, h = home, m = mute");
  Serial.println("i = force full DSPi state refresh");
  Serial.println();
}

void servicePresetSaveCompletion()
{
  if (!presetSaveCompletionPending ||
      (long)(millis() - presetSaveCompletionAt) < 0) return;

  presetSaveCompletionAttempts++;
  if (syncCurrentState(true)) {
    presetSaveCompletionPending = false;
    showToast("Preset saved");
    redrawCurrentView();
  } else if (presetSaveCompletionAttempts < 4) {
    presetSaveCompletionAt = millis() + 250;
  } else {
    // 0x90 was accepted, but the post-blackout verification link did not
    // recover in time. Do not incorrectly report a definite flash failure.
    presetSaveCompletionPending = false;
    showToast("Save accepted");
    redrawCurrentView();
  }
}

void handleSerial()
{
  while (Serial.available() > 0) {
    char c = Serial.read();
    if (c == '\r' || c == '\n' || c == ' ') continue;
    if (c == 'u') dispatchUiAction(ACT_NAV_UP);
    else if (c == 'd') dispatchUiAction(ACT_NAV_DOWN);
    else if (c == 'o') dispatchUiAction(ACT_SELECT);
    else if (c == 'b') dispatchUiAction(ACT_BACK);
    else if (c == 'h') dispatchUiAction(ACT_HOME);
    else if (c == 'm') dispatchUiAction(ACT_MUTE);
    else if (c == 'v') dispatchUiAction(ACT_VISUALIZER_TOGGLE);
    else if (c == 'i') { syncCurrentState(true); redrawCurrentView(); }
    else if (c == 'r') bleStartUserScan();
    else if (c == '?') printHelp();
  }
}

void bootUiFadeIn()
{
  drawHome();
  uint8_t target = (uint8_t)map(brightnessPercent, 0, 100, 0, BL_MAX);
  for (uint8_t step = 0; step <= 40; step++) {
    setBacklight((uint8_t)((step * target) / 40UL));
    delay(24);
  }
  screenDimmed = false;
  backlightFadeActive = false;
  lastUserActivityAt = millis();
}

void bootSplash()
{
  for (uint8_t step = 0; step <= 26; step++) {
    uint8_t alpha = (uint8_t)((step * BL_MAX) / 26UL);
    canvas->fillScreen(C_BLACK);
    drawFontCentred(FontLarge, 68, "DSPi", blend565(C_BLACK, C_WHITE, alpha));
    canvas->flush();
    setBacklight(alpha);
    delay(45);
  }
  delay(120);
  for (int step = 16; step >= 0; step--) {
    uint8_t alpha = (uint8_t)((step * BL_MAX) / 16UL);
    canvas->fillScreen(C_BLACK);
    drawFontCentred(FontLarge, 68, "DSPi", blend565(C_BLACK, C_WHITE, alpha));
    canvas->flush();
    setBacklight(alpha);
    delay(30);
  }
  canvas->fillScreen(C_BLACK);
  canvas->flush();
  setBacklight(0);
}

void setup()
{
  Serial.begin(115200);
  delay(350);

  pinMode(LCD_BL, OUTPUT);
  digitalWrite(LCD_BL, LOW);
  pinMode(LCD_CS, OUTPUT);
  digitalWrite(LCD_CS, HIGH);

  if (!panel->begin()) {
    Serial.println("panel->begin() failed");
    while (true) delay(1000);
  }
  if (!canvas->begin()) {
    Serial.println("canvas->begin() failed");
    while (true) delay(1000);
  }

  Serial.printf("MEM: heap free=%u largest=%u PSRAM free=%u total=%u\n",
                (unsigned)ESP.getFreeHeap(),
                (unsigned)ESP.getMaxAllocHeap(),
                (unsigned)ESP.getFreePsram(),
                (unsigned)ESP.getPsramSize());

  canvas->fillScreen(C_BLACK);
  canvas->flush();
  ledcAttach(LCD_BL, BL_PWM_FREQ, BL_PWM_RES);
  setBacklight(0);

  preferences.begin("dspi-panel", false);
  brightnessPercent = constrain(preferences.getUChar("brightness", 80), (uint8_t)10, (uint8_t)100);
  screenTimeoutOption = std::min<uint8_t>(preferences.getUChar("screen_to", 0), 4);
  screenDimPercent = preferences.getUChar("screen_dim", 20);
  if (screenDimPercent > 80 || (screenDimPercent % 10) != 0) screenDimPercent = 20;
  loadRemoteProfile();
  beginBleRemote();

  // Safe display defaults used until the first successful DSPi readback.
  dspi.platform = 1;
  dspi.firmwareMajor = 1;
  dspi.firmwareMinorPatchBcd = 0x15;
  dspi.outputChannels = 9;
  dspi.source = SRC_USB;
  dspi.volumeDb = -38.5f;
  dspi.masterVolumeDb = 0.0f;
  dspi.masterVolumeMode = 0;
  dspi.activePreset = 0;
  dspi.loudnessReferenceSpl = 83.0f;
  dspi.loudnessIntensity = 100.0f;
  dspi.crossfeedFrequencyHz = 700.0f;
  dspi.crossfeedFeedDb = 4.5f;
  dspi.levellerAmount = 50.0f;
  dspi.levellerMaxGainDb = 15.0f;
  dspi.levellerGateDb = -96.0f;
  dspi.levellerLookahead = true;
  dspi.psybassCutoffHz = 80.0f;
  dspi.psybassHarmonicsDb = 0.0f;
  dspi.psybassDriveDb = 6.0f;
  dspi.psybassCharacterPct = 50.0f;
  dspi.psybassOriginalDb = 0.0f;
  dspi.sampleRate = 48000;
  dspi.spdifInputCount = 3;
  dspi.spdifOptionalEnableMask = 0;
  dspi.spdifPins[0] = 5;
  dspi.spdifPins[1] = 20;
  dspi.spdifPins[2] = 21;
  dspi.adatInputEnabled = false;
  dspi.adatInputPin = 0xFF;
  strncpy(dspi.presetNames[0], "Default", sizeof(dspi.presetNames[0]) - 1);

  beginEncoder();
  DspiSerial.begin(DSPI_UART_BAUD, SERIAL_8N1, DSPI_UART_RX_PIN, DSPI_UART_TX_PIN);
  dspiDrainRx();

  printHelp();
  bootSplash();

  bool connected = false;
  for (uint8_t attempt = 0; attempt < 6 && !connected; attempt++) {
    connected = syncCurrentState(attempt == 0);
    if (!connected) delay(250);
  }
  if (!connected) Serial.println("DSPi UART not responding. Confirm beta5 UART is enabled and TX/RX are crossed.");

  bootUiFadeIn();
}

void loop()
{
  handleSerial();
  pollBleRemote();
  pollEncoder();
  pollEncoderLongPress();
  serviceScreenPower();
  servicePresetSaveCompletion();

  if (uiView == VIEW_FEATURE_CONFIRM && featureConfirmUntil &&
      (long)(millis() - featureConfirmUntil) >= 0) {
    dismissFeatureConfirmation();
  }

  if (uiView == VIEW_CHANGE_OVERLAY && changeOverlayUntil &&
      (long)(millis() - changeOverlayUntil) >= 0) {
    dismissChangeOverlay();
  }

  // Keep BLE search/pair/learn animation cadence independent of the blocking
  // UART state sweep. The overdue sweep runs immediately after leaving BLE.
  bool deferDspiSync = uiView == VIEW_BLE;

  if (notificationRefreshAt && (long)(millis() - notificationRefreshAt) >= 0) {
    notificationRefreshAt = 0;
    stateRefreshRequested = true;
  }

  if (!deferDspiSync && delayedRefreshAt && (long)(millis() - delayedRefreshAt) >= 0) {
    delayedRefreshAt = 0;
    lastStateSyncAt = millis();
    syncCurrentState(false);
    redrawCurrentView();
  }

  if (!dspi.connected) {
    if (!deferDspiSync && millis() - lastConnectAttemptAt >= 1000) {
      lastConnectAttemptAt = millis();
      if (syncCurrentState(true)) redrawCurrentView();
    }
  } else {
    bool refreshDebouncing = delayedRefreshAt != 0 || notificationRefreshAt != 0;
    if (!deferDspiSync && !refreshDebouncing && stateRefreshRequested &&
        millis() - lastStateSyncAt >= 120) {
      lastStateSyncAt = millis();
      syncCurrentState(false);
      redrawCurrentView();
    } else if (!deferDspiSync && !refreshDebouncing &&
               millis() - lastStateSyncAt >= 1200) {
      lastStateSyncAt = millis();
      syncCurrentState(false);
      if (uiView != VIEW_EDIT && uiView != VIEW_BLE && uiView != VIEW_VISUALIZER) redrawCurrentView();
    }

    if ((uiView == VIEW_HOME || uiView == VIEW_VISUALIZER) && millis() - lastMeterAt >= METER_POLL_MS) {
      lastMeterAt = millis();
      float leftWidth = 0.0f;
      float rightWidth = 0.0f;
      if (pollMeters()) {
        meterPollFailureCount = 0;
        const bool transportFresh = meterTransportHasFreshAudio();
        if (!transportFresh) {
          // The Pico can retain its last peak sample when an input transport
          // stops. Do not animate toward that stale value.
          clearMeterReadout(nullptr);
        } else {
          analogPeakSampleValid = true;
          const uint8_t meterLeft = meterLeftChannelIndex();
          const uint8_t meterRight = meterRightChannelIndex();
          // Preserve the accepted slower decay on user mute; transport loss and
          // source changes use the immediate clear path above.
          if (!dspi.muted) {
            leftWidth = peakToMeterWidth(dspi.peaks[meterLeft], 266.0f);
            rightWidth = peakToMeterWidth(dspi.peaks[meterRight], 266.0f);
          }
          updateMeterBallistics(leftWidth, rightWidth);
        }
        updateAnalogNeedle();
      } else {
        analogPeakSampleValid = false;
        resetAnalogPeakHold(-20.0f);
        if (meterPollFailureCount < 255) meterPollFailureCount++;
        if (meterPollFailureCount >= METER_FAILURE_CLEAR_COUNT) {
          clearMeterReadout("meter status unavailable");
        } else {
          updateMeterBallistics(0.0f, 0.0f);
        }
        updateAnalogNeedle();
      }

      if (uiView == VIEW_VISUALIZER) {
        drawVisualizer();
      } else {
        drawHome();
      }
    }
  }

  if (toastText.length() && (long)(millis() - toastUntil) >= 0) {
    toastText = "";
    if (uiView == VIEW_HOME) drawHome();
    else if (uiView == VIEW_VISUALIZER) drawVisualizer();
  }

  delay(2);
}
