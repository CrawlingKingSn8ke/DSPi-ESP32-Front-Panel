/*
  DSPi Front Panel v1.1.0-usability beta 1
  Target DSPi firmware: v1.1.5-beta5

  Board:
  Waveshare ESP32-S3-LCD-2, landscape 320 x 240

  Functions implemented:
  - Real DSPi UART control and state readback
  - Real post-DSP L/R output peak meters
  - Rotary encoder menu and user-volume control
  - Two-level listening menu: input, presets, loudness, crossfeed, leveller, Psycho Bass, BLE remote, system
  - White feature symbols matched to the macOS DSPi Console choices
  - Clean encoder/serial menu navigation
  - BLE HID/proprietary remote search, pairing, automatic reconnect and button learning
  - BLE remote profile and key mappings stored in ESP32 NVS (no SD card)
  - Interrupt-driven rotary encoder capture prevents lost/reversed volume steps
  - Two physical encoder notches equal one menu step; volume remains 0.5 dB per notch
  - Aligned Remote menu naming, single Pairing label and animated turquoise spinner
  - Multi-service BLE input subscriptions for remotes such as Amazon Fire TV
  - HID Report Reference identity retained in learned button mappings
  - Report Protocol and Exit Suspend setup for compatible HID remotes
  - Native anti-aliased main-menu font with accurate visual centring
  - Clean navigation dots replace pixelated fraction counters
  - Preset selector lists occupied slots only; no empty or duplicate entries
  - Complete Loudness, Crossfeed and Leveller parameter menus from Pico source truth
  - Turquoise text-only edit indication with Select=apply and Back=cancel
  - User-facing preset numbering is P1-P10 while firmware remains zero-based
  - R10 typography, centring, menu dots, preset filtering and turquoise edit style retained
  - Full 15-key Fire remote role mapping with no unmapped-key fallback actions
  - Five configurable Home Screen D-pad shortcuts for Up, Down, Left, Right and Centre
  - Direction keys follow dot orientation: horizontal Left/Right, vertical Up/Down
  - User Volume remains the daily listening control; Volume Limit controls DSPi Master Volume
  - System > Volume Limit uses verified 0xD2 set and 0xD3 readback
  - Fixed-size Volume Limit typography across its complete range
  - Five-second encoder hold opens a full-screen stereo L/R segmented VU display
  - Encoder rotation still changes User Volume while the VU display is active
  - VU display keeps the current User Volume visible and Back/one press exits
  - Home-shortcut toggles show a brief clean On/Off confirmation
  - Enabled feature symbols remain exactly as before; disabled symbols remain hidden
  - Preset page refreshes Console-saved slot names whenever it is opened
  - Save Current captures the active DSPi preset through the native 0x90 command
  - Global Volume Limit is persisted through DSPi independent storage
  - Large confirmed preset and input change screens for distance viewing
  - Screen timeout, dim level and brightness settings with non-blocking wake/dim fades
  - Complete six-source beta5 Input editor with verified dynamic availability
  - S/PDIF 1/2/3 and ADAT lock/rate status from exact protocol responses
  - Approved analogue combined-peak VU page after the unchanged stereo VU
  - Meter snapshots clear on source/preset/link changes and inactive USB streams
  - Single saved BLE remote ownership with state-derived menu rows
  - Remove Remote completes disconnect, bond deletion and stack restart before success

  Required display library:
  GFX Library for Arduino

  First-run serial controls at 115200 baud:
  u/d = volume, o = OK, b = back, h = home, m = mute, v = VU meter
  i = full DSPi refresh, r = BLE remote search
*/

#include <Arduino.h>
#include <Arduino_GFX_Library.h>
#include <pgmspace.h>
#include "AnalogVuFace320x240.h"
#include <math.h>
#include <algorithm>
#include <SPI.h>
#include <Preferences.h>
#include <NimBLEDevice.h>
#include <driver/gpio.h>

#define DSPI_HAVE_NIMBLE 1

#define LCD_SCLK 39
#define LCD_MOSI 38
#define LCD_MISO 40
#define LCD_DC   42
#define LCD_RST  -1
#define LCD_CS   45
#define LCD_BL    1
#define BL_PWM_CH 0
#define BL_PWM_FREQ 5000
#define BL_PWM_RES 8
#define BL_MAX 232

// Front-panel wiring (Waveshare ESP32-S3-LCD-2)
// Use clean GPIO16/GPIO17 on the left header for the DSPi control UART.
// This avoids the board-labelled TXD/RXD pins (GPIO43/44).
//   ESP32 GPIO16, left header pin 25 = RX from DSPi Pico GPIO16 TX
//   ESP32 GPIO17, left header pin 24 = TX to DSPi Pico GPIO17 RX
#define DSPI_UART_RX_PIN 16
#define DSPI_UART_TX_PIN 17
#define DSPI_UART_BAUD 115200
// Encoder connections on the labelled breakout headers:
//   CLK -> GPIO47, right header pin 5
//   DT  -> GPIO48, right header pin 6
//   SW -> GPIO21, left header pin 22
#define ENCODER_A_PIN 47
#define ENCODER_B_PIN 48
#define ENCODER_SW_PIN 21

#define METER_POLL_MS 55
// USB audio can stop without the Pico rewriting its last peak sample. Watch
// the firmware packet counter so the UI can invalidate stale meter data when
// Windows switches to another playback device or closes the USB stream.
#define USB_METER_ACTIVITY_POLL_MS 110
#define USB_METER_STALE_MS 300
#define METER_FAILURE_CLEAR_COUNT 2
#define DSPI_RESPONSE_TIMEOUT_MS 160
#define DSPI_TRANSACTION_ATTEMPTS 2
#define DSPI_RETRY_DELAY_MS 12
#define DSPI_RECOVERY_MIN_MS 60
#define DSPI_RECOVERY_MAX_MS 90
#define DSPI_RECOVERY_QUIET_MS 12
#define DSPI_NOTIFICATION_REFRESH_MS 250
#define CHANGE_OVERLAY_MS 1800
#define PRESET_SAVE_REFRESH_MS 350
#define SCREEN_FADE_MS 320
#define ENCODER_DEBOUNCE_MS 25
#define ENCODER_LONG_PRESS_MS 750
#define ENCODER_VISUALIZER_HOLD_MS 5000
#define ENCODER_COUNTS_PER_DETENT 2
#define ENCODER_MENU_DETENTS_PER_STEP 2
#define BLE_SCAN_TIME_MS 8000
#define BLE_RECONNECT_SCAN_MS 2500
#define BLE_RESCAN_INTERVAL_MS 5000
#define BLE_MAX_DEVICES 8
#define BLE_MAPPING_COUNT 15
#define BLE_PROFILE_VERSION 3
#define BLE_MAPPING_VERSION 4
#define HOME_SHORTCUT_COUNT 5
#define HOME_SHORTCUT_OPTION_COUNT 13
#define HOME_SHORTCUT_VERSION 2
#define BLE_REPEAT_DELAY_MS 350
#define BLE_REPEAT_INTERVAL_MS 120
#define BLE_REPEAT_ACCEL_1_MS 1400
#define BLE_REPEAT_ACCEL_2_MS 3200
#define BLE_REPEAT_ACCEL_3_MS 5200
#define BLE_HELD_FAILSAFE_MS 8000
#define VISUALIZER_SEGMENT_COUNT 19
#define BLE_MAX_INPUT_SOURCES 32

#define LCD_NATIVE_W 240
#define LCD_NATIVE_H 320
#define UI_W 320
#define UI_H 240
#define LCD_ROTATION 1

Arduino_DataBus *bus = new Arduino_ESP32SPI(
  LCD_DC,
  LCD_CS,
  LCD_SCLK,
  LCD_MOSI,
  LCD_MISO
);

Arduino_GFX *panel = new Arduino_ST7789(
  bus,
  LCD_RST,
  LCD_ROTATION,
  true,
  LCD_NATIVE_W,
  LCD_NATIVE_H
);

Arduino_Canvas *canvas = new Arduino_Canvas(UI_W, UI_H, panel);

