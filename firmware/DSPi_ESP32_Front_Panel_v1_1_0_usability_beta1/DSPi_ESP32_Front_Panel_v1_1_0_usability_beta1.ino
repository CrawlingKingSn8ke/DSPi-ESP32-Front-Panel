  else if ((isSpdifSource(dspi.source) && dspi.spdifState != 2) ||
           (dspi.source == SRC_ADAT && dspi.adatState != 3)) colour = C_ORANGE;
  drawFontCentred(FontMedium, y, audioMetaText(), colour);
}

uint16_t mix565(uint16_t a, uint16_t b, uint8_t amount)
{
  uint8_t ar = (a >> 11) & 0x1F, ag = (a >> 5) & 0x3F, ab = a & 0x1F;
  uint8_t br = (b >> 11) & 0x1F, bg = (b >> 5) & 0x3F, bb = b & 0x1F;
  uint8_t r = (ar * (255 - amount) + br * amount) / 255;
  uint8_t g = (ag * (255 - amount) + bg * amount) / 255;
  uint8_t bl = (ab * (255 - amount) + bb * amount) / 255;
  return (r << 11) | (g << 5) | bl;
}

uint16_t meterGradientColour(uint16_t x, uint16_t maxWidth)
{
  if (maxWidth == 0) return C_CYAN_SOFT;
  uint16_t pos = (x * 1000UL) / maxWidth;
  if (pos < 500) return C_CYAN;
  if (pos < 820) return mix565(C_CYAN, C_ORANGE, (uint8_t)(((pos - 500) * 255UL) / 320UL));
  return mix565(C_ORANGE, C_RED, (uint8_t)(((pos - 820) * 255UL) / 180UL));
}

float peakToMeterWidth(uint16_t peak, float fullWidth)
{
  if (peak == 0) return 0.0f;
  float linear = (float)peak / 32767.0f;
  float dbfs = 20.0f * log10f(max(linear, 0.000001f));
  float normalized = constrain((dbfs + 60.0f) / 60.0f, 0.0f, 1.0f);
  return normalized * fullWidth;
}

void updateMeterBallistics(float targetLeft, float targetRight)
{
  const float fallCoefficient = dspi.muted ? 0.045f : 0.24f;
  const float trailCoefficient = dspi.muted ? 0.025f : 0.13f;
  if (targetLeft >= meterLeftActive) meterLeftActive += (targetLeft - meterLeftActive) * 0.78f;
  else meterLeftActive += (targetLeft - meterLeftActive) * fallCoefficient;
  if (targetRight >= meterRightActive) meterRightActive += (targetRight - meterRightActive) * 0.78f;
  else meterRightActive += (targetRight - meterRightActive) * fallCoefficient;

  if (meterLeftTrail < meterLeftActive) meterLeftTrail = meterLeftActive;
  else meterLeftTrail += (meterLeftActive - meterLeftTrail) * trailCoefficient;
  if (meterRightTrail < meterRightActive) meterRightTrail = meterRightActive;
  else meterRightTrail += (meterRightActive - meterRightTrail) * trailCoefficient;
}

bool outputClipActive()
{
  return outputClipUntil != 0 && (long)(outputClipUntil - millis()) > 0;
}

struct AnalogScalePoint {
  float db;
  float x;
};

// The static bitmap and the live pointer share this exact calibration.
// X positions are the labelled major ticks on the approved face.
static constexpr AnalogScalePoint ANALOG_SCALE_POINTS[] = {
  {-20.0f,  21.0f},
  {-10.0f,  59.0f},
  { -7.0f,  95.0f},
  { -5.0f, 135.0f},
  { -3.0f, 173.0f},
  { -1.0f, 208.0f},
  {  0.0f, 232.0f},
  {  1.0f, 256.0f},
  {  3.0f, 280.0f},
  {  5.0f, 300.0f},
};

static constexpr size_t ANALOG_SCALE_POINT_COUNT =
    sizeof(ANALOG_SCALE_POINTS) / sizeof(ANALOG_SCALE_POINTS[0]);

// Centre line of the upper scale arc in the locked 320x240 face.
// The live pointer tip is placed seven pixels outward along the curve normal,
// so it lands inside the relevant tick instead of relying on hand-tuned Y values.
static constexpr float ANALOG_ARC_A = 0.00165639779f;
static constexpr float ANALOG_ARC_B = -0.537353311f;
static constexpr float ANALOG_ARC_C = 126.759248f;
static constexpr float ANALOG_NEEDLE_TIP_OFFSET_PX = 7.0f;
static constexpr unsigned long ANALOG_PEAK_HOLD_MS = 180;

float analogUpperArcY(float x)
{
  return ANALOG_ARC_A * x * x + ANALOG_ARC_B * x + ANALOG_ARC_C;
}

float analogScaleXForDb(float db)
{
  db = constrain(db,
                 ANALOG_SCALE_POINTS[0].db,
                 ANALOG_SCALE_POINTS[ANALOG_SCALE_POINT_COUNT - 1].db);

  for (size_t i = 0; i + 1 < ANALOG_SCALE_POINT_COUNT; ++i) {
    const AnalogScalePoint &a = ANALOG_SCALE_POINTS[i];
    const AnalogScalePoint &b = ANALOG_SCALE_POINTS[i + 1];
    if (db >= a.db && db <= b.db) {
      const float t = (db - a.db) / (b.db - a.db);
      return a.x + (b.x - a.x) * t;
    }
  }

  return ANALOG_SCALE_POINTS[ANALOG_SCALE_POINT_COUNT - 1].x;
}

float analogPeakSampleToDbfs(uint16_t peak)
{
  if (peak == 0) return -120.0f;

  // DSPi beta5 reports unsigned Q15 output peaks:
  // 32767 = 0 dBFS, 16384 = approximately -6.02 dBFS.
  const float linear = (float)peak / 32767.0f;
  return 20.0f * log10f(max(linear, 0.000001f));
}

float combinedOutputPeakDbfs()
{
  if (!dspi.connected || dspi.muted || !analogPeakSampleValid) return -40.0f;

  const uint8_t leftIndex = meterLeftChannelIndex();
  const uint8_t rightIndex = meterRightChannelIndex();
  if (rightIndex >= dspi.meterChannelCount || rightIndex >= 17) return -20.0f;

  // Combined PEAK meter: use the louder channel. Never average L/R because
  // averaging can hide a real peak on one channel.
  const uint16_t combinedPeak = max(dspi.peaks[leftIndex], dspi.peaks[rightIndex]);
  return constrain(analogPeakSampleToDbfs(combinedPeak), -40.0f, 0.0f);
}

float analogDisplayVuFromDbfs(float dbfs)
{
  // Display-only calibration. DSPi peak data and the stereo meter remain raw.
  // Normal programme around -20..-10 dBFS now occupies -10..0 VU, while the
  // final 10 dB of headroom is compressed into the face's 0..+5 VU region.
  dbfs = constrain(dbfs, -40.0f, 0.0f);
  if (dbfs <= -20.0f) return -20.0f + (dbfs + 40.0f) * 0.5f;
  if (dbfs <= -10.0f) return -10.0f + (dbfs + 20.0f);
  return (dbfs + 10.0f) * 0.5f;
}

void resetAnalogPeakHold(float seedDb)
{
  analogPeakHeldDb = constrain(seedDb, -20.0f, 0.0f);
  analogPeakHoldUntil = 0;
}

float analogPeakTargetDb()
{
  if (outputClipActive()) return 5.0f;

  if (!dspi.connected || dspi.muted || !analogPeakSampleValid) {
    resetAnalogPeakHold(-20.0f);
    return -20.0f;
  }

  const unsigned long now = millis();
  const float sampleDb = analogDisplayVuFromDbfs(combinedOutputPeakDbfs());
  const bool holdExpired =
      analogPeakHoldUntil == 0 || (long)(now - analogPeakHoldUntil) >= 0;

  if (sampleDb >= analogPeakHeldDb) {
    analogPeakHeldDb = sampleDb;
    analogPeakHoldUntil = now + ANALOG_PEAK_HOLD_MS;
  } else if (holdExpired) {
    analogPeakHeldDb = sampleDb;
    analogPeakHoldUntil = 0;
  }

  return analogPeakHeldDb;
}

void updateAnalogNeedle()
{
  const unsigned long now = millis();
  const float targetDb = analogPeakTargetDb();

  if (analogNeedleUpdatedAt == 0) {
    analogNeedleUpdatedAt = now;
    analogNeedleDb = targetDb;
    return;
  }

  const float dt = constrain((now - analogNeedleUpdatedAt) / 1000.0f,
                             0.001f, 0.250f);
  analogNeedleUpdatedAt = now;

  // Fast attack plus a short true-peak hold prevents a one-frame transient
  // being visually reduced by the mechanical smoothing. Release remains slow.
  const float attackTauSeconds = 0.018f;
  const float releaseTauSeconds = 0.320f;
  const float tau = targetDb >= analogNeedleDb
                  ? attackTauSeconds : releaseTauSeconds;
  const float coefficient = 1.0f - expf(-dt / tau);

  analogNeedleDb += (targetDb - analogNeedleDb) * coefficient;
  analogNeedleDb = constrain(analogNeedleDb, -20.0f, 5.0f);
}

void analogVuNeedlePointForDb(float db, int16_t &x, int16_t &y)
{
  const float scaleX = analogScaleXForDb(db);
  const float scaleY = analogUpperArcY(scaleX);
  const float slope = 2.0f * ANALOG_ARC_A * scaleX + ANALOG_ARC_B;

  // Outward/upward unit normal for y=f(x): (slope, -1).
  float nx = slope;
  float ny = -1.0f;
  const float length = sqrtf(nx * nx + ny * ny);
  if (length > 0.0001f) {
    nx /= length;
    ny /= length;
  }

  x = (int16_t)lroundf(scaleX + nx * ANALOG_NEEDLE_TIP_OFFSET_PX);
  y = (int16_t)lroundf(scaleY + ny * ANALOG_NEEDLE_TIP_OFFSET_PX);
}

void drawAnalogVuLockedFace()
{
  static_assert(ANALOG_VU_FACE_WIDTH == UI_W,
                "Analogue VU bitmap width must match the 320px canvas");
  static_assert(ANALOG_VU_FACE_HEIGHT == UI_H,
                "Analogue VU bitmap height must match the 240px canvas");

  // The approved RGB565 face is restored in full before every needle frame.
  canvas->draw16bitRGBBitmap(
      0,
      0,
      const_cast<uint16_t *>(ANALOG_VU_FACE_320X240),
      ANALOG_VU_FACE_WIDTH,
      ANALOG_VU_FACE_HEIGHT);
}

void drawAnalogVuNeedle()
{
  const uint16_t needle = canvas->color565(2, 13, 31);
  const uint16_t shadow = canvas->color565(12, 56, 96);
  const uint16_t hubOuter = canvas->color565(1, 8, 18);
  const uint16_t hubInner = canvas->color565(18, 24, 34);

  static constexpr int16_t pivotX = 160;
  static constexpr int16_t pivotY = 232;

  int16_t tipX = 21;
  int16_t tipY = 116;
  analogVuNeedlePointForDb(analogNeedleDb, tipX, tipY);

  // Subtle offset shadow, followed by a three-pixel dark needle.
  canvas->drawLine(pivotX + 2, pivotY + 1, tipX + 2, tipY + 1, shadow);
  canvas->drawLine(pivotX - 1, pivotY, tipX - 1, tipY, needle);
  canvas->drawLine(pivotX,     pivotY, tipX,     tipY, needle);
  canvas->drawLine(pivotX + 1, pivotY, tipX + 1, tipY, needle);

  // Bottom-centre mechanical pivot, intentionally clipped by the screen edge.
  canvas->fillRoundRect(145, 215, 30, 32, 15, needle);
  canvas->fillCircle(pivotX, pivotY, 8, hubOuter);
  canvas->fillCircle(pivotX, pivotY, 6, hubInner);
  canvas->drawCircle(pivotX, pivotY, 7, needle);
}

void drawAnalogVisualizer()
{
  uiView = VIEW_VISUALIZER;

  // Restore the complete locked face before drawing the moving needle. This
  // erases the previous pointer without redrawing any static face element.
  drawAnalogVuLockedFace();
  drawAnalogVuNeedle();
  canvas->flush();
}

void drawGradientBar(int16_t x, int16_t y, int16_t activeW, int16_t trailW, int16_t fullW, int16_t h)
{
  activeW = constrain(activeW, (int16_t)0, fullW);
  trailW = constrain(trailW, activeW, fullW);
  canvas->fillRect(x, y, fullW, h, C_BLACK);

  for (int16_t px = 0; px < activeW; px++) {
    canvas->fillRect(x + px, y, 1, h, meterGradientColour(px, fullW));
  }
  int16_t fadeSpan = trailW - activeW;
  for (int16_t px = activeW; px < trailW && fadeSpan > 0; px++) {
    uint8_t fade = (uint8_t)(((trailW - px) * 120UL) / fadeSpan);
    canvas->fillRect(x + px, y, 1, h,
                     blend565(C_BLACK, meterGradientColour(px, fullW), fade));
  }
}

void drawLevelBars()
{
  const int16_t fullW = 266;
  const int16_t x = 24;
  const int16_t h = 4;
  const int16_t y1 = 214;
  const int16_t y2 = 223;

  canvas->setTextSize(1);
  canvas->setTextColor(C_WHITE);
  canvas->setCursor(8, y1 - 1); canvas->print("L");
  canvas->setCursor(8, y2 - 1); canvas->print("R");

  drawGradientBar(x, y1, (int16_t)meterLeftActive, (int16_t)meterLeftTrail, fullW, h);
  drawGradientBar(x, y2, (int16_t)meterRightActive, (int16_t)meterRightTrail, fullW, h);

  if (outputClipActive()) {
    canvas->setCursor(295, 216);
    canvas->setTextColor(C_RED);
    canvas->print("OVR");
  }
}

void drawFontCentredGlow(const FontDef &font, int16_t y, const String &text)
{
