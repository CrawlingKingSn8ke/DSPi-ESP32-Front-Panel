{
  switch (option) {
    case 0: return "Off";
    case 1: return "30 seconds";
    case 2: return "1 minute";
    case 3: return "3 minutes";
    case 4: return "5 minutes";
    default: return "Off";
  }
}

String screenDimText(uint8_t percent)
{
  return percent == 0 ? "Screen Off" : String(percent);
}

String currentEditValue()
{
  if (!editActive) return "";
  if (menuPage == PAGE_INPUT) return sourceMenuText((InputSource)editInt);
  if (menuPage == PAGE_PRESET && menuIndex == 0) return "P" + String(editInt + 1);
  if (menuPage == PAGE_LOUDNESS) {
    if (menuIndex == 0) return editBool ? "On" : "Off";
    return String((int)roundf(editFloat));
  }
  if (menuPage == PAGE_CROSSFEED) {
    if (menuIndex == 0) return editBool ? "On" : "Off";
    if (menuIndex == 1) return crossfeedProfileText(editInt);
    if (menuIndex == 2) return String((int)roundf(editFloat));
    return String(editFloat, 1);
  }
  if (menuPage == PAGE_LEVELLER) {
    if (menuIndex == 0 || menuIndex == 5) return editBool ? "On" : "Off";
    if (menuIndex == 1) return String((int)roundf(editFloat));
    if (menuIndex == 2) return levellerSpeedText(editInt);
    if (menuIndex == 3) return String(editFloat, 1);
    return String((int)roundf(editFloat));
  }
  if (menuPage == PAGE_PSYBASS) {
    if (!psybassWritable()) return "Unavailable";
    if (menuIndex == 0) return editBool ? "On" : "Off";
    if (menuIndex == 1 || menuIndex == 4 || menuIndex == 5) return String((int)roundf(editFloat));
    return String(editFloat, 1);
  }
  if (menuPage == PAGE_SYSTEM && menuIndex == 2) return String(editFloat, 1) + " dB";
  if (menuPage == PAGE_SCREEN_SETTINGS) {
    if (menuIndex == 0) return screenTimeoutText((uint8_t)editInt);
    if (menuIndex == 1) return screenDimText((uint8_t)editInt);
    return String(editInt);
  }
  return "";
}

String menuItemValue(MenuPage page, uint8_t index)
{
  if (editActive) return currentEditValue();
  if (page == PAGE_MAIN) return "";
  if (page == PAGE_INPUT) return sourceMenuText(dspi.source);
  if (page == PAGE_PRESET) {
    int8_t first = firstOccupiedPreset();
    if (first < 0) return "";
    if (index == 1) return "P" + String((int)dspi.activePreset + 1);
    return "P" + String((int)displayedPresetSlot() + 1);
  }
  if (page == PAGE_LOUDNESS) {
    if (index == 0) return dspi.loudnessEnabled ? "On" : "Off";
    if (index == 1) return String((int)roundf(dspi.loudnessReferenceSpl));
    return String((int)roundf(dspi.loudnessIntensity));
  }
  if (page == PAGE_CROSSFEED) {
    if (index == 0) return dspi.crossfeedEnabled ? "On" : "Off";
    if (index == 1) return crossfeedProfileText(dspi.crossfeedPreset);
    if (index == 2) return String((int)roundf(dspi.crossfeedFrequencyHz));
    return String(dspi.crossfeedFeedDb, 1);
  }
  if (page == PAGE_LEVELLER) {
    if (index == 0) return dspi.levellerEnabled ? "On" : "Off";
    if (index == 1) return String((int)roundf(dspi.levellerAmount));
    if (index == 2) return levellerSpeedText(dspi.levellerSpeed);
    if (index == 3) return String(dspi.levellerMaxGainDb, 1);
    if (index == 4) return String((int)roundf(dspi.levellerGateDb));
    return dspi.levellerLookahead ? "On" : "Off";
  }
  if (page == PAGE_PSYBASS) {
    if (!dspi.psybassCapabilityKnown || !dspi.psybassSupported) return "Unavailable";
    if (index == 0) return dspi.psybassEnabled ? "On" : "Off";
    if (index == 1) return String((int)roundf(dspi.psybassCutoffHz));
    if (index == 2) return String(dspi.psybassHarmonicsDb, 1);
    if (index == 3) return String(dspi.psybassDriveDb, 1);
    if (index == 4) return String((int)roundf(dspi.psybassCharacterPct));
    return String((int)roundf(dspi.psybassOriginalDb));
  }
  if (page == PAGE_BLUETOOTH) {
    return bleMenuItemValue(index);
  }
  if (page == PAGE_SYSTEM) {
    if (index == 0) return dspi.connected ? "Ready" : "Fault";
    if (index == 1) return screenTimeoutText(screenTimeoutOption);
    return String(dspi.masterVolumeDb, 1) + " dB";
  }
  if (page == PAGE_SCREEN_SETTINGS) {
    if (index == 0) return screenTimeoutText(screenTimeoutOption);
    if (index == 1) return screenDimText(screenDimPercent);
    return String(brightnessPercent);
  }
  return "";
}

bool menuValueUsesPercent()
{
  return (menuPage == PAGE_LOUDNESS && menuIndex == 2) ||
         (menuPage == PAGE_LEVELLER && menuIndex == 1) ||
         (menuPage == PAGE_PSYBASS && menuIndex == 4) ||
         (menuPage == PAGE_SCREEN_SETTINGS && menuIndex >= 1 &&
          !(menuIndex == 1 && ((editActive ? editInt : screenDimPercent) == 0)));
}

const char *menuValueUnit()
{
  if (menuPage == PAGE_PSYBASS && !psybassWritable()) return "";
  if (menuValueUsesPercent()) return "%";
  if (menuPage == PAGE_LOUDNESS && menuIndex == 1) return "dB";
  if (menuPage == PAGE_CROSSFEED && menuIndex == 2) return "Hz";
  if (menuPage == PAGE_CROSSFEED && menuIndex == 3) return "dB";
  if (menuPage == PAGE_LEVELLER && (menuIndex == 3 || menuIndex == 4)) return "dB";
  if (menuPage == PAGE_PSYBASS && menuIndex == 1) return "Hz";
  if (menuPage == PAGE_PSYBASS && (menuIndex == 2 || menuIndex == 3 || menuIndex == 5)) return "dB";
  return "";
}

// -----------------------------------------------------------------------------
// Display rendering
// -----------------------------------------------------------------------------

void setBacklight(uint8_t level)
{
  backlightCurrent = level;
  ledcWrite(LCD_BL, level);
}

void applyBrightness()
{
  uint8_t percent = screenDimmed ? screenDimPercent : brightnessPercent;
  uint8_t pwm = (uint8_t)map(percent, 0, 100, 0, BL_MAX);
  backlightFadeActive = false;
  setBacklight(pwm);
}

uint8_t uiBrightnessPwm()
{
  return (uint8_t)map(brightnessPercent, 0, 100, 0, BL_MAX);
}

uint8_t uiDimPwm()
{
  return (uint8_t)map(screenDimPercent, 0, 100, 0, BL_MAX);
}

uint32_t screenTimeoutMs()
{
  static const uint32_t values[] = {0, 30000, 60000, 180000, 300000};
  return values[std::min<uint8_t>(screenTimeoutOption, 4)];
}

void startBacklightFade(uint8_t target)
{
  backlightFadeFrom = backlightCurrent;
  backlightFadeTo = target;
  backlightFadeStartedAt = millis();
  backlightFadeActive = backlightFadeFrom != backlightFadeTo;
  if (!backlightFadeActive) setBacklight(target);
}

void serviceBacklightFade()
{
  if (!backlightFadeActive) return;
  uint32_t elapsed = millis() - backlightFadeStartedAt;
  if (elapsed >= SCREEN_FADE_MS) {
    backlightFadeActive = false;
    setBacklight(backlightFadeTo);
    return;
  }

  int32_t span = (int32_t)backlightFadeTo - (int32_t)backlightFadeFrom;
  uint8_t level = (uint8_t)((int32_t)backlightFadeFrom +
                  (span * (int32_t)elapsed) / (int32_t)SCREEN_FADE_MS);
  setBacklight(level);
}

void recordUserActivity()
{
  lastUserActivityAt = millis();
  if (screenDimmed) {
    screenDimmed = false;
    startBacklightFade(uiBrightnessPwm());
  }
}

void serviceScreenPower()
{
  uint32_t timeout = screenTimeoutMs();
  if (!screenDimmed && timeout != 0 &&
      (uint32_t)(millis() - lastUserActivityAt) >= timeout) {
    screenDimmed = true;
    startBacklightFade(uiDimPwm());
  }
  serviceBacklightFade();
}

void fadeUiOut()
{
  backlightFadeActive = false;
  const uint8_t target = backlightCurrent;
  for (int8_t step = 8; step >= 0; step--) {
    setBacklight((uint8_t)((target * (uint16_t)step) / 8U));
    delay(7);
  }
}

void fadeUiIn()
{
  backlightFadeActive = false;
  screenDimmed = false;
  lastUserActivityAt = millis();
  const uint8_t target = uiBrightnessPwm();
  for (uint8_t step = 0; step <= 8; step++) {
    setBacklight((uint8_t)((target * (uint16_t)step) / 8U));
    delay(7);
  }
}

void drawBase()
{
  canvas->fillScreen(C_BLACK);
}

void drawTaperLine(int16_t centerX, int16_t y, int16_t length, int16_t maxThickness, uint16_t colour)
{
  (void)maxThickness;
  int16_t half = length / 2;
  for (int16_t dx = -half; dx <= half; dx++) {
    float edge = 1.0f - (fabs((float)dx) / (float)half);
    edge = edge * edge * (3.0f - (2.0f * edge));
    int16_t x = centerX + dx;
    if (x < 0 || x >= UI_W) continue;

    uint8_t alphaGlowFar = (uint8_t)(edge * 20.0f);
    uint8_t alphaGlowNear = (uint8_t)(edge * 58.0f);
    uint8_t alphaCore = (uint8_t)(edge * 255.0f);

    if (y - 2 >= 0) canvas->drawPixel(x, y - 2, blend565(C_BLACK, colour, alphaGlowFar));
    if (y - 1 >= 0) canvas->drawPixel(x, y - 1, blend565(C_BLACK, colour, alphaGlowNear));
    if (y >= 0 && y < UI_H) canvas->drawPixel(x, y, blend565(C_BLACK, colour, alphaCore));
    if (y + 1 < UI_H) canvas->drawPixel(x, y + 1, blend565(C_BLACK, colour, alphaGlowNear));
    if (y + 2 < UI_H) canvas->drawPixel(x, y + 2, blend565(C_BLACK, colour, alphaGlowFar));
  }
}

