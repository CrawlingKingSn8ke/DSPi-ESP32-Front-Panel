bool setPsybassEnabled(bool enabled)
{
  if (!psybassWritable() || !dspiSetByte(REQ_SET_PSYBASS, enabled ? 1 : 0)) return false;
  uint8_t readback = 0;
  if (!getExactByte(REQ_GET_PSYBASS, readback) || readback > 1) return false;
  dspi.psybassEnabled = readback != 0;
  return dspi.psybassEnabled == enabled;
}

bool setPsybassFloatVerified(uint8_t setRequest, uint8_t getRequest, float value,
                             float minimum, float maximum, float &stateField)
{
  if (!psybassWritable()) return false;
  value = constrain(value, minimum, maximum);
  if (!dspiSetFloat(setRequest, value)) return false;
  float readback = value;
  if (!getExactFloat(getRequest, readback) || readback < minimum || readback > maximum) return false;
  stateField = readback;
  return true;
}

