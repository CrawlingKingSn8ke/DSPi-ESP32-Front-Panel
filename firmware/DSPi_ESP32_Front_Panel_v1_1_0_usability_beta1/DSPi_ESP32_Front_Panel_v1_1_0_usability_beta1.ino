void drawVolumeTextCustom(int16_t x, int16_t y, const String &text, uint16_t colour)
{
  char prev = 0;
  for (uint16_t i = 0; i < text.length(); i++) {
    char ch = text.charAt(i);
    if (ch == ' ') { x += FontLarge.spaceAdvance; prev = ch; continue; }
    if (ch == '.') {
      x += volumeKernAdjust(prev, ch);
      drawRoundDecimalPoint(x + 9, y + 67);
      x += 20;
      prev = ch;
      continue;
    }
    const GlyphDef *g = findGlyph(FontLarge, ch);
    if (!g) continue;
    if (i > 0) x += volumeKernAdjust(prev, ch);
    drawGlyphRle(x + g->xOffset, y + g->yOffset, g, colour);
    x += g->advance;
    prev = ch;
  }
}

int16_t volumeTextWidthCustom(const String &text)
{
  int16_t width = 0;
  char prev = 0;
  for (uint16_t i = 0; i < text.length(); i++) {
    char ch = text.charAt(i);
    if (ch == ' ') { width += FontLarge.spaceAdvance; prev = ch; continue; }
    if (ch == '.') { width += volumeKernAdjust(prev, ch) + 20; prev = ch; continue; }
    const GlyphDef *g = findGlyph(FontLarge, ch);
    if (!g) continue;
    if (i > 0) width += volumeKernAdjust(prev, ch);
    width += g->advance;
    prev = ch;
  }
  return width;
}

void drawVolumeNumber(int16_t y)
{
  if (dspi.muted) {
    drawFontCentred(FontLarge, y, "Mute", C_WHITE);
    return;
  }

  String value = volumeText();
  int16_t volW = volumeTextWidthCustom(value);
  int16_t dbW = fontTextWidth(FontDb, "dB");
  int16_t dbX = UI_W - dbW - 8;
  int16_t volX = dbX - 10 - volW - 18;
  if (fabs(dspi.volumeDb) < 10.0f) volX -= 12;
  if (volX < 8) volX = 8;

  uint16_t glow = blend565(C_BLACK, C_WHITE, 108);
  drawVolumeTextCustom(volX - 1, y, value, glow);
  drawVolumeTextCustom(volX + 1, y, value, glow);
  drawVolumeTextCustom(volX, y - 1, value, glow);
  drawVolumeTextCustom(volX, y + 1, value, glow);
  drawVolumeTextCustom(volX + 1, y + 1, value, glow);
  drawVolumeTextCustom(volX, y, value, C_WHITE);
  drawDbLabel(dbX, y + 52);
}

