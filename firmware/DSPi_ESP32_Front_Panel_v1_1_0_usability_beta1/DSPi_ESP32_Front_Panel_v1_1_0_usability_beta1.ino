bool bleCanOfferFindRemote()
{
#if DSPI_HAVE_NIMBLE
  return !bleProfileValid && !bleRemovalInProgress && !bleStackRestartPending &&
         bleStackReady && !bleConnected && !bleScanActive &&
         !bleConnectRequested && !bleConnectTaskRunning &&
         (!bleClient || !bleClient->isConnected());
#else
  return false;
#endif
}

uint8_t bleMenuItemCount()
{
  if (bleProfileValid) return 5;
  return bleCanOfferFindRemote() ? 4 : 3;
}

BleMenuAction bleMenuActionForIndex(uint8_t index)
{
  static const BleMenuAction savedProfileActions[] = {
    BLE_MENU_DEVICE, BLE_MENU_KEY_MAP, BLE_MENU_SHORTCUTS,
    BLE_MENU_RESTORE_DEFAULTS, BLE_MENU_REMOVE_REMOTE
  };
  static const BleMenuAction cleanNoProfileActions[] = {
    BLE_MENU_DEVICE, BLE_MENU_FIND_REMOTE, BLE_MENU_SHORTCUTS,
    BLE_MENU_RESTORE_DEFAULTS
  };
  static const BleMenuAction busyNoProfileActions[] = {
    BLE_MENU_DEVICE, BLE_MENU_SHORTCUTS, BLE_MENU_RESTORE_DEFAULTS
  };

  if (bleProfileValid) {
    return index < 5 ? savedProfileActions[index] : BLE_MENU_NONE;
  }
  if (bleCanOfferFindRemote()) {
    return index < 4 ? cleanNoProfileActions[index] : BLE_MENU_NONE;
  }
  return index < 3 ? busyNoProfileActions[index] : BLE_MENU_NONE;
}

String bleMenuItemName(uint8_t index)
{
  switch (bleMenuActionForIndex(index)) {
    case BLE_MENU_DEVICE: return "Device";
    case BLE_MENU_FIND_REMOTE: return "Find Remote";
    case BLE_MENU_KEY_MAP: return "Key Map";
    case BLE_MENU_SHORTCUTS: return "Home Screen D-pad shortcuts";
    case BLE_MENU_RESTORE_DEFAULTS: return "Restore Defaults";
    case BLE_MENU_REMOVE_REMOTE: return "Remove Remote";
    default: return "Remote";
  }
}

String bleMenuItemValue(uint8_t index)
{
  switch (bleMenuActionForIndex(index)) {
    case BLE_MENU_DEVICE:
      return bleProfileValid ? String(bleSavedName) : "None";
    case BLE_MENU_FIND_REMOTE:
      return "Search";
    case BLE_MENU_KEY_MAP: {
      uint8_t mapped = 0;
      for (uint8_t i = 0; i < BLE_MAPPING_COUNT; i++) {
        if (remoteMapEntrySet(remoteMap[i])) mapped++;
      }
      return mapped ? String(mapped) + " set" : "Set";
    }
    case BLE_MENU_SHORTCUTS:
      return "Edit";
    case BLE_MENU_RESTORE_DEFAULTS:
      return "Reset";
    case BLE_MENU_REMOVE_REMOTE:
      return "Ready";
    default:
      return "";
  }
}

void clampBleMenuIndex()
{
  uint8_t count = bleMenuItemCount();
  menuIndex = count ? std::min<uint8_t>(menuIndex, count - 1) : 0;
  rememberedMenuIndex[PAGE_BLUETOOTH] = menuIndex;
}

uint8_t menuItemCount(MenuPage page)
{
  switch (page) {
    case PAGE_MAIN: return 8;
    case PAGE_INPUT: return 1;
    case PAGE_PRESET: return 2;
    case PAGE_LOUDNESS: return 3;
    case PAGE_CROSSFEED: return 4;
    case PAGE_LEVELLER: return 6;
    case PAGE_PSYBASS: return 6;
    case PAGE_BLUETOOTH: return bleMenuItemCount();
    case PAGE_SYSTEM: return 3;
    case PAGE_SCREEN_SETTINGS: return 3;
  }
  return 1;
}

String menuItemName(MenuPage page, uint8_t index)
{
  if (page == PAGE_MAIN) {
    const char *items[] = {"Input", "Preset", "Loudness", "Crossfeed", "Leveller", "Psy Bass", "Remote", "System"};
    return items[std::min<uint8_t>(index, 7)];
  }
  if (page == PAGE_INPUT) return "Source";
  if (page == PAGE_PRESET) return index == 0 ? "Select" : "Save Current";
  if (page == PAGE_LOUDNESS) {
    const char *items[] = {"Enable", "Reference SPL", "Strength"};
    return items[std::min<uint8_t>(index, 2)];
  }
  if (page == PAGE_CROSSFEED) {
    const char *items[] = {"Enable", "Profile", "Frequency", "Feed Level"};
    return items[std::min<uint8_t>(index, 3)];
  }
  if (page == PAGE_LEVELLER) {
    const char *items[] = {"Enable", "Amount", "Speed", "Max Gain", "Gate", "Lookahead"};
    return items[std::min<uint8_t>(index, 5)];
  }
  if (page == PAGE_PSYBASS) {
    const char *items[] = {"Enable", "Cutoff", "Harmonics", "Drive", "Character", "Original Bass"};
    return items[std::min<uint8_t>(index, 5)];
  }
  if (page == PAGE_BLUETOOTH) {
    return bleMenuItemName(index);
  }
  if (page == PAGE_SYSTEM) {
    const char *items[] = {"Status", "Screen Settings", "Volume Limit"};
    return items[std::min<uint8_t>(index, 2)];
  }
  if (page == PAGE_SCREEN_SETTINGS) {
    const char *items[] = {"Timeout", "Dim Level", "Brightness"};
    return items[std::min<uint8_t>(index, 2)];
  }
  return "";
}

