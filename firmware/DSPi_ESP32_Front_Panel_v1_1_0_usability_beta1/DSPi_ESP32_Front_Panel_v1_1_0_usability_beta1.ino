bool setInputSource(InputSource source)
{
  if ((uint8_t)source > (uint8_t)SRC_OPTICAL_3 || !inputSourceAvailable(source)) return false;
  if (!dspiSetByte(REQ_SET_INPUT_SOURCE, (uint8_t)source)) return false;

  // Source changes are deferred in beta5. Poll through the hardened transport
  // for about one second and publish only an exact matching one-byte readback.
  const unsigned long deadline = millis() + 1000;
  uint8_t readback = 0xFF;
  bool confirmed = false;
  do {
    if (getExactByte(REQ_GET_INPUT_SOURCE, readback) &&
        readback <= SRC_OPTICAL_3 && readback == (uint8_t)source) {
      confirmed = true;
      break;
    }
    if ((long)(millis() - deadline) >= 0) break;
    delay(55);
  } while ((long)(millis() - deadline) < 0);
  if (!confirmed) return false;

  InputSource oldSource = dspi.source;
  dspi.source = (InputSource)readback;
  if (oldSource != dspi.source) {
    Serial.printf("DSPi source change: old=%u new=%u reason=local SET\n",
                  (unsigned)oldSource, (unsigned)dspi.source);
  }
  dspi.spdifState = 0;
  dspi.spdifNonAudio = false;
  dspi.adatState = 0;
  resetMetersForStateChange("local input source change");
  scheduleStateRefresh(300, "local SET");
  return true;
}

bool loadPreset(uint8_t slot)
{
  // Loading asks the Pico to restore its complete slot snapshot. The source,
  // feature state and user volume remain DSPi-owned; the ESP32 stores no copy.
  uint8_t payload[2] = {0};
  uint16_t length = 0;
  if (!dspiGet(REQ_PRESET_LOAD, slot, 1, payload, sizeof(payload), length)) return false;
  if (length != 1 || payload[0] != 0) return false;
  pendingPresetOverlay = true;
  pendingPresetOverlaySlot = slot;
  resetMetersForStateChange("preset load accepted");
  scheduleStateRefresh(250, "preset refresh");
  return true;
}

bool saveCurrentPreset()
{
  if (!dspi.connected || dspi.activePreset >= 10) return false;

  uint8_t payload[1] = {0xFF};
  uint16_t length = 0;
  if (!dspiGet(REQ_PRESET_SAVE, dspi.activePreset, 1,
               payload, sizeof(payload), length) ||
      length != 1 || payload[0] != 0) return false;

  // DSPi performs the flash write in its main loop. Reconnect and refresh the
  // directory after the blackout instead of issuing more traffic immediately.
  presetSaveCompletionPending = true;
  presetSaveCompletionAttempts = 0;
  presetSaveCompletionAt = millis() + PRESET_SAVE_REFRESH_MS;
  return true;
}

